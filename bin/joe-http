#!/usr/bin/env python3
"""joe-http: tiny HTTP wrapper around joe-agent for LAN / phone access.

Spins up a FastAPI server on the Mac. Endpoints map 1:1 to joe-agent's
subcommands: /chat, /pr, /standup, /web. Auth is a single bearer token
read from ~/.joe-agent/http-token or the JOE_HTTP_TOKEN env var.

Usage:
  joe-http                            listen on 0.0.0.0:8765
  joe-http --port 9000                custom port
  joe-http --host 127.0.0.1           local-only
  joe-http --token <hex>              one-shot token override

First-run setup:
  1. Run `joe-http`. It will generate a token in ~/.joe-agent/http-token
     if one doesn't exist, print it once, and start listening.
  2. Note the Mac's LAN IP (e.g. `ipconfig getifaddr en0`).
  3. From your phone or another machine on the LAN:
       curl -sS http://<mac-ip>:8765/chat \\
            -H "Authorization: Bearer <token>" \\
            -H "Content-Type: application/json" \\
            -d '{"prompt": "summarise today"}'

Security: only listen on a trusted LAN. The token is bearer-only, no
rate limiting, no TLS. For external access, front it with a Cloudflare
Tunnel or Tailscale rather than opening the Mac firewall.
"""

from __future__ import annotations

import argparse
import datetime as dt
import html
import json
import os
import secrets
import sqlite3
import subprocess
import threading
import urllib.request
from pathlib import Path
from typing import Optional

try:
    from fastapi import FastAPI, Header, HTTPException, Request
    from fastapi.responses import HTMLResponse, StreamingResponse
    from pydantic import BaseModel
    import uvicorn
except ImportError as e:
    raise SystemExit(
        f"joe-http: missing dependency: {e}\n"
        "Install with: python3 -m pip install --user fastapi uvicorn"
    )


HOME = Path.home()
STATE_DIR = HOME / ".joe-agent"
STATE_DIR.mkdir(parents=True, exist_ok=True)
TOKEN_FILE = STATE_DIR / "http-token"
JOE_AGENT = HOME / ".local" / "bin" / "joe-agent"


def _ensure_token() -> str:
    if os.environ.get("JOE_HTTP_TOKEN"):
        return os.environ["JOE_HTTP_TOKEN"]
    if TOKEN_FILE.exists():
        return TOKEN_FILE.read_text().strip()
    tok = secrets.token_hex(24)
    TOKEN_FILE.write_text(tok + "\n")
    TOKEN_FILE.chmod(0o600)
    print(f"[joe-http] generated new auth token, saved to {TOKEN_FILE}")
    print(f"[joe-http] token: {tok}")
    return tok


TOKEN = _ensure_token()


def _check_auth(authorization: Optional[str]) -> None:
    if not authorization or not authorization.startswith("Bearer "):
        raise HTTPException(status_code=401, detail="missing bearer token")
    if authorization.removeprefix("Bearer ").strip() != TOKEN:
        raise HTTPException(status_code=403, detail="invalid token")


def _run_joe_agent(args: list[str], timeout: int = 600) -> str:
    if not JOE_AGENT.exists():
        raise HTTPException(status_code=500, detail=f"joe-agent not found at {JOE_AGENT}")
    try:
        cp = subprocess.run(
            [str(JOE_AGENT), *args],
            capture_output=True, text=True, timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        raise HTTPException(status_code=504, detail=f"joe-agent timed out after {timeout}s")
    out = cp.stdout or ""
    if cp.stderr:
        out = (out + "\n[stderr]\n" + cp.stderr) if out else cp.stderr
    return out or f"(exit {cp.returncode}, no output)"


# --------------------------------------------------------------------------
# FastAPI app
# --------------------------------------------------------------------------

app = FastAPI(title="joe-agent", version="0.2.0")


class ChatRequest(BaseModel):
    prompt: str
    session: Optional[str] = None
    model: Optional[str] = None
    use_rag: bool = True
    use_tools: bool = True


@app.get("/health")
def health() -> dict:
    return {"ok": True, "joe_agent": str(JOE_AGENT), "token_file": str(TOKEN_FILE)}


@app.post("/chat")
def chat(req: ChatRequest, authorization: Optional[str] = Header(None)) -> dict:
    _check_auth(authorization)
    args = ["chat", "--no-stream", "--quiet", "--no-git-state"]
    if req.session:
        args.extend(["--session", req.session])
    if req.model:
        args.extend(["--model", req.model])
    if not req.use_rag:
        args.append("--no-rag")
    if not req.use_tools:
        args.append("--no-tools")
    args.append(req.prompt)
    return {"response": _run_joe_agent(args)}


class PRRequest(BaseModel):
    base: str = "main"
    cwd: Optional[str] = None  # ignored on remote side; relies on cwd of caller


@app.post("/pr")
def pr(req: PRRequest, authorization: Optional[str] = Header(None)) -> dict:
    _check_auth(authorization)
    # cwd doesn't propagate via HTTP. PR drafting is most useful when this is
    # the same machine that has the repo open, so we just run in HOME.
    return {"response": _run_joe_agent(["pr", "--base", req.base], timeout=900)}


class StandupRequest(BaseModel):
    hours: int = 24


@app.post("/standup")
def standup(req: StandupRequest, authorization: Optional[str] = Header(None)) -> dict:
    _check_auth(authorization)
    return {"response": _run_joe_agent(["standup", "--hours", str(req.hours)], timeout=900)}


@app.get("/standup/latest")
def standup_latest(authorization: Optional[str] = Header(None)) -> dict:
    """Return the most recent launchd-generated standup, if one exists."""
    _check_auth(authorization)
    latest = STATE_DIR / "standups" / "latest.md"
    if not latest.exists():
        raise HTTPException(status_code=404, detail="no standup generated yet")
    return {
        "path": str(latest.resolve()),
        "mtime": latest.stat().st_mtime,
        "content": latest.read_text(encoding="utf-8", errors="replace"),
    }


class WebRequest(BaseModel):
    query: str


@app.post("/web")
def web(req: WebRequest, authorization: Optional[str] = Header(None)) -> dict:
    _check_auth(authorization)
    prompt = (
        f"Search the web for: {req.query}\n"
        f"Use the <web_search> tool and summarise the first three results."
    )
    return {"response": _run_joe_agent(["chat", "--no-stream", "--quiet", "--no-git-state",
                                        "--no-rag", prompt])}


# --------------------------------------------------------------------------
# iOS bridge: a single endpoint a Shortcut can call from anywhere.
# --------------------------------------------------------------------------


class IOSRequest(BaseModel):
    prompt: str
    session: Optional[str] = None
    model: Optional[str] = None
    # If set, joe-http runs the model in the background and pushes the
    # answer to ntfy.sh/<topic> when it finishes (returns 202 immediately).
    # If unset, the request blocks until the model returns the answer.
    ntfy: Optional[str] = None
    # Shortcut/device tag, echoed in the ntfy push title for clarity.
    source: Optional[str] = "iOS"


def _ntfy_push(topic: str, title: str, body: str) -> None:
    if not topic:
        return
    try:
        req = urllib.request.Request(
            f"https://ntfy.sh/{topic}",
            data=body.encode("utf-8"),
            headers={"Title": title, "Priority": "default", "Tags": "robot,joe"},
            method="POST",
        )
        urllib.request.urlopen(req, timeout=10).close()
    except Exception:
        pass


def _ios_run_async(req: IOSRequest) -> None:
    args = ["chat", "--no-stream", "--quiet", "--no-git-state"]
    if req.session:
        args.extend(["--session", req.session])
    if req.model:
        args.extend(["--model", req.model])
    args.append(req.prompt)
    try:
        answer = _run_joe_agent(args)
    except Exception as e:  # never let the bg thread crash the server
        answer = f"[joe-http error] {e}"
    # Trim to a phone-friendly length; ntfy caps message size.
    if len(answer) > 3500:
        answer = answer[:3500] + "\n[... truncated; tail in joe-http logs ...]"
    _ntfy_push(
        req.ntfy or "",
        f"joe replied to {req.source or 'phone'}",
        answer.strip() or "(no output)",
    )


@app.post("/ios")
def ios(req: IOSRequest, authorization: Optional[str] = Header(None)):
    _check_auth(authorization)
    if req.ntfy:
        # Fire-and-forget: respond 202 immediately, push the answer to ntfy.
        threading.Thread(target=_ios_run_async, args=(req,), daemon=True).start()
        return {"status": "accepted", "delivery": f"ntfy.sh/{req.ntfy}"}
    # Synchronous: block and return the answer inline (Shortcut reads it).
    args = ["chat", "--no-stream", "--quiet", "--no-git-state"]
    if req.session:
        args.extend(["--session", req.session])
    if req.model:
        args.extend(["--model", req.model])
    args.append(req.prompt)
    return {"answer": _run_joe_agent(args)}


# --------------------------------------------------------------------------
# Web dashboard: one page rendering live state from the joe sqlite DBs.
# Bearer auth via query string (?token=<TOKEN>) since browsers can't easily
# send Authorization headers on a top-level page load.
# --------------------------------------------------------------------------


def _check_auth_qs(token: Optional[str]) -> None:
    if not token or token != TOKEN:
        raise HTTPException(status_code=403, detail="missing or invalid ?token=")


def _safe_query(db: Path, sql: str, params: tuple = ()) -> list[tuple]:
    if not db.is_file():
        return []
    try:
        c = sqlite3.connect(str(db))
        rows = c.execute(sql, params).fetchall()
        c.close()
        return rows
    except sqlite3.Error:
        return []


def _eval_sparkline(values: list[float], width: int = 220, height: int = 36) -> str:
    """Render a tiny inline SVG sparkline for a series of similarity scores."""
    if not values:
        return '<span style="color:#888">(no eval runs)</span>'
    lo, hi = min(values), max(values)
    span = max(1e-9, hi - lo)
    pts = []
    for i, v in enumerate(values):
        x = (i / max(1, len(values) - 1)) * width
        y = height - ((v - lo) / span) * (height - 4) - 2
        pts.append(f"{x:.1f},{y:.1f}")
    polyline = " ".join(pts)
    last_x = pts[-1].split(",")[0]
    last_y = pts[-1].split(",")[1]
    return (
        f'<svg width="{width}" height="{height}" '
        f'style="vertical-align:middle">'
        f'<polyline points="{polyline}" fill="none" stroke="#7fd17f" stroke-width="2"/>'
        f'<circle cx="{last_x}" cy="{last_y}" r="3" fill="#7fd17f"/>'
        f'</svg>'
    )


def _render_dashboard_html() -> str:
    state = Path.home() / ".joe-agent"

    # Provenance: most-recent 10 writes/edits.
    prov_rows = _safe_query(
        state / "provenance.sqlite",
        "SELECT ts, path, op, agent, model, user_msg, adds, dels"
        " FROM provenance ORDER BY ts DESC LIMIT 10",
    )

    # Eval: per-model avg over time.
    eval_rows = _safe_query(
        state / "evals.sqlite",
        "SELECT ts, model, AVG(score) FROM results"
        " GROUP BY ts, model ORDER BY ts ASC",
    )
    by_model: dict[str, list[tuple[str, float]]] = {}
    for ts, model, avg in eval_rows:
        by_model.setdefault(model, []).append((ts, avg))

    # Knowledge graph: total triples + 10 newest.
    kg_count_rows = _safe_query(
        state / "knowledge.sqlite", "SELECT COUNT(*) FROM triples",
    )
    kg_n = kg_count_rows[0][0] if kg_count_rows else 0
    kg_newest = _safe_query(
        state / "knowledge.sqlite",
        "SELECT subject, relation, object, session, ts FROM triples"
        " ORDER BY ts DESC LIMIT 12",
    )

    # Lessons active rules.
    rules = _safe_query(
        state / "lessons.sqlite",
        "SELECT rule FROM rules WHERE status = 'active' ORDER BY id ASC",
    )

    # Sessions: top 10 by recency.
    sessions = _safe_query(
        state / "joe-sessions.sqlite",
        "SELECT session, COUNT(*), MAX(ts) FROM turns"
        " GROUP BY session ORDER BY MAX(ts) DESC LIMIT 10",
    )

    # Background tasks: walk the tasks dir.
    tasks_dir = state / "tasks"
    task_blocks: list[str] = []
    if tasks_dir.is_dir():
        for f in sorted(tasks_dir.glob("*.json"))[-8:]:
            try:
                d = json.loads(f.read_text())
                tid = d.get("id", "")
                status = d.get("status", "")
                cmd = d.get("cmd", "")[:80]
                color = {"running": "#cf9b00", "finished": "#7fd17f",
                         "failed": "#d94a4a", "orphaned": "#a060c0"}.get(status, "#aaa")
                task_blocks.append(
                    f'<li>#{tid} <span style="color:{color}">{status}</span> '
                    f'<code>{html.escape(cmd)}</code></li>'
                )
            except Exception:
                continue

    # Active model marker.
    active_model = "joe-gemma"
    am = state / "active-model"
    if am.is_file():
        active_model = am.read_text().strip()

    # Render.
    parts: list[str] = []

    def section(title: str, body: str) -> None:
        parts.append(
            f'<section><h2>{html.escape(title)}</h2>{body}</section>'
        )

    # Banner.
    parts.append(
        f'<header><h1>joe</h1>'
        f'<div class="sub">local-first agent dashboard '
        f'<code>{html.escape(active_model)}</code> '
        f'</div></header>'
    )

    # Interactive chat (SSE streaming).
    parts.append(
        '<section><h2>Ask</h2>'
        '<form id="chat-form" onsubmit="return joeAsk(event)">'
        '<textarea id="chat-input" rows="2" '
        'placeholder="type and hit Cmd-Enter / Ctrl-Enter to stream a response..."></textarea>'
        '<div class="chat-controls">'
        '<input type="text" id="chat-model" placeholder="model (optional)" size="22">'
        '<button type="submit">Ask</button>'
        '<button type="button" onclick="document.getElementById(\'chat-output\').innerHTML=\'\'">'
        'Clear</button>'
        '</div>'
        '<pre id="chat-output" class="chat-output"></pre>'
        '</form></section>'
    )

    # Eval sparklines.
    eval_body = ""
    for model in sorted(by_model.keys()):
        series = by_model[model]
        avgs = [a for _, a in series]
        latest = avgs[-1] if avgs else 0.0
        prev = avgs[-2] if len(avgs) >= 2 else latest
        delta = latest - prev
        sign = "+" if delta >= 0 else ""
        color = "#7fd17f" if delta >= 0 else "#d94a4a"
        eval_body += (
            f'<div class="evalrow">'
            f'<code>{html.escape(model)}</code> '
            f'<span class="score">{latest:.3f}</span> '
            f'<span style="color:{color}">{sign}{delta:.3f}</span> '
            f'{_eval_sparkline(avgs)}</div>'
        )
    if not eval_body:
        eval_body = '<p class="dim">No eval runs yet. Try <code>joe eval build && joe eval run</code>.</p>'
    section("Eval trend (similarity to gold)", eval_body)

    # Provenance. Path cells are clickable: open in VSCode (vscode://) when
    # the user's editor is VSCode/Cursor; otherwise the link is a no-op.
    prov_body = '<table><thead><tr><th>when</th><th>op</th><th>path</th><th>agent</th><th>prompt</th><th>±</th></tr></thead><tbody>'
    for ts, path, op, agent, model, user_msg, adds, dels in prov_rows:
        agent_display = f"@@{agent}" if agent else "-"
        path_short = path.replace(str(Path.home()), "~")[-60:]
        msg_short = (user_msg or "")[:80]
        prov_body += (
            f'<tr><td>{html.escape(ts[:16])}</td>'
            f'<td><code>{op}</code></td>'
            f'<td title="{html.escape(path)}">'
            f'<a href="vscode://file{html.escape(path)}" class="editor-link">'
            f'{html.escape(path_short)}</a></td>'
            f'<td>{html.escape(agent_display)}</td>'
            f'<td class="dim">{html.escape(msg_short)}</td>'
            f'<td>+{adds}/-{dels}</td></tr>'
        )
    prov_body += '</tbody></table>'
    if not prov_rows:
        prov_body = '<p class="dim">No tracked writes yet.</p>'
    section(f"Provenance (latest 10)", prov_body)

    # Knowledge graph.
    kg_body = f'<p>{kg_n} triples total.</p>'
    if kg_newest:
        kg_body += '<table><thead><tr><th>subject</th><th>relation</th><th>object</th><th>session</th></tr></thead><tbody>'
        for s, r, o, sess, ts in kg_newest:
            kg_body += (
                f'<tr><td>{html.escape(s[:40])}</td>'
                f'<td><em>{html.escape(r[:30])}</em></td>'
                f'<td>{html.escape(o[:60])}</td>'
                f'<td class="dim">{html.escape(sess[:20])} · {html.escape(ts[:10])}</td></tr>'
            )
        kg_body += '</tbody></table>'
    section("Knowledge graph (12 newest triples)", kg_body)

    # Lessons.
    if rules:
        rules_body = '<ol>' + "".join(
            f'<li>{html.escape(r[0])}</li>' for r in rules
        ) + '</ol>'
    else:
        rules_body = '<p class="dim">No distilled rules yet. <code>joe lessons distill</code> turns recent /undo events into rules.</p>'
    section("Active lessons", rules_body)

    # Sessions + tasks side-by-side.
    sess_body = '<ul>'
    for sess, n, last_ts in sessions:
        sess_body += (
            f'<li><code>{html.escape(sess)}</code> '
            f'<span class="dim">{n} turns · {html.escape(last_ts[:16])}</span></li>'
        )
    sess_body += '</ul>' if sessions else '</ul><p class="dim">No sessions yet.</p>'
    section("Recent sessions", sess_body)

    if task_blocks:
        section("Background tasks", '<ul>' + "".join(task_blocks) + '</ul>')

    # Footer with refresh + token tip.
    parts.append(
        '<footer><p class="dim">'
        'Refresh the page for live data. '
        'Endpoints under same auth: <code>/health</code> · '
        '<code>/chat</code> · <code>/ios</code> · <code>/standup/latest</code>.'
        '</p></footer>'
    )

    css = """
    * { box-sizing: border-box; }
    body { font: 14px/1.5 -apple-system, BlinkMacSystemFont, sans-serif;
           background: #0e0e10; color: #e8e8e8; margin: 0; padding: 24px;
           max-width: 980px; margin-inline: auto; }
    h1 { font-size: 28px; margin: 0; color: #fff; }
    h2 { font-size: 16px; margin: 32px 0 12px; color: #cfd8dc;
         text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
    header .sub { color: #888; margin-top: 4px; }
    section { border-top: 1px solid #1f1f24; padding-top: 4px; }
    code { font: 12px/1.4 ui-monospace, SFMono-Regular, monospace;
           background: #1a1a1f; padding: 1px 4px; border-radius: 3px;
           color: #f0c674; }
    em { color: #81a1c1; font-style: normal; }
    a.editor-link { color: #f0c674; text-decoration: none; }
    a.editor-link:hover { text-decoration: underline; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 6px 10px; border-bottom: 1px solid #1f1f24;
             text-align: left; vertical-align: top; font-size: 13px; }
    th { color: #888; font-weight: 600; text-transform: uppercase;
         font-size: 11px; letter-spacing: 0.5px; }
    .dim { color: #888; }
    .evalrow { padding: 6px 0; display: flex; align-items: center;
               gap: 12px; }
    .score { font-weight: 600; color: #7fd17f; font-variant-numeric: tabular-nums; }
    ol, ul { padding-left: 22px; }
    li { margin: 4px 0; }
    footer { margin-top: 48px; color: #555; font-size: 12px;
             border-top: 1px solid #1f1f24; padding-top: 16px; }
    /* Chat form. */
    textarea, input[type="text"] {
      width: 100%; background: #1a1a1f; color: #e8e8e8;
      border: 1px solid #2a2a30; border-radius: 4px; padding: 8px 10px;
      font: 13px/1.4 ui-monospace, SFMono-Regular, monospace;
    }
    textarea:focus, input[type="text"]:focus { outline: 1px solid #7fd17f; }
    .chat-controls { display: flex; gap: 8px; margin: 8px 0; align-items: center; }
    .chat-controls input { width: auto; flex: 0 0 220px; }
    button { background: #2a2a30; color: #e8e8e8; border: 1px solid #3a3a40;
             border-radius: 4px; padding: 6px 14px; cursor: pointer;
             font: 13px/1.4 -apple-system, sans-serif; }
    button:hover { background: #3a3a40; }
    button[type="submit"] { background: #2d4a2d; }
    button[type="submit"]:hover { background: #3d5a3d; }
    .chat-output { background: #161618; border: 1px solid #2a2a30;
                   border-radius: 4px; padding: 10px; min-height: 60px;
                   max-height: 400px; overflow-y: auto; white-space: pre-wrap;
                   font: 13px/1.5 ui-monospace, SFMono-Regular, monospace;
                   color: #e8e8e8; margin: 0; }
    """
    js_token = _esc_js(TOKEN)
    js = """
    function joeAsk(ev) {
      ev.preventDefault();
      const inp = document.getElementById('chat-input');
      const out = document.getElementById('chat-output');
      const modelInp = document.getElementById('chat-model');
      const prompt = inp.value.trim();
      if (!prompt) return false;
      out.textContent = '';
      const params = new URLSearchParams({token: __TOKEN__, prompt});
      if (modelInp.value.trim()) params.set('model', modelInp.value.trim());
      const es = new EventSource('/chat-stream?' + params.toString());
      es.onmessage = (e) => {
        try { out.textContent += JSON.parse(e.data); }
        catch (_) { out.textContent += e.data; }
        out.scrollTop = out.scrollHeight;
      };
      es.addEventListener('done', () => es.close());
      es.addEventListener('error', () => { out.textContent += '\\n[stream error]'; es.close(); });
      return false;
    }
    document.addEventListener('keydown', (ev) => {
      if ((ev.metaKey || ev.ctrlKey) && ev.key === 'Enter') {
        document.getElementById('chat-form').dispatchEvent(new Event('submit', {cancelable: true}));
      }
    });
    """.replace("__TOKEN__", f"'{js_token}'")
    return f"""<!doctype html>
<html lang="en"><head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>joe dashboard</title>
  <style>{css}</style>
</head><body>
{"".join(parts)}
<script>{js}</script>
</body></html>"""


def _esc_js(s: str) -> str:
    """Escape for embedding inside single-quoted JS string."""
    return s.replace("\\", "\\\\").replace("'", "\\'").replace("\n", "\\n")


@app.get("/", response_class=HTMLResponse)
@app.get("/dashboard", response_class=HTMLResponse)
def dashboard(token: Optional[str] = None) -> HTMLResponse:
    _check_auth_qs(token)
    return HTMLResponse(_render_dashboard_html())


# --------------------------------------------------------------------------
# /chat-stream: SSE streaming endpoint for the dashboard chat textarea.
# Browsers' EventSource only supports GET, so we accept the prompt as a
# query param. Bearer token also via query param to match the dashboard.
# --------------------------------------------------------------------------


def _stream_ollama(prompt: str, model: str):
    """Generator yielding SSE-formatted token events from ollama."""
    body = json.dumps({"model": model, "prompt": prompt,
                       "stream": True, "think": False}).encode()
    req = urllib.request.Request(
        "http://localhost:11434/api/generate",
        data=body,
        headers={"Content-Type": "application/json"},
    )
    try:
        resp = urllib.request.urlopen(req, timeout=600)
    except Exception as e:
        yield f"event: error\ndata: {json.dumps(str(e))}\n\n"
        return
    try:
        for raw in resp:
            line = raw.decode("utf-8", errors="ignore").strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            tok = obj.get("response", "")
            if tok:
                yield f"data: {json.dumps(tok)}\n\n"
            if obj.get("done"):
                break
    finally:
        try:
            resp.close()
        except Exception:
            pass
    yield "event: done\ndata: {}\n\n"


@app.get("/chat-stream")
def chat_stream(
    token: Optional[str] = None,
    prompt: Optional[str] = None,
    model: Optional[str] = None,
):
    _check_auth_qs(token)
    if not prompt:
        raise HTTPException(status_code=400, detail="prompt is required")
    use_model = model or os.environ.get("JOE_DEFAULT_MODEL", "joe-gemma")
    return StreamingResponse(
        _stream_ollama(prompt, use_model),
        media_type="text/event-stream",
        headers={"Cache-Control": "no-cache", "X-Accel-Buffering": "no"},
    )


# --------------------------------------------------------------------------
# Main
# --------------------------------------------------------------------------


def main() -> int:
    ap = argparse.ArgumentParser(prog="joe-http")
    ap.add_argument("--host", default="0.0.0.0", help="bind address (default: 0.0.0.0)")
    ap.add_argument("--port", type=int, default=8765)
    ap.add_argument("--token", help="override the bearer token (one-shot, doesn't persist)")
    args = ap.parse_args()

    if args.token:
        global TOKEN
        TOKEN = args.token
        print(f"[joe-http] using --token override")

    # Print connection hint once.
    print(f"[joe-http] listening on http://{args.host}:{args.port}")
    print(f"[joe-http] token file: {TOKEN_FILE}")
    print(f"[joe-http] health: curl http://{args.host}:{args.port}/health")
    print(f"[joe-http] chat:   curl -sS -X POST http://{args.host}:{args.port}/chat \\")
    print(f"           -H \"Authorization: Bearer <token>\" \\")
    print(f"           -H \"Content-Type: application/json\" \\")
    print(f"           -d '{{\"prompt\": \"hi\"}}'")
    print()

    uvicorn.run(app, host=args.host, port=args.port, log_level="info")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
