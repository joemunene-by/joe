# --------------------------------------------------------------------------
# Per-repo profiles
# --------------------------------------------------------------------------

def _load_profile(cwd: Path) -> dict:
    """Resolve the active profile for cwd.

    Precedence:
      1. `.joe-profile.toml` walking up from cwd to first match (in-tree).
      2. `~/.joe-agent/profiles/<repo-name>.toml` (out-of-tree per repo).
      3. Empty dict if neither exists.

    Repo name is taken from the nearest enclosing git repo root, falling
    back to the directory name.
    """
    try:
        import tomllib  # 3.11+
    except ImportError:
        return {}

    # (1) walk up for an in-tree profile.
    for ancestor in [cwd] + list(cwd.parents):
        p = ancestor / ".joe-profile.toml"
        if p.is_file():
            try:
                return tomllib.loads(p.read_text())
            except Exception:
                return {}

    # (2) per-repo file keyed by repo basename.
    repo_name = cwd.name
    try:
        cp = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=cwd, capture_output=True, text=True, timeout=3,
        )
        if cp.returncode == 0:
            repo_name = Path(cp.stdout.strip()).name
    except Exception:
        pass

    p = PROFILES_DIR / f"{repo_name}.toml"
    if p.is_file():
        try:
            return tomllib.loads(p.read_text())
        except Exception:
            return {}
    return {}


@dataclasses.dataclass
class Agent:
    """A named persona joe can adopt for a turn (Claude-Code-style subagent)."""
    name: str
    description: str
    model: str
    coder: str
    system_prompt: str
    auto_yes: bool


