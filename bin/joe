def _seed_default_agents() -> None:
    """If AGENTS_DIR is empty, drop default reviewer/doc-writer/security/explainer."""
    if any(AGENTS_DIR.iterdir()):
        return
    for name, body in _SEED_AGENTS.items():
        p = AGENTS_DIR / f"{name}.toml"
        sp = body["system_prompt"].replace('"""', '\\"\\"\\"')
        text = (
            f'description = {json.dumps(body["description"])}\n'
            f'model = {json.dumps(body["model"])}\n'
            f'coder = {json.dumps(body["coder"])}\n'
            f'auto_yes = {str(body["auto_yes"]).lower()}\n'
            f'system_prompt = """\n{sp}\n"""\n'
        )
        p.write_text(text)


def _load_agent(name: str) -> Optional[Agent]:
    try:
        import tomllib
    except ImportError:
        return None
    p = AGENTS_DIR / f"{name}.toml"
    if not p.is_file():
        # Fall through to seeding so first-time @@ users get the defaults.
        _seed_default_agents()
    if not p.is_file():
        return None
    try:
        d = tomllib.loads(p.read_text())
    except Exception:
        return None
    return Agent(
        name=name,
        description=d.get("description", ""),
        model=d.get("model", DEFAULT_MODEL),
        coder=d.get("coder", DEFAULT_CODER),
        system_prompt=d.get("system_prompt", "").strip(),
        auto_yes=bool(d.get("auto_yes", False)),
    )


def _list_agents() -> list[Agent]:
    _seed_default_agents()
    out: list[Agent] = []
    for p in sorted(AGENTS_DIR.glob("*.toml")):
        a = _load_agent(p.stem)
        if a:
            out.append(a)
    return out


def _profile_block(profile: dict) -> str:
    """Render the profile as a <repo_profile>...</repo_profile> prompt block."""
    if not profile:
        return ""
    lines = []
    for k, v in profile.items():
        if k == "context_extra":
            continue
        lines.append(f"{k}: {v}")
    ctx = profile.get("context_extra", "").strip()
    body = "\n".join(lines)
    if ctx:
        body += "\n\nnotes:\n" + ctx
    return f"<repo_profile>\n{body}\n</repo_profile>"


# --------------------------------------------------------------------------
# Image attachments (vision support)
# --------------------------------------------------------------------------

IMAGE_EXT = {".png", ".jpg", ".jpeg", ".gif", ".webp", ".bmp"}


def attach_image(path: str) -> str:
    """Stash an image path for inclusion in the next model call."""
    p = _resolve_path(path)
    if not p.exists():
        raise ToolError(f"image not found: {path}")
    if p.suffix.lower() not in IMAGE_EXT:
        raise ToolError(f"not an image (extension {p.suffix!r}): {path}")
    _pending_images.append(str(p))
    panel(
        f"Image attached: {p.name}",
        Text(f"{p}  ({p.stat().st_size // 1024} KB)", style="bright_blue"),
        style="bright_blue",
        subtitle=f"{len(_pending_images)} attached this turn",
    )
    return f"attached {path}"


def _drain_image_base64() -> list[str]:
    """Pop all pending images and return them base64-encoded for Ollama."""
    out: list[str] = []
    for path in _pending_images:
        try:
            out.append(base64.b64encode(Path(path).read_bytes()).decode("ascii"))
        except OSError:
            continue
    _pending_images.clear()
    return out


def _paste_clipboard_image() -> Optional[Path]:
    """Capture the clipboard image. Portable across macOS + Linux."""
    return os_clip_image()


def tool_image(attrs: dict, body: str) -> str:
    """The <image path="..." /> tool: model-side image attachment."""
    path = attrs.get("path") or body.strip()
    if not path:
        raise ToolError("<image> requires path=\"...\" or body")
    return attach_image(path)


# --------------------------------------------------------------------------
# Watch mode (fswatch loop)
# --------------------------------------------------------------------------

def cmd_watch(args: argparse.Namespace) -> int:
    """Watch `path` and auto-run lint + test on each change.

    Debounces events into a 2-second window so a save-storm produces a single
    lint/test pass rather than dozens.
    """
    fswatch = shutil.which("fswatch")
    if not fswatch:
        console.print("[red]fswatch not on PATH. Install with: brew install fswatch[/]")
        return 1
    watch_path = Path(os.path.expanduser(args.path)).resolve()
    if not watch_path.exists():
        console.print(f"[red]watch path does not exist: {watch_path}[/]")
        return 1
    debounce = args.debounce

    console.print(
        Panel(
            f"[bold]watching:[/] {watch_path}\n"
            f"[bold]debounce:[/] {debounce}s\n"
            f"[bold]actions:[/] lint, test\n"
            f"[dim]Ctrl-C to stop[/]",
            title="joe watch",
            border_style="cyan",
        )
    )

    proc = subprocess.Popen(
        [fswatch, "-o", str(watch_path)],
        stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True,
    )

    last_fire = 0.0
    try:
        while True:
            line = proc.stdout.readline()
            if not line:
                break
            now = time.time()
            if now - last_fire < debounce:
                continue
            last_fire = now
            console.rule(f"[bold cyan]change at {dt.datetime.now().strftime('%H:%M:%S')}")
            for tool_name, fn in (("lint", tool_lint), ("test", tool_test)):
                try:
                    fn({"path": str(watch_path)}, "", confirm=False)
                except ToolError as e:
                    console.print(f"[red]{tool_name}: {e}[/]")
                except Exception as e:
                    console.print(f"[red]{tool_name} crashed: {e}[/]")
            # Desktop notification when both run cleanly. fswatch keeps streaming.
            os_notify("joe watch", "lint + test re-ran")
    except KeyboardInterrupt:
        console.print("\n[dim]watch stopped[/]")
    finally:
        proc.terminate()
    return 0


def _shell_history_block(n: int = 10) -> str:
    """Return the last `n` lines of zsh history as a <recent_shell> block."""
    if os.environ.get("JOE_SHELL_HISTORY", "").strip() not in {"1", "true", "yes"}:
        return ""
    candidates = [
        Path(os.environ.get("HISTFILE", "")),
        HOME / ".zsh_history",
        HOME / ".bash_history",
    ]
    src = next((p for p in candidates if p and p.is_file()), None)
    if not src:
        return ""
    try:
        raw = src.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return ""
    lines: list[str] = []
    for ln in raw[-n * 3:]:  # zsh history lines may be metadata; over-fetch
        # Strip zsh extended-history prefix ": 1700000000:0;cmd"
        m = re.match(r"^:\s*\d+:\d+;(.*)$", ln)
        cmd = m.group(1) if m else ln
        cmd = cmd.strip()
        if cmd:
            lines.append(cmd)
    lines = lines[-n:]
    if not lines:
        return ""
    return "<recent_shell>\n" + "\n".join(lines) + "\n</recent_shell>"


def _initial_prompt(user_msg: str, cwd: Path, session: Optional[str]) -> str:
    """Build the first message for a turn: history + cwd + user message."""
    parts: list[str] = []
    if session:
        h = session_recall(session)
        if h:
            parts.append(h)
    # Cross-session memory: pull semantically similar past turns from other
    # sessions and inject as context. Best-effort, silent on miss.
    past = history_recall(user_msg, k=3, exclude_session=session or "")
    pb = history_block(past)
    if pb:
        parts.append(pb)
    sh = _shell_history_block()
    if sh:
        parts.append(sh)
    parts.append(f"<cwd>{cwd}</cwd>")
    # Inject distilled preference rules so joe drifts toward Joe's actual
    # taste over time without retraining.
    lb = lessons_block()
    if lb:
        parts.append(lb)
    # If joe is connected to external MCP servers, list their tools so the
    # orchestrator knows it can call them.
    mcp_block = _mcp_tools_block()
    if mcp_block:
        parts.append(mcp_block)
    profile = _load_profile(cwd)
    profile_block = _profile_block(profile)
    if profile_block:
        parts.append(profile_block)
    parts.append(
        "<environment name=\"joe shell\">\n"
        "You are running inside the `joe` interactive shell. You are the\n"
        "orchestrator. Your coders are qwen2.5-coder:7b (small / fast) and\n"
        "qwen2.5-coder:14b (bigger / slower / smarter). Delegate code-writing\n"
        "to them; your job is the meta-work around their output.\n"
        "\n"
        "Tools (emit one XML tag per response; the shell executes, then calls\n"
        "you again with the result in a <tool_result> block):\n"
        "  <read path=\"...\" />\n"
        "  <write path=\"...\">content</write>\n"
        "  <edit path=\"...\"><old>X</old><new>Y</new></edit>\n"
        "  <bash>command</bash>\n"
        "  <grep pattern=\"...\" path=\"...\" />\n"
        "  <glob pattern=\"...\" />\n"
        "  <delegate model=\"qwen2.5-coder:7b\">spec</delegate>   (simple tasks)\n"
        "  <delegate model=\"qwen2.5-coder:14b\">spec</delegate>  (complex tasks)\n"
        "  <test path=\"...\" />        auto-detects pytest/cargo test/npm test\n"
        "  <lint path=\"...\" />        auto-detects ruff/clippy/eslint/tsc\n"
        "  <build path=\"...\" />       auto-detects build command\n"
        "  <web_search query=\"...\" />        DuckDuckGo HTML search\n"
        "  <web_fetch url=\"...\" />           fetch + strip HTML to text\n"
        "  <plan title=\"...\">numbered steps</plan>  trigger plan mode\n"
        "\n"
        "Plan mode: if the task touches multiple files or has independent\n"
        "phases, emit a <plan> tag with one step per numbered line. The\n"
        "shell will display the plan, ask the user to approve, then drive\n"
        "the steps one at a time with checkpoints between.\n"
        "\n"
        "Test / lint / build: after writing or editing code, emit <test>\n"
        "or <lint> against the changed path so the change is validated\n"
        "before you call the task done. The shell picks the right runner.\n"
        "\n"
        "Web search / fetch: when you hit an error message you don't\n"
        "recognise, or a library you're not sure about, search rather\n"
        "than guess. Quote your source when you cite it.\n"
        "\n"
        "Code-writing protocol (this is the most important rule in the\n"
        "whole shell, do not skip):\n"
        "  - The moment the user asks for new code in any language,\n"
        "    your FIRST action MUST be a <delegate> tag. Not a <write>.\n"
        "    Not a code block in prose. A <delegate>.\n"
        "  - Pick the coder by complexity:\n"
        "    7b: single function, < 50 LOC, one-file fix, boilerplate.\n"
        "    14b: multi-file change, new feature, refactor, test design,\n"
        "         perf-critical, architectural decision.\n"
        "  - Pass the spec verbatim plus any context. The wrapper already\n"
        "    prepends Joe's style rules to the coder's prompt.\n"
        "  - WAIT for the <tool_result> from the delegate before doing\n"
        "    anything else. The result will contain a fenced code block.\n"
        "  - CRITICAL: that code is TEXT in the tool_result. NO file has\n"
        "    been written yet. You MUST emit <write path=\"...\">...</write>\n"
        "    with the extracted code in the body to actually save it.\n"
        "    Until you emit <write>, the file does not exist. Do not\n"
        "    <read> a path until after you have <write>n it.\n"
        "  - THEN your meta-work, in order:\n"
        "      1. Skim the returned code. Fix any off-style bits inline\n"
        "         (em-dashes, emojis, missing type hints, missing\n"
        "         docstrings on public APIs).\n"
        "      2. Apply via a single <write> or <edit>. Don't paste code\n"
        "         in prose, don't narrate the code, just commit it.\n"
        "      3. Draft a commit message in Joe's style (imperative\n"
        "         subject, WHY-first body, no Co-Authored-By trailers).\n"
        "      4. If a public surface changed (new module, function,\n"
        "         CLI flag, env var, route), draft and APPLY (via\n"
        "         <write> or <edit>) the matching README / CHANGELOG /\n"
        "         docs / tags update. Don't wait for the user to ask.\n"
        "      5. End with a [followup] list of anything you spotted:\n"
        "         missing tests, edge cases, perf concerns, security.\n"
        "  - Hard exception: you may write inline (no delegate) ONLY for\n"
        "    typo / one-line fixes the user pasted at you, OR for pure\n"
        "    prose changes (README, comments, commit bodies).\n"
        "  - If you catch yourself starting a <write> with new code\n"
        "    before any <delegate>, STOP and emit <delegate> instead.\n"
        "\n"
        "Path discipline (don't skip this either):\n"
        "  - When the user gives an absolute path or any path in the\n"
        "    prompt, use it VERBATIM in <write path=\"...\">. Never\n"
        "    substitute placeholders like 'path/to/file.py' or\n"
        "    '~/somewhere/file.ext'. The shell rejects those.\n"
        "  - When asked for multiple files (e.g. a script + a README),\n"
        "    write each one with its own <write> turn. The shell loops.\n"
        "    Don't pack two files into one <write>.\n"
        "\n"
        "When you have no more tools to call, reply in plain prose. The\n"
        "shell ends the turn when you stop emitting tags.\n"
        "</environment>"
    )
    parts.append(f"User: {user_msg}")
    return "\n\n".join(parts)


def run_turn(
    model: str,
    coder_model: str,
    user_msg: str,
    cwd: Path,
    session: Optional[str],
    allow_all_bash: bool,
    max_turns: int,
) -> None:
    # Stamp this turn's context for the provenance/lessons subsystems.
    # @@agent dispatch sets `_TURN_CTX["agent"]` before us; preserve it here.
    _TURN_CTX.update(
        user_msg=user_msg[:4000],
        session=session or "",
        model=model,
        coder=coder_model,
    )
    prompt = _initial_prompt(user_msg, cwd, session)
    full_response_chunks: list[str] = []
    last_call_signature: Optional[str] = None
    same_call_count = 0

    for turn in range(max_turns):
        response = _ollama_stream_to_console(model, prompt)
        full_response_chunks.append(response)

        call = extract_first_tool_call(response)
        if not call:
            break  # no tool call: the model is done

        # Detect a stuck loop: same tool + same args twice in a row.
        sig = f"{call.name}|{sorted(call.attrs.items())}|{call.body[:200]}"
        if sig == last_call_signature:
            same_call_count += 1
            if same_call_count >= 1:
                console.print(
                    "[yellow]Same tool call emitted twice in a row; "
                    "breaking the loop. Tell the model what to do differently.[/]"
                )
                break
        else:
            same_call_count = 0
            last_call_signature = sig

        # Execute the call. ToolError gets reflected back to the model.
        try:
            if call.name == "read":
                result = tool_read(call.attrs, call.body)
            elif call.name == "write":
                result = tool_write(call.attrs, call.body)
            elif call.name == "edit":
                result = tool_edit(call.attrs, call.body)
            elif call.name == "bash":
                result = tool_bash(call.attrs, call.body, allow_all=allow_all_bash)
            elif call.name == "grep":
                result = tool_grep(call.attrs, call.body)
            elif call.name == "glob":
                result = tool_glob(call.attrs, call.body)
            elif call.name == "delegate":
                result = tool_delegate(call.attrs, call.body, coder_model)
            elif call.name == "test":
                result = tool_test(call.attrs, call.body)
            elif call.name == "lint":
                result = tool_lint(call.attrs, call.body)
            elif call.name == "build":
                result = tool_build(call.attrs, call.body)
            elif call.name == "web_search":
                result = tool_web_search(call.attrs, call.body)
            elif call.name == "web_fetch":
                result = tool_web_fetch(call.attrs, call.body)
            elif call.name == "image":
                result = tool_image(call.attrs, call.body)
            elif call.name == "mcp":
                result = tool_mcp(call.attrs, call.body)
            elif call.name == "plan":
                # Don't execute inline; hand back to the user so they can
                # approve. The model will see this as "plan acknowledged".
                plan = parse_plan_block(call.raw)
                if plan:
                    execute_plan(plan, model, coder_model, cwd, session, allow_all_bash)
                    return  # plan owns the rest of the turn
                result = "plan tag was malformed; emit numbered steps"
            else:
                result = f"unknown tool: {call.name}"
        except ToolError as e:
            console.print(f"[red]Tool error:[/] {e}")
            result = f"ERROR: {e}"
        except Exception as e:
            console.print(f"[red]Tool crashed:[/] {e}")
            result = f"ERROR: {e}"

        # Reflect tool result to the model.
        if len(result) > 4000:
            result = result[:4000] + "\n[... truncated ...]"
        # If the tool failed (the result contains a leading ERROR: line, or
        # a known crash signature), nudge the model toward STOP rather than
        # blind retry.
        result_is_error = result.startswith("ERROR:") or "Tool error" in result \
            or "Tool crashed" in result or "no such file" in result.lower()
        nudge = (
            "Continue. Either emit another tool tag or answer in plain prose."
        )
        if result_is_error:
            nudge = (
                "The previous tool call failed. Either:\n"
                "  - retry with a CORRECTED tag (different path, different args),\n"
                "  - or, if you cannot make progress on this step, output "
                "    exactly STOP: <one-sentence reason>  and stop emitting tags.\n"
                "Do NOT repeat the same tag with the same args."
            )
        prompt = (
            response + f"\n\n<tool_result name=\"{call.name}\">\n{result}\n</tool_result>\n"
            + nudge
        )
    else:
        console.print(f"[yellow]Hit {max_turns}-turn tool-loop cap. Stopping.[/]")

    full = "\n".join(full_response_chunks)
    if session:
        session_append(session, "user", user_msg)
        session_append(session, "assistant", full)
        # Best-effort cross-session indexing. Runs in a daemon thread so it
        # doesn't add latency to the user's next prompt.
        threading.Thread(
            target=history_remember,
            args=(session, user_msg, full),
            daemon=True,
        ).start()
        # Knowledge graph triple extraction (also background).
        threading.Thread(
            target=kg_remember,
            args=(session, model, user_msg, full),
            daemon=True,
        ).start()


# --------------------------------------------------------------------------
# REPL
# --------------------------------------------------------------------------


def repl(model: str, coder_model: str, allow_all_bash: bool, session: Optional[str]) -> int:
    cwd = Path.cwd()
    banner(model, cwd)
    # Best-effort: spin up any configured external MCP clients. Failures
    # are printed inline and don't block REPL start.
    _mcp_connect_all()
    state = {
        "model": model,
        "coder": coder_model,
        "cwd": cwd,
        "session": session or f"joe-{dt.datetime.now().strftime('%Y%m%d-%H%M%S')}",
        "speak": False,         # auto-TTS after each turn
        "voice": "Samantha",    # default macOS voice
    }

    while True:
        # Macro replay: if a /macro run is in progress, feed the next step
        # as if the user typed it, rather than prompting.
        if state.get("macro_queue"):
            user_input = state["macro_queue"].pop(0).strip()
            if not user_input:
                continue
            console.print(
                f"[dim]>>> macro:[/] [bold]{user_input}[/]"
            )
        else:
            try:
                _print_status_line(state)
                short = str(state["cwd"]).replace(str(HOME), "~")
                user_input = _get_input(short)
            except (EOFError, KeyboardInterrupt):
                console.print("\n[dim]bye[/]")
                return 0
            if not user_input:
                continue
        # Macro recording: capture every input that is not itself a /macro cmd.
        if state.get("macro_recording_name") and not user_input.startswith("/macro"):
            state.setdefault("macro_recording_steps", []).append(user_input)

        # Mirror user input into the live transcript (if --transcript is on)
        # so external observers tailing the file see what was typed.
        transcript_user_input(user_input)

        # Reset the per-turn agent stamp. The @@ dispatch below will set it
        # if the user invoked a persona; otherwise it stays empty.
        _TURN_CTX["agent"] = ""

        # Multi-line mode: `///` opens, another `///` closes. Useful for
        # pasting stack traces or long code samples without having every
        # newline send a turn.
        if user_input == "///":
            console.print("[dim]multi-line mode: end with /// on its own line[/]")
            buf: list[str] = []
            while True:
                try:
                    ln = input("... ")
                except (EOFError, KeyboardInterrupt):
                    console.print("\n[yellow]cancelled[/]")
                    buf = []
                    break
                if ln.strip() == "///":
                    break
                buf.append(ln)
            user_input = "\n".join(buf).strip()
            if not user_input:
                continue

        # Background task: anything starting with `&` is launched async.
        if user_input.startswith("&"):
            cmd_body = user_input[1:].strip()
            if not cmd_body:
                console.print("[red]& needs a command[/]"); continue
            data = task_spawn(cmd_body, state["cwd"])
            panel(
                f"task #{data['id']} started",
                Text.from_markup(
                    f"[bold]cmd:[/] {data['cmd']}\n"
                    f"[bold]pid:[/] {data['pid']}    "
                    f"[bold]log:[/] {_task_paths(data['id'])[1]}\n"
                    f"[dim]/tasks to list, /task {data['id']} to inspect[/]"
                ),
                style="yellow",
            )
            continue

        # `@@agent-name rest...` : run the turn under a named subagent persona.
        if user_input.startswith("@@"):
            tag, _, rest = user_input.partition(" ")
            agent_name = tag[2:].strip()
            agent = _load_agent(agent_name)
            if not agent:
                avail = ", ".join(a.name for a in _list_agents()) or "(none)"
                console.print(
                    f"[red]no agent matches @@{agent_name}[/]  "
                    f"[dim]available: {avail}[/]"
                )
                continue
            if not rest.strip():
                panel(
                    f"@@{agent.name}",
                    Text.from_markup(
                        f"[bold]description:[/] {agent.description}\n"
                        f"[bold]model:[/]       {agent.model}\n"
                        f"[bold]coder:[/]       {agent.coder}\n\n"
                        f"[dim]system prompt:[/]\n{agent.system_prompt}"
                    ),
                    style="bright_blue",
                )
                continue
            # Frame the user message with the persona so the orchestrator
            # adopts it for this turn. We also override the model and coder.
            wrapped = (
                f"<persona name=\"{agent.name}\" description=\"{agent.description}\">\n"
                f"{agent.system_prompt}\n"
                f"</persona>\n\n"
                f"{rest.strip()}"
            )
            prev_auto = os.environ.get("JOE_AUTO_YES")
            if agent.auto_yes:
                os.environ["JOE_AUTO_YES"] = "1"
            _TURN_CTX["agent"] = agent.name
            console.print(
                f"[bright_blue]@@{agent.name}[/] [dim]({agent.model})[/]"
            )
            try:
                run_turn(
                    model=agent.model, coder_model=agent.coder,
                    user_msg=wrapped, cwd=state["cwd"],
                    session=state["session"], allow_all_bash=allow_all_bash,
                    max_turns=MAX_AUTO_TURNS,
                )
            except KeyboardInterrupt:
                console.print("\n[yellow]turn interrupted[/]")
            finally:
                if agent.auto_yes:
                    if prev_auto is None:
                        os.environ.pop("JOE_AUTO_YES", None)
                    else:
                        os.environ["JOE_AUTO_YES"] = prev_auto
                _TURN_CTX["agent"] = ""
            continue

        # `@repo-name rest...` : run the turn with cwd switched to that repo.
        if user_input.startswith("@") and not user_input.startswith("@@"):
            tag, _, rest = user_input.partition(" ")
            repo_name = tag[1:]
            picked: Optional[Path] = None
            for r in _active_repos():
                if r.name == repo_name or r.name.lower() == repo_name.lower():
                    picked = r; break
            if not picked:
                console.print(f"[red]no active repo matches @{repo_name}[/] "
                              f"([dim]/repos[/])")
                continue
            if not rest.strip():
                # Bare @repo just switches cwd.
                os.chdir(picked); state["cwd"] = picked
                console.print(f"[dim]cwd -> {picked}[/]")
                continue
            # Run the turn with cwd switched for this turn only.
            saved_cwd = state["cwd"]
            os.chdir(picked); state["cwd"] = picked
            console.print(f"[dim]@{repo_name}: cwd -> {picked}[/]")
            try:
                run_turn(model=state["model"], coder_model=state["coder"],
                         user_msg=rest.strip(), cwd=picked,
                         session=state["session"], allow_all_bash=allow_all_bash,
                         max_turns=MAX_AUTO_TURNS)
            except KeyboardInterrupt:
                console.print("\n[yellow]turn interrupted[/]")
            finally:
                os.chdir(saved_cwd); state["cwd"] = saved_cwd
            continue

        # Slash commands
        if user_input.startswith("/"):
            cmd, _, args = user_input[1:].partition(" ")
            args = args.strip()
            if cmd in {"exit", "quit"}:
                return 0
            if cmd == "help":
                slash_help(); continue
            if cmd == "tools":
                slash_tools(); continue
            if cmd == "cwd":
                if args:
                    new = Path(os.path.expanduser(args)).resolve()
                    if new.is_dir():
                        os.chdir(new); state["cwd"] = new
                        console.print(f"[dim]cwd -> {new}[/]")
                    else:
                        console.print(f"[red]not a directory:[/] {new}")
                else:
                    console.print(f"[dim]cwd: {state['cwd']}[/]")
                continue
            if cmd == "model":
                if args:
                    state["model"] = args
                console.print(f"[dim]model: {state['model']}[/]")
                continue
            if cmd == "coder":
                if args:
                    state["coder"] = args
                console.print(f"[dim]coder-delegate: {state['coder']}[/]")
                continue
            if cmd == "clear":
                console.clear()
                state["session"] = f"joe-{dt.datetime.now().strftime('%Y%m%d-%H%M%S')}"
                banner(state["model"], state["cwd"])
                continue
            if cmd == "save":
                if not args:
                    console.print("[red]/save needs a name[/]"); continue
                # Rename current session.
                c = _db()
                c.execute("UPDATE turns SET session = ? WHERE session = ?", (args, state["session"]))
                c.commit(); c.close()
                state["session"] = args
                console.print(f"[dim]saved as {args}[/]")
                continue
            if cmd == "load":
                if not args:
                    console.print("[red]/load needs a name[/]"); continue
                state["session"] = args
                h = session_recall(args)
                if h:
                    panel(f"Loaded session {args}", Text(h[:2000]), style="dim")
                else:
                    console.print(f"[dim]no turns yet for session {args}[/]")
                continue
            if cmd == "read":
                if not args:
                    console.print("[red]/read needs a path[/]"); continue
                try:
                    tool_read({"path": args}, "")
                except ToolError as e:
                    console.print(f"[red]{e}[/]")
                continue
            if cmd == "run":
                if not args:
                    console.print("[red]/run needs a command[/]"); continue
                try:
                    tool_bash({}, args, allow_all=allow_all_bash)
                except ToolError as e:
                    console.print(f"[red]{e}[/]")
                continue
            if cmd == "commit":
                # /commit                draft a message from staged + unstaged, ask for stage-and-commit
                # /commit my message     use that subject line as-is
                cwd = state["cwd"]
                if not (cwd / ".git").exists() and not any(
                    (p / ".git").exists() for p in cwd.parents
                ):
                    console.print(f"[red]/commit: {cwd} is not in a git repo[/]"); continue
                # Stage everything modified + untracked unless already staged.
                status_out = subprocess.run(
                    ["git", "status", "--porcelain"], cwd=cwd,
                    capture_output=True, text=True,
                ).stdout
                if not status_out.strip():
                    console.print("[dim](working tree clean)[/]"); continue
                diff_out = subprocess.run(
                    ["git", "diff", "HEAD"], cwd=cwd, capture_output=True, text=True,
                ).stdout
                if len(diff_out) > 12000:
                    diff_out = diff_out[:12000] + "\n[... truncated ...]"

                if args:
                    msg_subject = args
                    msg_body = ""
                else:
                    # Have joe-gemma draft the message from the diff.
                    spec = (
                        "Draft a single commit message for this diff. Match my style: "
                        "imperative subject line under 70 chars, then a blank line, then "
                        "a WHY-first body with two-space-indented section headings if "
                        "multiple axes changed. No em-dashes, no emojis, no "
                        "Co-Authored-By trailers. Output JUST the commit message text, "
                        "nothing else, no fences.\n\n"
                        f"<git_status>\n{status_out}\n</git_status>\n\n"
                        f"<git_diff>\n{diff_out}\n</git_diff>"
                    )
                    drafted = _ollama_once(state["model"], spec).strip()
                    # Strip surrounding fences if the model added them anyway.
                    drafted = re.sub(r"^```[a-z]*\s*", "", drafted)
                    drafted = re.sub(r"\s*```$", "", drafted)
                    if not drafted:
                        console.print("[red]model returned empty commit message[/]"); continue
                    lines = drafted.splitlines()
                    msg_subject = lines[0]
                    msg_body = "\n".join(lines[1:]).strip()

                panel(
                    f"Commit message draft  ({cwd.name})",
                    Group(
                        Text(msg_subject, style="bold green"),
                        Text(""),
                        Text(msg_body) if msg_body else Text("(no body)", style="dim"),
                        Text(""),
                        Text("changed files:", style="dim"),
                        Syntax(status_out.strip(), "text", theme="ansi_dark"),
                    ),
                    style="green",
                )
                if not _confirm("Stage everything and commit?"):
                    console.print("[dim]commit aborted[/]"); continue
                subprocess.run(["git", "add", "-A"], cwd=cwd, check=False)
                full_msg = msg_subject + (("\n\n" + msg_body) if msg_body else "")
                cp = subprocess.run(
                    ["git", "commit", "-m", full_msg], cwd=cwd,
                    capture_output=True, text=True,
                )
                if cp.returncode == 0:
                    console.print(f"[green]committed[/]: {cp.stdout.strip().splitlines()[-1]}")
                else:
                    console.print(f"[red]commit failed[/]: {cp.stderr.strip()}")
                continue
            if cmd == "push":
                cwd = state["cwd"]
                branch = subprocess.run(
                    ["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=cwd,
                    capture_output=True, text=True,
                ).stdout.strip()
                if not branch:
                    console.print(f"[red]/push: not in a git repo[/]"); continue
                remote = args or "origin"
                if not _confirm(f"Push {branch} to {remote}?"):
                    console.print("[dim]push aborted[/]"); continue
                cp = subprocess.run(
                    ["git", "push", remote, branch], cwd=cwd,
                    capture_output=True, text=True,
                )
                out = (cp.stdout + cp.stderr).strip()
                style = "green" if cp.returncode == 0 else "red"
                panel(f"Push {branch} -> {remote}", Text(out or "(no output)"),
                      style=style, subtitle=f"exit {cp.returncode}")
                continue
            if cmd == "paste":
                # Grab the clipboard image and stash it for the next turn.
                try:
                    p = _paste_clipboard_image()
                    attach_image(str(p))
                except ToolError as e:
                    console.print(f"[red]{e}[/]")
                continue
            if cmd == "attach":
                if not args:
                    console.print("[red]/attach needs a path[/]"); continue
                try:
                    attach_image(args)
                except ToolError as e:
                    console.print(f"[red]{e}[/]")
                continue
            if cmd == "profile":
                p = _load_profile(state["cwd"])
                if not p:
                    console.print("[dim](no profile for this cwd)[/]")
                else:
                    panel("Active profile",
                          Syntax(json.dumps(p, indent=2), "json", theme="ansi_dark"),
                          style="cyan")
                continue
            if cmd == "speak":
                # /speak               toggle auto-TTS
                # /speak Alex          toggle on + set voice
                # /speak off           force off
                # /speak <text>        speak this once, leave mode unchanged
                speak_bin = shutil.which("joe-speak")
                if not speak_bin:
                    console.print("[red]joe-speak not on PATH[/]"); continue
                if args.lower() in {"off", "no", "false"}:
                    state["speak"] = False
                    console.print("[dim]auto-speak: off[/]"); continue
                if not args or args.lower() in {"on", "yes", "true"}:
                    state["speak"] = not state["speak"]
                    console.print(f"[dim]auto-speak: {'on (' + state['voice'] + ')' if state['speak'] else 'off'}[/]")
                    continue
                # Heuristic: single token = voice name; multi-word = speak it once.
                if " " not in args and args.isalpha():
                    state["voice"] = args
                    state["speak"] = True
                    console.print(f"[dim]auto-speak: on (voice {state['voice']})[/]")
                else:
                    subprocess.Popen(
                        [speak_bin, "--voice", state["voice"], "--background", args],
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                    )
                continue
            if cmd == "history":
                n = int(args) if args.isdigit() else 15
                cmd_history(limit=n); continue
            if cmd == "undo":
                n = int(args) if args.isdigit() else 1
                cmd_undo(n=n); continue
            if cmd == "redo":
                n = int(args) if args.isdigit() else 1
                cmd_redo(n=n); continue
            if cmd == "listen":
                # Run joe-listen, then feed the transcription back as user input
                # for the next turn. Args after /listen are passed through to
                # joe-listen (e.g. --duration 12).
                listen_bin = shutil.which("joe-listen")
                if not listen_bin:
                    console.print("[red]joe-listen not on PATH; brew install whisper-cpp sox[/]")
                    continue
                listen_args = shlex.split(args) if args else []
                try:
                    cp = subprocess.run(
                        [listen_bin, *listen_args],
                        capture_output=True, text=True, timeout=120,
                    )
                except subprocess.TimeoutExpired:
                    console.print("[red]joe-listen timed out[/]"); continue
                heard = (cp.stdout or "").strip()
                if cp.stderr:
                    console.print(f"[dim]{cp.stderr.strip()}[/]")
                if not heard:
                    console.print("[yellow]nothing heard[/]"); continue
                panel("Heard", Text(heard, style="bold"), style="bright_magenta")
                # Treat the transcription as the next user message.
                try:
                    run_turn(model=state["model"], coder_model=state["coder"],
                             user_msg=heard, cwd=state["cwd"],
                             session=state["session"], allow_all_bash=allow_all_bash,
                             max_turns=MAX_AUTO_TURNS)
                except KeyboardInterrupt:
                    console.print("\n[yellow]turn interrupted[/]")
                continue
            if cmd == "plan":
                if not args:
                    console.print("[red]/plan needs a task description[/]"); continue
                # cwd guard: refuse /plan from / or $HOME when there's no
                # nearby git repo. Most useful failure mode this prevents:
                # the executor emits 'src/foo.py' which resolves to '/src/...'
                # and the OS rejects with EROFS, then the model drifts to
                # some unrelated file it happens to find.
                cwd_check = state["cwd"]
                bad_cwd = (
                    cwd_check == Path("/") or cwd_check == HOME
                ) and not any(
                    (p / ".git").exists() for p in [cwd_check, *cwd_check.parents]
                )
                if bad_cwd:
                    console.print(
                        f"[red]/plan refused: cwd is {cwd_check} and no git repo "
                        f"is nearby[/]\n"
                        f"[dim]switch first: /cwd ~/some-project   "
                        f"or  @reponame your-task[/]"
                    )
                    continue
                # Split planning from execution:
                #   - the planner (deepseek-r1 by default) emits the
                #     <plan> block ONLY -- reasoning models often don't
                #     follow tool-call protocols well
                #   - each step then runs under the orchestrator
                #     (joe-gemma), which knows how to emit <write> /
                #     <delegate> / <test> / etc.
                profile = _load_profile(state["cwd"])
                planner = profile.get("planner") or DEFAULT_PLANNER
                forced = (
                    f"{args}\n\n"
                    "Produce a single <plan title=\"...\">...</plan> block "
                    "with one concrete step per numbered line. Each step "
                    "should be a self-contained instruction the executor "
                    "can act on. Do NOT emit any other tags this turn."
                )
                if planner != state["model"]:
                    console.print(
                        f"[dim]routing /plan to [bold]{planner}[/] (profile or default); "
                        f"steps will execute under [bold]{state['model']}[/][/]"
                    )
                try:
                    plan_text = _ollama_stream_to_console(planner, forced)
                except KeyboardInterrupt:
                    console.print("\n[yellow]plan interrupted[/]"); continue
                plan = parse_plan_block(plan_text)
                if not plan:
                    console.print(
                        "[yellow]planner didn't emit a <plan> block. "
                        "Try /plan again, or give it a more specific task.[/]"
                    )
                    continue
                try:
                    execute_plan(
                        plan,
                        model=state["model"],
                        coder_model=state["coder"],
                        cwd=state["cwd"],
                        session=state["session"],
                        allow_all_bash=allow_all_bash,
                    )
                except KeyboardInterrupt:
                    console.print("\n[yellow]plan execution interrupted[/]")
                continue
            if cmd == "test":
                where = args or "."
                try: tool_test({"path": where}, "")
                except ToolError as e: console.print(f"[red]{e}[/]")
                continue
            if cmd == "lint":
                where = args or "."
                try: tool_lint({"path": where}, "")
                except ToolError as e: console.print(f"[red]{e}[/]")
                continue
            if cmd == "build":
                where = args or "."
                try: tool_build({"path": where}, "")
                except ToolError as e: console.print(f"[red]{e}[/]")
                continue
            if cmd == "web":
                if not args:
                    console.print("[red]/web needs a query[/]"); continue
                try: tool_web_search({"query": args}, "")
                except ToolError as e: console.print(f"[red]{e}[/]")
                continue
            if cmd == "fetch":
                if not args:
                    console.print("[red]/fetch needs a URL[/]"); continue
                try: tool_web_fetch({"url": args}, "")
                except ToolError as e: console.print(f"[red]{e}[/]")
                continue
            if cmd == "repos":
                repos = _active_repos()
                body = "\n".join(str(r).replace(str(HOME), "~") for r in repos) or "(none)"
                panel("Active repos visible to this shell", Text(body), style="cyan")
                continue
            if cmd == "agents":
                agents = _list_agents()
                if not agents:
                    console.print("[dim](no agents)[/]"); continue
                lines = []
                for a in agents:
                    lines.append(
                        f"[bold bright_blue]@@{a.name}[/]  "
                        f"[dim]({a.model})[/]\n"
                        f"    {a.description}"
                    )
                panel(
                    f"Subagents ({len(agents)})",
                    Text.from_markup("\n\n".join(lines)),
                    style="bright_blue",
                    subtitle=f"defs at {AGENTS_DIR}",
                )
                continue
            if cmd == "sessions":
                c = _db()
                rows = c.execute(
                    "SELECT session, COUNT(*) AS n, MAX(ts) AS last"
                    " FROM turns GROUP BY session ORDER BY last DESC LIMIT 20"
                ).fetchall()
                c.close()
                if not rows:
                    console.print("[dim](no saved sessions)[/]"); continue
                lines = [f"{n:>4}  {last[:19]}  {sess}" for sess, n, last in rows]
                panel(f"Recent sessions ({len(rows)})",
                      Text.from_markup(
                          "[dim]turns       last (UTC)     name[/]\n" + "\n".join(lines)
                      ),
                      style="cyan", subtitle=f"current: {state['session']}")
                continue
            if cmd == "whoami":
                profile = _load_profile(state["cwd"])
                tk = session_token_estimate(state["session"])
                rag = HISTORY_INDEX_DB.exists()
                rag_n = 0
                if rag:
                    try:
                        c = _hidb()
                        rag_n = c.execute("SELECT COUNT(*) FROM hist").fetchone()[0]
                        c.close()
                    except Exception:
                        pass
                short = str(state["cwd"]).replace(str(HOME), "~")
                body = (
                    f"[bold]session:[/] {state['session']}\n"
                    f"[bold]model:[/]   {state['model']}\n"
                    f"[bold]coder:[/]   {state['coder']}\n"
                    f"[bold]cwd:[/]     {short}\n"
                    f"[bold]profile:[/] {'yes (' + ', '.join(profile.keys()) + ')' if profile else 'none'}\n"
                    f"[bold]tokens:[/]  ~{tk} / {CONTEXT_BUDGET_TOKENS} budget\n"
                    f"[bold]rag:[/]     {rag_n} past-turn embeddings\n"
                    f"[bold]ntfy:[/]    {NTFY_TOPIC or '(unset; set NTFY_TOPIC for phone push)'}"
                )
                panel("joe status", Text.from_markup(body), style="cyan")
                continue
            if cmd == "cost":
                tk = session_token_estimate(state["session"])
                ratio = tk / CONTEXT_BUDGET_TOKENS
                color = "green" if ratio < 0.5 else "yellow" if ratio < 0.85 else "red"
                bar_w = 40
                fill = int(bar_w * min(1.0, ratio))
                bar = "█" * fill + "·" * (bar_w - fill)
                panel(
                    "Context budget",
                    Text.from_markup(
                        f"[{color}]{bar}[/] [bold]{ratio * 100:.1f}%[/]\n"
                        f"~{tk} tokens of {CONTEXT_BUDGET_TOKENS} budget\n"
                        f"({tk * CHARS_PER_TOKEN} chars across session {state['session']!r})"
                    ),
                    style=color,
                    subtitle="run /compact to summarise old turns",
                )
                continue
            if cmd == "compact":
                # Summarise the oldest half of the session into a single system
                # note, then rewrite the session with just (summary + recent).
                c = _db()
                rows = c.execute(
                    "SELECT role, content FROM turns WHERE session = ? ORDER BY ts ASC",
                    (state["session"],),
                ).fetchall()
                if len(rows) < 6:
                    console.print("[dim]nothing to compact (under 6 turns)[/]")
                    c.close(); continue
                cut = len(rows) // 2
                older = rows[:cut]
                older_text = "\n\n".join(f"{r.upper()}: {ct}" for r, ct in older)
                if len(older_text) > 16000:
                    older_text = older_text[:16000] + "\n[...]"
                spec = (
                    "Summarise this conversation history in a compact "
                    "bullet list. Capture: what the user was working on, "
                    "key decisions made, files touched, and any open "
                    "follow-ups. Be terse. No fluff.\n\n" + older_text
                )
                console.print("[dim]asking model for compaction summary...[/]")
                summary = _ollama_once(state["model"], spec).strip()
                # Replace the older rows with one synthetic 'system' turn.
                c.execute("DELETE FROM turns WHERE session = ?", (state["session"],))
                c.execute(
                    "INSERT INTO turns (session, ts, role, content) VALUES (?, ?, ?, ?)",
                    (state["session"], dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
                     "system", f"[earlier-history-summary]\n{summary}"),
                )
                for r, ct in rows[cut:]:
                    c.execute(
                        "INSERT INTO turns (session, ts, role, content) VALUES (?, ?, ?, ?)",
                        (state["session"], dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(), r, ct),
                    )
                c.commit(); c.close()
                panel(
                    f"Compacted {len(older)} old turns",
                    Text(summary),
                    style="green",
                    subtitle=f"session now: 1 summary + {len(rows) - cut} recent turns",
                )
                continue
            if cmd == "yolo":
                cur = os.environ.get("JOE_AUTO_YES", "").strip() in {"1", "true", "yes"}
                if cur:
                    os.environ.pop("JOE_AUTO_YES", None)
                    console.print("[dim]yolo mode: OFF (will ask to confirm writes)[/]")
                else:
                    os.environ["JOE_AUTO_YES"] = "1"
                    console.print("[bold red]yolo mode: ON[/] (auto-approve all writes/edits/bash)")
                continue
            if cmd == "doctor":
                rows = []
                def chk(label, ok, detail=""):
                    rows.append((label, ok, detail))
                # Ollama up?
                try:
                    r = urllib.request.urlopen("http://localhost:11434/api/tags", timeout=3)
                    tags = json.loads(r.read()).get("models", [])
                    chk("ollama", True, f"{len(tags)} models")
                    names = {m.get("name", "").split(":")[0] for m in tags}
                    chk("model: joe-gemma", "joe-gemma" in names)
                    chk("model: qwen2.5-coder", any("qwen2.5-coder" in m.get("name", "") for m in tags))
                    chk("model: nomic-embed-text", "nomic-embed-text" in names)
                except Exception as e:
                    chk("ollama", False, str(e))
                for tool in ("joe-speak", "joe-listen", "joe-schedule", "gh", "git",
                             "pngpaste", "fswatch", "rec", "whisper-cli", "pbcopy"):
                    chk(tool, shutil.which(tool) is not None)
                chk("ntfy topic", bool(NTFY_TOPIC), NTFY_TOPIC or "set NTFY_TOPIC for phone push")
                chk("history-index", HISTORY_INDEX_DB.exists(),
                    str(HISTORY_INDEX_DB).replace(str(HOME), "~"))
                lines = []
                for label, ok, detail in rows:
                    mark = "[green]ok  [/]" if ok else "[red]miss[/]"
                    extra = f"  [dim]{detail}[/]" if detail else ""
                    lines.append(f"{mark}  {label}{extra}")
                panel("joe doctor", Text.from_markup("\n".join(lines)), style="cyan")
                continue
            if cmd == "diff":
                where = args or "."
                cp = subprocess.run(
                    ["git", "diff", "--", where] if args else ["git", "diff"],
                    cwd=str(state["cwd"]), capture_output=True, text=True,
                )
                if not cp.stdout.strip():
                    console.print("[dim](no diff)[/]"); continue
                out = cp.stdout
                if len(out) > 12000:
                    out = out[:12000] + "\n[... truncated ...]"
                panel(f"git diff {where}", Syntax(out, "diff", theme="ansi_dark"), style="yellow")
                continue
            if cmd == "copy":
                # Look for a code fence in the most recent assistant turn.
                c = _db()
                row = c.execute(
                    "SELECT content FROM turns WHERE session = ? AND role = 'assistant'"
                    " ORDER BY ts DESC LIMIT 1",
                    (state["session"],),
                ).fetchone()
                c.close()
                if not row:
                    console.print("[red]no assistant turn yet[/]"); continue
                blocks = re.findall(r"```[a-zA-Z0-9_+-]*\n(.*?)```", row[0], re.DOTALL)
                if not blocks:
                    body_to_copy = row[0]
                else:
                    idx = int(args) - 1 if args.isdigit() and int(args) > 0 else -1
                    try:
                        body_to_copy = blocks[idx]
                    except IndexError:
                        console.print(f"[red]no code block #{args} (have {len(blocks)})[/]")
                        continue
                if os_clip_copy(body_to_copy):
                    console.print(f"[green]copied {len(body_to_copy)} chars to clipboard[/]")
                else:
                    console.print(
                        "[red]no clipboard tool found (install pbcopy / xclip / wl-clipboard)[/]"
                    )
                continue
            if cmd == "explain":
                if not args:
                    console.print("[red]/explain needs a path[/]"); continue
                p = _resolve_path(args)
                if not p.exists():
                    console.print(f"[red]no such file: {p}[/]"); continue
                src = p.read_text(encoding="utf-8", errors="replace")
                if len(src) > 18000:
                    src = src[:18000] + "\n... [truncated]"
                spec = (
                    f"Explain {p} for someone reading it for the first time. "
                    "Lead with one sentence stating what the file is for. "
                    "Then a short bulleted list of the main building blocks "
                    "(functions, classes, sections). Then call out anything "
                    "non-obvious: invariants, subtle dependencies, gotchas. "
                    "Be terse. No emojis, no em-dashes.\n\n"
                    f"<file path=\"{p}\">\n{src}\n</file>"
                )
                out = _ollama_once(state["coder"], spec).strip()
                panel(f"Explain {p.name}", Markdown(out), style="bright_blue",
                      subtitle=f"{p}")
                continue
            if cmd == "snap":
                sub, _, rest = args.partition(" ")
                rest = rest.strip()
                if sub == "save":
                    name = rest or dt.datetime.now().strftime("snap-%Y%m%d-%H%M%S")
                    cwd = state["cwd"]
                    repo = subprocess.run(
                        ["git", "rev-parse", "--show-toplevel"],
                        cwd=str(cwd), capture_output=True, text=True,
                    ).stdout.strip()
                    root = Path(repo) if repo else cwd
                    tar_path = SNAPS_DIR / f"{name}.tar.gz"
                    if tar_path.exists():
                        console.print(f"[red]snap exists:[/] {tar_path}"); continue
                    # Exclude heavy dirs.
                    excludes = {".git", "node_modules", "__pycache__", "target",
                                ".next", "dist", "build", ".venv", "venv"}
                    def _filter(tarinfo: tarfile.TarInfo) -> Optional[tarfile.TarInfo]:
                        if any(part in excludes for part in Path(tarinfo.name).parts):
                            return None
                        return tarinfo
                    with tarfile.open(tar_path, "w:gz") as tf:
                        tf.add(str(root), arcname=root.name, filter=_filter)
                    console.print(
                        f"[green]snap saved[/] {name}  "
                        f"({tar_path.stat().st_size // 1024} KB)  "
                        f"[dim]{tar_path}[/]"
                    )
                    continue
                if sub == "list":
                    files = sorted(SNAPS_DIR.glob("*.tar.gz"))
                    if not files:
                        console.print("[dim](no snaps)[/]"); continue
                    lines = []
                    for f in files:
                        s = f.stat()
                        age = dt.datetime.now() - dt.datetime.fromtimestamp(s.st_mtime)
                        ages = (f"{age.total_seconds() / 60:.0f}m" if age.total_seconds() < 3600
                                else f"{age.total_seconds() / 3600:.1f}h" if age.total_seconds() < 86400
                                else f"{age.days}d")
                        lines.append(f"{s.st_size // 1024:>6} KB  {ages:>4} ago  {f.stem}")
                    panel("Snaps", Text("\n".join(lines)), style="cyan",
                          subtitle=str(SNAPS_DIR))
                    continue
                if sub == "restore":
                    if not rest:
                        console.print("[red]/snap restore needs a name[/]"); continue
                    tar_path = SNAPS_DIR / f"{rest}.tar.gz"
                    if not tar_path.exists():
                        console.print(f"[red]no such snap: {rest}[/]"); continue
                    target = state["cwd"]
                    if not _confirm(f"Restore {rest} into {target.parent}? "
                                    f"(extracts repo dir alongside)"):
                        continue
                    with tarfile.open(tar_path, "r:gz") as tf:
                        tf.extractall(str(target.parent))
                    console.print(f"[green]restored {rest}[/]")
                    continue
                if sub == "drop":
                    if not rest:
                        console.print("[red]/snap drop needs a name[/]"); continue
                    tar_path = SNAPS_DIR / f"{rest}.tar.gz"
                    if not tar_path.exists():
                        console.print(f"[red]no such snap: {rest}[/]"); continue
                    if _confirm(f"Delete snap {rest}?"):
                        tar_path.unlink()
                        console.print(f"[dim]dropped {rest}[/]")
                    continue
                console.print("[dim]/snap save|list|restore|drop [name][/]")
                continue
            if cmd == "journal":
                today = dt.date.today().isoformat()
                jp = JOURNAL_DIR / f"{today}.md"
                if not jp.exists():
                    # Seed with daily context.
                    header = [f"# Journal {today}", ""]
                    # Active repos with recent commits.
                    header.append("## recent activity")
                    for r in _active_repos():
                        gl = subprocess.run(
                            ["git", "-C", str(r), "log", "--oneline", "-3",
                             "--since=24.hours"], capture_output=True, text=True,
                        ).stdout.strip()
                        if gl:
                            header.append(f"\n### {r.name}\n```\n{gl}\n```")
                    header.extend(["", "## notes", ""])
                    jp.write_text("\n".join(header))
                if args:
                    stamp = dt.datetime.now().strftime("%H:%M")
                    with jp.open("a") as f:
                        f.write(f"\n- [{stamp}] {args}\n")
                    console.print(f"[dim]appended to {jp}[/]")
                    continue
                # Open in $EDITOR, fall back to printing.
                editor = os.environ.get("EDITOR") or shutil.which("nvim") or shutil.which("vim") or shutil.which("nano")
                if editor and sys.stdin.isatty():
                    subprocess.run([editor, str(jp)])
                else:
                    panel(f"Journal {today}", Markdown(jp.read_text()),
                          style="cyan", subtitle=str(jp))
                continue
            if cmd in {"pr", "issue"}:
                if not shutil.which("gh"):
                    console.print("[red]gh CLI not on PATH (brew install gh)[/]"); continue
                sub, _, rest = args.partition(" ")
                rest = rest.strip()
                cwd_run = str(state["cwd"])
                gh_args: list[str] = []
                if cmd == "pr":
                    if sub == "list" or not sub:
                        gh_args = ["pr", "list"]
                    elif sub == "view":
                        if not rest:
                            console.print("[red]/pr view needs an id[/]"); continue
                        gh_args = ["pr", "view", rest, "--comments"]
                    elif sub == "comment":
                        nm = rest.split(" ", 1)
                        if len(nm) < 2:
                            console.print("[red]/pr comment <id> <text>[/]"); continue
                        gh_args = ["pr", "comment", nm[0], "--body", nm[1]]
                    elif sub == "review":
                        if not rest:
                            console.print("[red]/pr review needs an id[/]"); continue
                        gh_args = ["pr", "view", rest, "--json",
                                   "title,body,files,comments,reviews"]
                    elif sub == "create":
                        # Open `gh pr create` interactively (it needs a TTY).
                        subprocess.run(["gh", "pr", "create"], cwd=cwd_run)
                        continue
                    else:
                        console.print("[dim]/pr list | view N | comment N text | review N | create[/]")
                        continue
                else:  # issue
                    if sub == "list" or not sub:
                        gh_args = ["issue", "list"]
                    elif sub == "view":
                        if not rest:
                            console.print("[red]/issue view needs an id[/]"); continue
                        gh_args = ["issue", "view", rest, "--comments"]
                    elif sub == "comment":
                        nm = rest.split(" ", 1)
                        if len(nm) < 2:
                            console.print("[red]/issue comment <id> <text>[/]"); continue
                        gh_args = ["issue", "comment", nm[0], "--body", nm[1]]
                    elif sub == "new":
                        subprocess.run(["gh", "issue", "create"], cwd=cwd_run); continue
                    elif sub == "close":
                        if not rest:
                            console.print("[red]/issue close needs an id[/]"); continue
                        gh_args = ["issue", "close", rest]
                    else:
                        console.print("[dim]/issue list | view N | comment N text | new | close N[/]")
                        continue
                cp = subprocess.run(["gh", *gh_args], cwd=cwd_run,
                                    capture_output=True, text=True)
                out = (cp.stdout or "") + (("\n[stderr]\n" + cp.stderr) if cp.stderr else "")
                if not out.strip():
                    out = f"(exit {cp.returncode}, no output)"
                if len(out) > 8000:
                    out = out[:8000] + "\n[... truncated ...]"
                panel(f"gh {cmd} {sub}", Syntax(out, "text", theme="ansi_dark"),
                      style="cyan" if cp.returncode == 0 else "red",
                      subtitle=f"exit {cp.returncode}")
                continue
            if cmd == "recall":
                if not args:
                    console.print("[red]/recall needs a query[/]"); continue
                hits = history_recall(args, k=6, exclude_session="")
                if not hits:
                    console.print(
                        "[dim](no semantic match: either history-index is empty "
                        "or query similarity below 0.35)[/]"
                    )
                    continue
                parts = []
                for h in hits:
                    when = h["ts"][:16]
                    sim = f"{h['score']:.2f}"
                    parts.append(
                        f"[bold]{when}[/]  [dim]session[/] {h['session']}  "
                        f"[dim]sim[/] {sim}\n"
                        f"[yellow]USER:[/] {h['user_msg'][:300]}\n"
                        f"[cyan]YOU:[/]  {h['asst_msg'][:600]}"
                    )
                panel(
                    f"Recall: {args!r}",
                    Text.from_markup("\n\n".join(parts)),
                    style="cyan",
                    subtitle=f"{len(hits)} matches",
                )
                continue
            if cmd == "review":
                cwd = state["cwd"]
                diff_out = subprocess.run(
                    ["git", "diff", "HEAD"], cwd=str(cwd),
                    capture_output=True, text=True,
                ).stdout
                if not diff_out.strip():
                    # Try staged-only diff in case nothing's unstaged.
                    diff_out = subprocess.run(
                        ["git", "diff", "--cached"], cwd=str(cwd),
                        capture_output=True, text=True,
                    ).stdout
                if not diff_out.strip():
                    console.print("[dim](no diff to review)[/]"); continue
                if len(diff_out) > 20000:
                    diff_out = diff_out[:20000] + "\n[... truncated ...]"
                spec = (
                    "Review this git diff like a careful pre-commit reviewer. "
                    "Output a markdown checklist:\n"
                    "  ## Bugs        (logic errors, off-by-ones, missing returns)\n"
                    "  ## Edge cases  (untested paths, nil/empty inputs)\n"
                    "  ## Style       (em-dashes, emojis, naming, comment noise)\n"
                    "  ## Security    (input handling, secrets, injection)\n"
                    "  ## Tests       (what's missing)\n"
                    "Quote exact lines (file:line). Skip empty sections. "
                    "Be terse. End with a verdict line: SHIP | FIX-FIRST.\n\n"
                    f"<git_diff>\n{diff_out}\n</git_diff>"
                )
                console.print("[dim]reviewing diff...[/]")
                out = _ollama_once(state["model"], spec).strip()
                panel(f"Pre-commit review  ({cwd.name})", Markdown(out),
                      style="bright_blue", subtitle=f"{len(diff_out)} chars analyzed")
                continue
            if cmd == "timer":
                parts = args.split(None, 1)
                try:
                    minutes = float(parts[0])
                except (IndexError, ValueError):
                    console.print("[red]/timer <minutes> [label][/]"); continue
                label = parts[1] if len(parts) > 1 else "joe timer"
                seconds = max(1.0, minutes * 60)
                def _fire(secs: float, msg: str) -> None:
                    time.sleep(secs)
                    os_notify("joe timer", f"{msg} is up")
                    speak = shutil.which("joe-speak")
                    if speak:
                        subprocess.Popen(
                            [speak, "--background", f"timer done: {msg}"],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                        )
                    else:
                        os_speak(f"timer done: {msg}", background=True)
                threading.Thread(target=_fire, args=(seconds, label), daemon=True).start()
                eta = dt.datetime.now() + dt.timedelta(seconds=seconds)
                console.print(
                    f"[green]timer[/] {minutes:g}m  [dim]({label})[/]  "
                    f"[dim]fires at {eta.strftime('%H:%M')}[/]"
                )
                continue
            if cmd == "fork":
                if not args:
                    console.print("[red]/fork needs a new session name[/]"); continue
                new_name = args.strip().split()[0]
                c = _db()
                exists = c.execute(
                    "SELECT 1 FROM turns WHERE session = ? LIMIT 1", (new_name,),
                ).fetchone()
                if exists:
                    console.print(f"[red]session {new_name!r} already exists[/]")
                    c.close(); continue
                rows = c.execute(
                    "SELECT ts, role, content FROM turns WHERE session = ? ORDER BY ts ASC",
                    (state["session"],),
                ).fetchall()
                if not rows:
                    console.print("[dim](current session has no turns yet)[/]")
                    c.close(); continue
                for ts, role, content in rows:
                    c.execute(
                        "INSERT INTO turns (session, ts, role, content) VALUES (?, ?, ?, ?)",
                        (new_name, ts, role, content),
                    )
                c.commit(); c.close()
                console.print(
                    f"[green]forked[/] {state['session']} -> {new_name}  "
                    f"({len(rows)} turns copied)\n"
                    f"[dim]switch with /load {new_name}[/]"
                )
                continue
            if cmd == "share":
                target = args.strip() or state["session"]
                c = _db()
                rows = c.execute(
                    "SELECT ts, role, content FROM turns WHERE session = ? ORDER BY ts ASC",
                    (target,),
                ).fetchall()
                c.close()
                if not rows:
                    console.print(f"[red]no turns for session {target!r}[/]"); continue
                lines = [f"# Session: {target}", "",
                         f"_exported {dt.datetime.now().isoformat(timespec='seconds')}_",
                         f"_{len(rows)} turns_", ""]
                for ts, role, content in rows:
                    lines.append(f"## {role.upper()}  ·  {ts[:19]}")
                    lines.append("")
                    lines.append(content)
                    lines.append("")
                out_path = EXPORTS_DIR / f"{target}-{dt.datetime.now():%Y%m%d-%H%M%S}.md"
                out_path.write_text("\n".join(lines), encoding="utf-8")
                panel(
                    f"Exported {target}",
                    Text.from_markup(
                        f"[bold]file:[/]   {out_path}\n"
                        f"[bold]size:[/]   {out_path.stat().st_size // 1024} KB  "
                        f"({len(rows)} turns)\n"
                        f"[dim]open with: open {out_path}[/]"
                    ),
                    style="green",
                )
                continue
            if cmd == "blame":
                if not args:
                    console.print("[red]/blame needs a path or path:line[/]")
                    continue
                cmd_blame(args)
                continue
            if cmd == "ask":
                if not args:
                    console.print("[red]/ask needs a question[/]"); continue
                cmd_ask(args, state["model"])
                continue
            if cmd == "debate":
                if not args:
                    console.print(
                        "[red]/debate <topic>[/]  or  "
                        "[red]/debate @@a @@b @@c <topic>[/]"
                    )
                    continue
                # Pick personas: explicit @@names first, else 3 sensible defaults
                # whose system prompts already have distinct viewpoints.
                tokens = args.split()
                explicit: list[str] = []
                rest_idx = 0
                for t in tokens:
                    if t.startswith("@@"):
                        explicit.append(t[2:])
                        rest_idx += 1
                    else:
                        break
                topic = " ".join(tokens[rest_idx:]).strip()
                persona_names = explicit if explicit else [
                    "reviewer", "security", "explainer",
                ]
                if not topic:
                    console.print("[red]/debate needs a topic[/]"); continue
                personas: list[Agent] = []
                for n in persona_names:
                    a = _load_agent(n)
                    if not a:
                        console.print(f"[yellow]skipping unknown agent: @@{n}[/]")
                        continue
                    personas.append(a)
                if len(personas) < 2:
                    console.print(
                        "[red]/debate needs at least 2 known personas[/]")
                    continue
                other_names = lambda me: ", ".join(
                    f"@@{p.name}" for p in personas if p.name != me
                )
                console.print(
                    f"[bright_blue]debating[/] [bold]{topic}[/]  "
                    f"[dim]({len(personas)} personas)[/]"
                )
                takes: list[tuple[str, str]] = []
                for p in personas:
                    spec = (
                        f"<persona name=\"{p.name}\" description=\"{p.description}\">\n"
                        f"{p.system_prompt}\n</persona>\n\n"
                        f"You are debating with {other_names(p.name)}. "
                        f"Surface disagreement where you genuinely have a different "
                        f"view; don't manufacture conflict. Be specific: state what "
                        f"you'd optimise for, what you'd refuse, and the single "
                        f"strongest reason the other personas might be wrong.\n\n"
                        f"Topic: {topic}\n\n"
                        f"Reply in under 200 words. No preamble."
                    )
                    try:
                        out = _ollama_once(p.model, spec, timeout=180).strip()
                    except Exception as e:
                        out = f"(error: {e})"
                    takes.append((p.name, out))
                    panel(
                        f"@@{p.name}  [dim]({p.model})[/]",
                        Markdown(out) if len(out) < 4000 else Text(out[:4000]),
                        style="bright_blue",
                    )
                # Synthesis turn.
                joined = "\n\n".join(
                    f"### @@{n}\n{t}" for n, t in takes
                )
                synth_spec = (
                    "Here are takes from "
                    f"{len(takes)} personas on the same topic. Surface the "
                    "STRONGEST disagreement (1-3 axes max) and call the "
                    "winner if you can. If they're all saying roughly the "
                    "same thing, say so plainly. End with a 1-line "
                    "recommendation. No fluff.\n\n"
                    f"Topic: {topic}\n\n{joined}"
                )
                try:
                    synth = _ollama_once(state["model"], synth_spec).strip()
                except Exception as e:
                    synth = f"(synthesis failed: {e})"
                panel(
                    "synthesis",
                    Markdown(synth),
                    style="green",
                    subtitle=f"{len(takes)} takes on  {topic[:60]}",
                )
                continue
            if cmd == "inbox":
                cmd_inbox(); continue
            if cmd == "reflect":
                cmd_reflect(state["model"]); continue
            if cmd == "lessons":
                sub, _, rest = args.partition(" ")
                rest = rest.strip()
                if sub == "list" or not sub:
                    rules = lessons_active_rules()
                    sup_path = PROMPT_SUPPLEMENT if PROMPT_SUPPLEMENT.is_file() else None
                    if not rules and not sup_path:
                        console.print(
                            "[dim](no rules yet; run /lessons distill after some "
                            "corrections, or /lessons add 'short rule')[/]"
                        )
                        continue
                    body = ""
                    if rules:
                        body = "\n".join(f"{i + 1}. {r}" for i, r in enumerate(rules))
                    if sup_path:
                        body += f"\n\n[dim]supplement file: {sup_path}[/]"
                    panel(
                        f"Active lessons ({len(rules)})",
                        Text.from_markup(body), style="bright_blue",
                    )
                    continue
                if sub == "add":
                    if not rest:
                        console.print("[red]/lessons add <rule text>[/]"); continue
                    c = _lessdb()
                    try:
                        c.execute(
                            "INSERT INTO rules (ts, rule, status)"
                            " VALUES (?, ?, 'active')",
                            (dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
                             rest[:200]),
                        )
                        c.commit()
                        console.print(f"[green]added rule[/]: {rest}")
                    except sqlite3.IntegrityError:
                        console.print("[yellow]that rule is already on the list[/]")
                    c.close(); continue
                if sub == "drop":
                    if not rest.isdigit():
                        console.print("[red]/lessons drop <rule-number-from-list>[/]")
                        continue
                    idx = int(rest)
                    rules = lessons_active_rules()
                    if not (1 <= idx <= len(rules)):
                        console.print(f"[red]no rule #{idx}[/]"); continue
                    rule = rules[idx - 1]
                    c = _lessdb()
                    c.execute(
                        "UPDATE rules SET status = 'retired' WHERE rule = ?", (rule,),
                    )
                    c.commit(); c.close()
                    console.print(f"[dim]retired:[/] {rule}")
                    continue
                if sub == "distill":
                    console.print("[dim]asking the model to distill recent corrections...[/]")
                    n = lessons_distill(state["model"])
                    if n == 0:
                        console.print(
                            "[dim](no new rules; either no recent corrections or "
                            "everything was a duplicate)[/]"
                        )
                    else:
                        console.print(f"[green]added {n} new rule(s); /lessons list to view[/]")
                    continue
                if sub == "review":
                    editor = os.environ.get("EDITOR") or shutil.which("nvim") \
                        or shutil.which("vim") or shutil.which("nano")
                    PROMPT_SUPPLEMENT.touch(exist_ok=True)
                    if editor and sys.stdin.isatty():
                        subprocess.run([editor, str(PROMPT_SUPPLEMENT)])
                    else:
                        body = PROMPT_SUPPLEMENT.read_text(encoding="utf-8") \
                            if PROMPT_SUPPLEMENT.is_file() else ""
                        panel(
                            f"Supplement {PROMPT_SUPPLEMENT}",
                            Markdown(body) if body else Text("(empty)", style="dim"),
                            style="cyan",
                        )
                    continue
                console.print(
                    "[dim]/lessons list | add <rule> | drop <n> | distill | review[/]"
                )
                continue
            if cmd == "macro":
                sub, _, rest = args.partition(" ")
                rest = rest.strip()
                if sub == "record":
                    if not rest:
                        console.print("[red]/macro record <name>[/]"); continue
                    state["macro_recording_name"] = rest
                    state["macro_recording_steps"] = []
                    console.print(
                        f"[green]recording macro[/] [bold]{rest}[/]  "
                        f"[dim](every input is captured until /macro stop)[/]"
                    )
                    continue
                if sub == "stop":
                    name = state.get("macro_recording_name")
                    if not name:
                        console.print("[red]not recording[/]"); continue
                    steps = state.get("macro_recording_steps", [])
                    state.pop("macro_recording_name", None)
                    state.pop("macro_recording_steps", None)
                    if not steps:
                        console.print("[yellow]no steps captured; discarding[/]")
                        continue
                    p = MACROS_DIR / f"{name}.toml"
                    safe = json.dumps(steps)  # legal in toml as a json-ish array
                    body = (
                        f'name = "{name}"\n'
                        f'created = "{dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat()}"\n'
                        f'steps = {safe}\n'
                    )
                    p.write_text(body)
                    panel(
                        f"Saved macro {name}",
                        Text.from_markup(
                            f"[bold]file:[/]  {p}\n"
                            f"[bold]steps:[/] {len(steps)}\n\n"
                            + "\n".join(f"  {i + 1}. {s}" for i, s in enumerate(steps[:20]))
                            + (f"\n  ... (+{len(steps) - 20} more)" if len(steps) > 20 else "")
                            + f"\n\n[dim]replay with /macro run {name}[/]"
                        ),
                        style="green",
                    )
                    continue
                if sub == "run":
                    if not rest:
                        console.print("[red]/macro run <name>[/]"); continue
                    p = MACROS_DIR / f"{rest}.toml"
                    if not p.is_file():
                        console.print(f"[red]no macro {rest!r}[/]"); continue
                    try:
                        import tomllib
                        cfg = tomllib.loads(p.read_text())
                    except Exception as e:
                        console.print(f"[red]can't read macro: {e}[/]"); continue
                    steps = list(cfg.get("steps", []))
                    if not steps:
                        console.print(f"[yellow]macro {rest!r} has no steps[/]"); continue
                    console.print(
                        f"[bright_blue]running macro[/] [bold]{rest}[/]  "
                        f"[dim]({len(steps)} steps)[/]"
                    )
                    state["macro_queue"] = steps
                    continue
                if sub == "list":
                    files = sorted(MACROS_DIR.glob("*.toml"))
                    if not files:
                        console.print("[dim](no macros)[/]"); continue
                    lines = []
                    for f in files:
                        try:
                            import tomllib
                            cfg = tomllib.loads(f.read_text())
                            n = len(cfg.get("steps", []))
                            first = (cfg.get("steps") or [""])[0][:50]
                        except Exception:
                            n, first = -1, "(unreadable)"
                        lines.append(f"  [bold]{f.stem:<16}[/]  {n:>3} steps   "
                                     f"[dim]{first}[/]")
                    panel(
                        f"Macros ({len(files)})",
                        Text.from_markup("\n".join(lines)),
                        style="cyan", subtitle=str(MACROS_DIR),
                    )
                    continue
                if sub == "drop":
                    if not rest:
                        console.print("[red]/macro drop <name>[/]"); continue
                    p = MACROS_DIR / f"{rest}.toml"
                    if not p.exists():
                        console.print(f"[red]no macro {rest!r}[/]"); continue
                    if _confirm(f"Delete macro {rest}?"):
                        p.unlink()
                        console.print(f"[dim]dropped {rest}[/]")
                    continue
                console.print("[dim]/macro record <name> | stop | run <name> | list | drop <name>[/]")
                continue
            if cmd == "mcp":
                sub, _, rest = args.partition(" ")
                if not sub or sub == "list":
                    _mcp_connect_all()
                    if not _MCP_CLIENTS:
                        console.print(
                            "[dim](no MCP clients configured; run "
                            "[bold]joe mcp init[/] to scaffold ~/.joe-agent/mcp-clients.json)[/]"
                        )
                        continue
                    blocks: list[str] = []
                    for name, client in _MCP_CLIENTS.items():
                        status = "[green]connected[/]" if client.connected \
                            else f"[red]failed[/] ({client._connect_error})"
                        if client.connected:
                            tools = "\n".join(
                                f"    [bold]{t.name}[/]  [dim]{(getattr(t, 'description', '') or '').strip()[:80]}[/]"
                                for t in client.tools
                            )
                        else:
                            tools = ""
                        blocks.append(
                            f"[bold bright_blue]@{name}[/]  {status}\n{tools}"
                        )
                    panel(
                        f"MCP clients ({len(_MCP_CLIENTS)})",
                        Text.from_markup("\n\n".join(blocks)),
                        style="bright_blue",
                        subtitle=str(MCP_CLIENTS_CONFIG),
                    )
                    continue
                if sub == "reload":
                    # Tear down + reconnect. Used after editing the config.
                    for c in list(_MCP_CLIENTS.values()):
                        try:
                            if c._loop and c._loop.is_running():
                                c._loop.call_soon_threadsafe(c._loop.stop)
                        except Exception:
                            pass
                    _MCP_CLIENTS.clear()
                    _mcp_connect_all()
                    continue
                console.print("[dim]/mcp list  |  /mcp reload[/]")
                continue
            if cmd == "tasks":
                cmd_tasks(); continue
            if cmd == "task":
                sub, _, rest = args.partition(" ")
                if not sub:
                    console.print("[dim]/task <id> | /task kill <id>[/]"); continue
                if sub == "kill":
                    if not rest:
                        console.print("[red]/task kill needs an id[/]"); continue
                    if task_kill(rest):
                        console.print(f"[green]sent SIGTERM to #{rest}[/]")
                    else:
                        console.print(f"[red]could not kill #{rest}[/]")
                    continue
                cmd_task_show(sub); continue
            console.print(f"[red]unknown command:[/] /{cmd} ([dim]/help[/])")
            continue

        # Otherwise: run a turn.
        try:
            run_turn(
                model=state["model"],
                coder_model=state["coder"],
                user_msg=user_input,
                cwd=state["cwd"],
                session=state["session"],
                allow_all_bash=allow_all_bash,
                max_turns=MAX_AUTO_TURNS,
            )
        except KeyboardInterrupt:
            console.print("\n[yellow]turn interrupted[/]")
            continue

        # Auto-TTS: read the most recent assistant turn from the session DB.
        if state["speak"]:
            speak_bin = shutil.which("joe-speak")
            if speak_bin:
                try:
                    c = _db()
                    row = c.execute(
                        "SELECT content FROM turns WHERE session = ? AND role = 'assistant' "
                        "ORDER BY ts DESC LIMIT 1",
                        (state["session"],),
                    ).fetchone()
                    c.close()
                    if row and row[0]:
                        subprocess.Popen(
                            [speak_bin, "--voice", state["voice"], "--background", row[0]],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                        )
                except Exception:
                    pass


# --------------------------------------------------------------------------
# CLI entrypoint
# --------------------------------------------------------------------------


def _scan_style(cwd: Path) -> dict:
    """Scan source files under cwd and produce a coarse style fingerprint.

    The output is a small dict of human-readable style hints that gets
    appended to the profile's context_extra so the coder model matches the
    existing convention rather than imposing a generic one. Best-effort:
    sampling, capped at ~120 files. Skips vendor / build / cache dirs.
    """
    exts = {".py", ".ts", ".tsx", ".js", ".jsx", ".rs", ".go", ".rb",
            ".swift", ".kt", ".java", ".c", ".cpp", ".h"}
    skip_dirs = {".git", "node_modules", "__pycache__", "target", ".next",
                 "dist", "build", ".venv", "venv", ".pytest_cache",
                 ".turbo", "vendor"}
    files: list[Path] = []
    for p in cwd.rglob("*"):
        if not p.is_file():
            continue
        if p.suffix.lower() not in exts:
            continue
        if any(part in skip_dirs for part in p.relative_to(cwd).parts):
            continue
        files.append(p)
        if len(files) >= 120:
            break
    if not files:
        return {}

    line_lengths: list[int] = []
    comment_lines = 0
    code_lines = 0
    tab_indent = 0
    space_indent = 0
    indent_widths: list[int] = []
    single_q = 0
    double_q = 0
    snake_count = 0
    camel_count = 0
    func_lines: list[int] = []
    cur_func_len = 0
    in_func = False

    comment_pat = re.compile(r"^\s*(#|//|/\*|\*)")
    snake_pat = re.compile(r"\b[a-z]+_[a-z0-9_]+\b")
    camel_pat = re.compile(r"\b[a-z]+[A-Z][a-zA-Z0-9]+\b")
    func_start = re.compile(r"^\s*(def |fn |func |function )")

    for fp in files:
        try:
            text = fp.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        for raw in text.splitlines():
            if not raw.strip():
                continue
            line_lengths.append(len(raw))
            if comment_pat.match(raw):
                comment_lines += 1
            else:
                code_lines += 1
            stripped = raw.lstrip(" \t")
            indent = raw[: len(raw) - len(stripped)]
            if indent:
                if indent[0] == "\t":
                    tab_indent += 1
                else:
                    space_indent += 1
                    # measure first run of leading spaces
                    width = len(indent) - len(indent.lstrip(" "))
                    if width:
                        indent_widths.append(width)
            # Quote style: count occurrences only in lines with strings.
            single_q += raw.count("'")
            double_q += raw.count('"')
            # Naming convention: count tokens
            snake_count += len(snake_pat.findall(raw))
            camel_count += len(camel_pat.findall(raw))
            # Function length tracking (rough).
            if func_start.match(raw):
                if in_func:
                    func_lines.append(cur_func_len)
                in_func = True
                cur_func_len = 0
            elif in_func:
                cur_func_len += 1
        if in_func:
            func_lines.append(cur_func_len)
            in_func = False; cur_func_len = 0

    if not line_lengths:
        return {}

    avg_ll = sum(line_lengths) / len(line_lengths)
    p90_ll = sorted(line_lengths)[int(0.9 * len(line_lengths))] if line_lengths else 0
    comment_density = comment_lines / max(1, comment_lines + code_lines)
    indent_kind = "tabs" if tab_indent > space_indent else "spaces"
    # mode width of leading spaces (commonly 2 or 4)
    indent_w = 4
    if indent_widths:
        from collections import Counter
        indent_w = Counter(indent_widths).most_common(1)[0][0]
    quote = "double" if double_q >= single_q else "single"
    naming = "snake_case" if snake_count >= camel_count else "camelCase"
    avg_func = (sum(func_lines) / len(func_lines)) if func_lines else 0
    return {
        "files_scanned": len(files),
        "avg_line_length": round(avg_ll, 1),
        "p90_line_length": int(p90_ll),
        "comment_density": round(comment_density, 3),
        "indent": f"{indent_w} {indent_kind}",
        "quote_style": quote,
        "naming": naming,
        "avg_function_length_lines": round(avg_func, 1),
    }


def _style_block(style: dict) -> str:
    """Render the style fingerprint as instructions for the coder model."""
    if not style:
        return ""
    bits = (
        f"This repo's style fingerprint (match it):\n"
        f"  - indent: {style['indent']}\n"
        f"  - quotes: prefer {style['quote_style']} quotes\n"
        f"  - naming: {style['naming']}\n"
        f"  - line length: aim for ~{int(style['avg_line_length'])} chars "
        f"(p90 = {style['p90_line_length']})\n"
        f"  - comment density: {style['comment_density'] * 100:.1f}% of lines "
        f"({'sparse' if style['comment_density'] < 0.08 else 'moderate'})\n"
        f"  - function length: ~{int(style['avg_function_length_lines'])} "
        f"lines on average; don't write 200-line monsters\n"
    )
    return bits


def cmd_init(args: argparse.Namespace) -> int:
    """`joe init`: scan cwd, detect runners, write .joe-profile.toml, seed RAG."""
    cwd = Path(os.path.expanduser(args.path)).resolve()
    if not cwd.is_dir():
        console.print(f"[red]not a directory: {cwd}[/]"); return 1
    profile_path = cwd / ".joe-profile.toml"
    if profile_path.exists() and not args.force:
        console.print(f"[red]{profile_path} already exists. Pass --force to overwrite.[/]")
        return 1
    repo_name = cwd.name
    try:
        gp = subprocess.run(
            ["git", "-C", str(cwd), "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=3,
        ).stdout.strip()
        if gp:
            repo_name = Path(gp).name
    except Exception:
        pass
    lang, root = _detect_lang_root(str(cwd))
    lint_cmd = test_cmd = build_cmd = ""
    default_coder = DEFAULT_CODER
    if lang == "python":
        lint_cmd = "ruff check ."
        test_cmd = "pytest"
        build_cmd = "python3 -m build"
    elif lang == "rust":
        lint_cmd = "cargo clippy -- -D warnings"
        test_cmd = "cargo test"
        build_cmd = "cargo build --release"
    elif lang == "node":
        runner = _node_runner(root) if root else "npm"
        lint_cmd = f"{runner} run lint"
        test_cmd = f"{runner} test"
        build_cmd = f"{runner} run build"
    elif lang == "go":
        lint_cmd = "go vet ./..."
        test_cmd = "go test ./..."
        build_cmd = "go build ./..."
    body = (
        f'# joe-profile for {repo_name}\n'
        f'default_coder = "{default_coder}"\n'
        f'default_base = "main"\n'
    )
    if lint_cmd:
        body += f'lint_cmd = "{lint_cmd}"\n'
    if test_cmd:
        body += f'test_cmd = "{test_cmd}"\n'
    if build_cmd:
        body += f'build_cmd = "{build_cmd}"\n'
    style = _scan_style(cwd) if not args.no_style else {}
    style_lines = _style_block(style) if style else ""
    style_summary = ""
    if style:
        style_summary = (
            f"  - indent: {style['indent']}\n"
            f"  - quotes: {style['quote_style']}\n"
            f"  - naming: {style['naming']}\n"
            f"  - p90 line len: {style['p90_line_length']}\n"
        )
    body += (
        f'\n'
        f'# context_extra is injected verbatim into joe\'s system prompt for\n'
        f'# this repo. Use it for repo-specific rules, glossary, conventions.\n'
        f'context_extra = """\n'
        f'{repo_name}: detected language = {lang or "unknown"}.\n'
        + (f'\n{style_lines}' if style_lines else '')
        + f'"""\n'
    )
    profile_path.write_text(body)
    rows = [
        Text(f"language: {lang or 'unknown'}", style="cyan"),
        Text(f"profile : {profile_path}", style="cyan"),
    ]
    if style:
        rows.append(Text(""))
        rows.append(Text(f"style fingerprint ({style['files_scanned']} files):",
                          style="bright_blue"))
        rows.append(Text(style_summary.rstrip(), style="bright_blue"))
    rows.extend([Text(""), Syntax(body, "toml", theme="ansi_dark")])
    panel(f"joe init: {repo_name}", Group(*rows), style="green")
    # Build initial RAG index for this repo via joe-index.
    indexer = shutil.which("joe-index")
    if indexer and not args.no_index:
        console.print(f"[dim]building RAG index for {cwd} (may take a minute)...[/]")
        cp = subprocess.run([indexer, "build", str(cwd)],
                            capture_output=True, text=True, timeout=600)
        if cp.returncode == 0:
            console.print("[green]index built[/]")
        else:
            console.print(f"[yellow]joe-index returned {cp.returncode}: {cp.stderr.strip()[:200]}[/]")
    elif args.no_index:
        console.print("[dim]skipping index build (--no-index)[/]")
    else:
        console.print("[dim]joe-index not on PATH; skipping RAG seed[/]")
    return 0


def cmd_self_update(args: argparse.Namespace) -> int:
    """`joe self-update`: pull updated binary from a remote, install, restart-hint."""
    src = args.from_url or os.environ.get("JOE_SELF_UPDATE_FROM",
                                          "ghostlm-linux:/tmp/joe")
    dest = Path(args.dest or os.path.expanduser("~/.local/bin/joe")).resolve()
    panel(
        "joe self-update",
        Text.from_markup(
            f"[bold]source:[/] {src}\n"
            f"[bold]target:[/] {dest}\n"
            "[dim]downloading...[/]"
        ),
        style="cyan",
    )
    # If src looks like host:path, use scp. Else assume http(s).
    if ":" in src and not src.startswith(("http://", "https://")):
        cp = subprocess.run(["scp", "-q", src, str(dest)],
                            capture_output=True, text=True, timeout=60)
        if cp.returncode != 0:
            console.print(f"[red]scp failed:[/] {cp.stderr.strip()}")
            return 1
    else:
        try:
            with urllib.request.urlopen(src, timeout=30) as r:
                dest.write_bytes(r.read())
        except Exception as e:
            console.print(f"[red]download failed:[/] {e}"); return 1
    dest.chmod(0o755)
    sz = dest.stat().st_size
    panel(
        "joe updated",
        Text.from_markup(
            f"[bold green]wrote[/] {dest}  ({sz // 1024} KB)\n"
            f"[dim]start a fresh `joe` to pick up the change.[/]"
        ),
        style="green",
    )
    return 0


def cmd_replay(session: str, alt_model: Optional[str] = None) -> int:
    """Step through a past session turn-by-turn.

    For each (user, assistant) pair, render both. After every pair, ask the
    user if they want to rerun the prompt against `alt_model` for a
    side-by-side comparison ('rerun' or 'rerun <model>'), or press enter to
    advance. Useful for forensics ("why did the model say that?") and for
    building eval candidates from real conversation history.
    """
    c = _db()
    rows = c.execute(
        "SELECT ts, role, content FROM turns WHERE session = ? ORDER BY ts ASC",
        (session,),
    ).fetchall()
    c.close()
    if not rows:
        console.print(f"[red]no turns for session {session!r}[/]")
        return 1
    # Pair user -> assistant. Skip 'system' rows used by /compact.
    pairs: list[tuple[str, str, str]] = []
    pending_u: Optional[tuple[str, str]] = None
    for ts, role, content in rows:
        if role == "user":
            pending_u = (ts, content)
        elif role == "assistant" and pending_u is not None:
            pairs.append((pending_u[0], pending_u[1], content))
            pending_u = None
    if not pairs:
        console.print(f"[yellow]session {session!r} has no complete pairs[/]")
        return 0
    console.rule(f"[bold cyan]replay  session={session}  pairs={len(pairs)}")
    for i, (ts, user_msg, asst_msg) in enumerate(pairs, 1):
        panel(
            f"[{i}/{len(pairs)}]  user  ·  {ts[:19]}",
            Text(user_msg),
            style="yellow",
        )
        panel(
            f"[{i}/{len(pairs)}]  assistant",
            Markdown(asst_msg) if len(asst_msg) < 6000 else
                Text(asst_msg[:6000] + "\n[...truncated...]"),
            style="cyan",
        )
        if i == len(pairs):
            break
        try:
            ans = input(
                "  press enter for next  ·  'r' to rerun against alt model  "
                "·  'r <model>' for a specific one  ·  'q' to quit > "
            ).strip()
        except (EOFError, KeyboardInterrupt):
            console.print("\n[dim]stopped[/]"); break
        if ans.startswith("q"):
            break
        if ans.startswith("r"):
            parts = ans.split(None, 1)
            target = parts[1] if len(parts) > 1 else (alt_model or DEFAULT_CODER)
            console.print(f"[dim]rerunning against [bold]{target}[/]...[/]")
            try:
                rerun = _ollama_once(target, user_msg).strip()
            except Exception as e:
                console.print(f"[red]rerun failed:[/] {e}")
                continue
            panel(
                f"rerun via {target}",
                Markdown(rerun) if len(rerun) < 6000 else Text(rerun[:6000]),
                style="bright_blue",
            )
    return 0


def cmd_mcp_init() -> int:
    """Scaffold ~/.joe-agent/mcp-clients.json with two commented-out example
    servers (filesystem, github). All entries start as enabled=false so joe
    doesn't try to connect to anything you haven't reviewed."""
    if MCP_CLIENTS_CONFIG.exists():
        console.print(
            f"[yellow]{MCP_CLIENTS_CONFIG} already exists; not overwriting.[/]"
        )
        return 0
    sample = {
        "servers": [
            {
                "name": "filesystem",
                "transport": "stdio",
                "enabled": False,
                "command": "npx",
                "args": ["-y", "@modelcontextprotocol/server-filesystem",
                         str(HOME / "Desktop")],
                "_help": (
                    "Official filesystem MCP server. Set enabled=true and "
                    "adjust the path to expose only the dir you want."
                ),
            },
            {
                "name": "github",
                "transport": "stdio",
                "enabled": False,
                "command": "npx",
                "args": ["-y", "@modelcontextprotocol/server-github"],
                "env": {"GITHUB_PERSONAL_ACCESS_TOKEN": "<paste-PAT-here>"},
                "_help": (
                    "Official GitHub MCP server. Paste a fine-grained PAT "
                    "above and set enabled=true."
                ),
            },
        ],
        "_help": (
            "Every entry has `enabled: false` by default. Flip to true after "
            "you've reviewed the command + args. Restart joe (or run /mcp "
            "reload) to pick up changes. transports: 'stdio' supported in v1."
        ),
    }
    MCP_CLIENTS_CONFIG.write_text(json.dumps(sample, indent=2) + "\n")
    panel(
        "joe mcp init",
        Text.from_markup(
            f"[bold]wrote:[/] {MCP_CLIENTS_CONFIG}\n"
            f"[bold]install:[/]\n"
            f"  python3 -m pip install --user mcp\n"
            f"  brew install node  (or any way to get npx)\n\n"
            f"[dim]edit the file, flip [bold]enabled[/] to true on the\n"
            f"servers you want, then [bold]joe mcp reload[/] (in REPL) or\n"
            f"restart joe.[/]"
        ),
        style="green",
    )
    return 0


def cmd_stats() -> int:
    """Local, telemetry-free analytics: scan local SQLite stores and emit
    aggregates that hint at how you actually use joe. Nothing leaves the
    machine. All counts derive from data you've already accumulated."""
    from collections import Counter

    blocks: list[str] = []

    # Sessions: per-day turn counts, total active days, longest session.
    try:
        c = _db()
        rows = c.execute(
            "SELECT session, ts, role FROM turns ORDER BY ts ASC"
        ).fetchall()
        c.close()
    except Exception:
        rows = []
    if rows:
        days = Counter()
        per_session = Counter()
        hour_buckets = Counter()
        for sess, ts, _role in rows:
            try:
                d = dt.datetime.fromisoformat(ts)
            except ValueError:
                continue
            days[d.date()] += 1
            per_session[sess] += 1
            hour_buckets[d.hour] += 1
        active_days = len(days)
        total_turns = sum(per_session.values())
        peak_day = max(days.items(), key=lambda kv: kv[1])
        peak_hour = max(hour_buckets.items(), key=lambda kv: kv[1])
        top_sessions = per_session.most_common(5)
        blocks.append(
            f"[bold cyan]sessions[/]\n"
            f"  total turns:     {total_turns}\n"
            f"  active days:     {active_days}\n"
            f"  peak day:        {peak_day[0]}  ({peak_day[1]} turns)\n"
            f"  peak hour (UTC): {peak_hour[0]:02d}:00  ({peak_hour[1]} turns)\n"
            f"  longest sessions:\n"
            + "\n".join(
                f"    {n:>4}  {s}" for s, n in top_sessions
            )
        )

    # Provenance: writes/edits per repo per day, top files, w:e ratio.
    try:
        c = _provdb()
        prov_rows = c.execute(
            "SELECT ts, path, op FROM provenance ORDER BY ts ASC"
        ).fetchall()
        c.close()
    except Exception:
        prov_rows = []
    if prov_rows:
        writes = sum(1 for _, _, op in prov_rows if op == "write")
        edits = sum(1 for _, _, op in prov_rows if op == "edit")
        repos = Counter()
        files = Counter()
        prov_hours = Counter()
        for ts, path, _op in prov_rows:
            # Repo guess: walk up for .git
            try:
                p = Path(path)
                for ancestor in p.parents:
                    if (ancestor / ".git").exists():
                        repos[ancestor.name] += 1
                        break
            except Exception:
                pass
            files[path.replace(str(HOME), "~")] += 1
            try:
                prov_hours[dt.datetime.fromisoformat(ts).hour] += 1
            except ValueError:
                pass
        top_repos = repos.most_common(5)
        top_files = files.most_common(5)
        peak_prov_hour = max(prov_hours.items(), key=lambda kv: kv[1]) \
            if prov_hours else (0, 0)
        blocks.append(
            f"[bold cyan]edits[/]\n"
            f"  total writes:    {writes}\n"
            f"  total edits:     {edits}\n"
            f"  w:e ratio:       "
            f"{writes / max(1, edits):.1f}:1\n"
            f"  peak edit hour:  {peak_prov_hour[0]:02d}:00\n"
            f"  most-touched repos:\n"
            + "\n".join(f"    {n:>4}  {r}" for r, n in top_repos)
            + ("\n  most-touched files:\n" if top_files else "")
            + "\n".join(f"    {n:>4}  {f[-60:]}" for f, n in top_files)
        )

    # Lessons: active rules + total events.
    try:
        c = _lessdb()
        n_events = c.execute("SELECT COUNT(*) FROM events").fetchone()[0]
        n_rules = c.execute(
            "SELECT COUNT(*) FROM rules WHERE status = 'active'"
        ).fetchone()[0]
        sources = c.execute(
            "SELECT source, COUNT(*) FROM events GROUP BY source"
            " ORDER BY 2 DESC"
        ).fetchall()
        c.close()
    except Exception:
        n_events = n_rules = 0
        sources = []
    blocks.append(
        f"[bold cyan]lessons[/]\n"
        f"  active rules:    {n_rules}\n"
        f"  events captured: {n_events}\n"
        + ("  by source:\n" + "\n".join(f"    {n:>4}  {s}" for s, n in sources)
           if sources else "")
    )

    # Knowledge graph + history index sizes.
    try:
        c = _kgdb()
        n_triples = c.execute("SELECT COUNT(*) FROM triples").fetchone()[0]
        c.close()
    except Exception:
        n_triples = 0
    try:
        c = _hidb()
        n_hist = c.execute("SELECT COUNT(*) FROM hist").fetchone()[0]
        c.close()
    except Exception:
        n_hist = 0
    blocks.append(
        f"[bold cyan]memory[/]\n"
        f"  knowledge triples:      {n_triples}\n"
        f"  embedded chat pairs:    {n_hist}"
    )

    # Eval runs: count + best model.
    try:
        c = _evaldb()
        n_evals = c.execute(
            "SELECT COUNT(DISTINCT ts) FROM results"
        ).fetchone()[0]
        best = c.execute(
            "SELECT model, AVG(score) FROM results"
            " GROUP BY model ORDER BY 2 DESC LIMIT 1"
        ).fetchone()
        c.close()
    except Exception:
        n_evals = 0
        best = None
    if n_evals or best:
        blocks.append(
            f"[bold cyan]eval[/]\n"
            f"  runs:        {n_evals}\n"
            + (f"  best model:  {best[0]} ({best[1]:.3f})\n" if best else "")
        )

    if not blocks:
        console.print("[dim](no data yet; use joe for a while and come back)[/]")
        return 0
    panel(
        f"joe stats  ·  {dt.datetime.now().strftime('%Y-%m-%d %H:%M')}",
        Text.from_markup("\n\n".join(blocks)),
        style="bright_blue",
        subtitle="local-only; nothing leaves the machine",
    )
    return 0


def cmd_ios_setup() -> int:
    """Print the iOS Shortcut recipe + curl examples for the /ios endpoint."""
    token_file = STATE_DIR / "http-token"
    token = token_file.read_text().strip() if token_file.exists() else "<run joe-http once to generate>"
    # Best-effort: find the Mac's LAN IP via `ipconfig getifaddr en0`.
    try:
        ip = subprocess.run(
            ["ipconfig", "getifaddr", "en0"],
            capture_output=True, text=True, timeout=3,
        ).stdout.strip()
    except Exception:
        ip = ""
    if not ip:
        try:
            ip = subprocess.run(
                ["ipconfig", "getifaddr", "en1"],
                capture_output=True, text=True, timeout=3,
            ).stdout.strip()
        except Exception:
            pass
    ip = ip or "<mac-lan-ip>"
    base = f"http://{ip}:8765"
    ntfy = NTFY_TOPIC or "<set NTFY_TOPIC in your shell>"
    recipe = (
        f"[bold]1. Start joe-http on the Mac (login item or launchd)[/]\n"
        f"   joe-http   # or run via joe-schedule for autostart\n"
        f"\n"
        f"[bold]2. Test from the same network[/]\n"
        f"   curl -sS -X POST {base}/ios \\\n"
        f"     -H \"Authorization: Bearer {token}\" \\\n"
        f"     -H \"Content-Type: application/json\" \\\n"
        f"     -d '{{\"prompt\": \"summarise my last commit\"}}'\n"
        f"\n"
        f"[bold]3. iOS Shortcut (one action: Get Contents of URL)[/]\n"
        f"   URL:    {base}/ios\n"
        f"   Method: POST\n"
        f"   Headers:\n"
        f"     Authorization: Bearer {token}\n"
        f"     Content-Type:  application/json\n"
        f"   Request body (JSON):\n"
        f"     {{\"prompt\": \"<Ask for Text>\", \"ntfy\": \"{ntfy}\"}}\n"
        f"\n"
        f"[bold]4. Phone setup[/]\n"
        f"   Install the ntfy.sh iOS app, subscribe to topic: [bold]{ntfy}[/]\n"
        f"   When the Shortcut posts to /ios with `ntfy`, joe runs in the\n"
        f"   background and pushes the answer to that topic. The push is\n"
        f"   the notification you'll see on your phone.\n"
        f"\n"
        f"[bold]5. Outside the LAN[/]\n"
        f"   Front joe-http with Tailscale (best) or a Cloudflare Tunnel.\n"
        f"   Do NOT open port 8765 to the public internet without TLS.\n"
    )
    panel("iOS bridge setup", Text.from_markup(recipe), style="cyan",
          subtitle=f"token file: {token_file}")
    return 0


def cmd_completion(args: list[str]) -> int:
    """Print a zsh tab-completion script for joe."""
    if not args or args[0] not in {"zsh", "bash", "fish"}:
        console.print(
            "[dim]usage: joe completion zsh|bash|fish[/]\n"
            "[dim]install with:[/]\n"
            "  joe completion zsh > ~/.zsh/_joe   # zsh\n"
            "  (then add 'fpath=(~/.zsh \\$fpath)' + 'autoload -U compinit; compinit'"
            " to ~/.zshrc)"
        )
        return 1
    shell = args[0]
    cmds = (
        "watch init self-update doctor tasks task blame ask inbox reflect "
        "sync eval train lessons ios-setup completion demo --help -p -s"
    ).split()
    slashes = " ".join(f"/{n}" for n in SLASH_COMMAND_NAMES)
    if shell == "zsh":
        body = (
            "#compdef joe\n"
            "_joe() {\n"
            "  local -a subs\n"
            "  subs=(" + " ".join(f"'{c}'" for c in cmds) + ")\n"
            "  _arguments '1: :->cmd' '*:: :->args'\n"
            "  case $state in\n"
            "    cmd)  _describe 'subcommand' subs ;;\n"
            "    args) _files ;;\n"
            "  esac\n"
            "}\n"
            "_joe \"$@\"\n"
        )
    elif shell == "bash":
        body = (
            "_joe_complete() {\n"
            "  local cur prev\n"
            "  cur=\"${COMP_WORDS[COMP_CWORD]}\"\n"
            "  if [ \"$COMP_CWORD\" -eq 1 ]; then\n"
            "    COMPREPLY=( $(compgen -W \"" + " ".join(cmds) + "\" -- \"$cur\") )\n"
            "  else\n"
            "    COMPREPLY=( $(compgen -f -- \"$cur\") )\n"
            "  fi\n"
            "}\n"
            "complete -F _joe_complete joe\n"
        )
    else:  # fish
        body = (
            f"complete -c joe -n '__fish_use_subcommand' -a '{' '.join(cmds)}'\n"
            "complete -c joe -F\n"
        )
    print(body)
    return 0


def cmd_demo() -> int:
    """Run a self-contained walkthrough of joe's killer features on a sample repo.

    Creates /tmp/joe-demo as a fresh Python project, runs joe init, makes a
    deliberately-flawed file, asks @@reviewer to review it, demonstrates
    /blame, /recall, /ask, lessons, macros. Auto-approves writes via
    JOE_AUTO_YES=1 so the demo plays start-to-finish without prompts.
    """
    import tempfile
    demo_root = Path(tempfile.gettempdir()) / "joe-demo"
    if demo_root.exists():
        shutil.rmtree(demo_root)
    demo_root.mkdir(parents=True)
    os.chdir(demo_root)

    os.environ["JOE_AUTO_YES"] = "1"

    def step(n: int, title: str, body: str = "") -> None:
        console.rule(f"[bold cyan]step {n}: {title}")
        if body:
            console.print(body)

    step(1, "create a sample Python project")
    (demo_root / "pyproject.toml").write_text(
        '[project]\nname = "demo"\nversion = "0.1.0"\n'
    )
    src = demo_root / "src"; src.mkdir()
    # Deliberately flawed file: silent except-pass, off-by-one slice, missing tests.
    (src / "tokenizer.py").write_text(
        'def split_tokens(text: str, n: int) -> list[str]:\n'
        '    """Naive whitespace tokenizer; returns the first n tokens."""\n'
        '    try:\n'
        '        toks = text.split()\n'
        '        return toks[1:n]   # bug: off-by-one slice + skips index 0\n'
        '    except Exception:\n'
        '        pass               # bug: silently swallows everything\n'
    )
    console.print(f"[dim]created {demo_root}/src/tokenizer.py with two known bugs[/]")

    step(2, "joe init  (detects language, writes profile, scans style)")
    cp = subprocess.run([sys.executable, sys.argv[0], "init", str(demo_root),
                         "--no-index"], capture_output=True, text=True)
    print(cp.stdout)

    step(3, "@@reviewer @@security run via one-shot joe -p")
    for agent in ("reviewer", "security"):
        console.rule(f"[bold blue]asking @@{agent}")
        cp = subprocess.run(
            [sys.executable, sys.argv[0], "-p",
             f"@@{agent} review src/tokenizer.py"],
            cwd=str(demo_root), capture_output=True, text=True, timeout=180,
        )
        print(cp.stdout[-3000:] if cp.stdout else "(no output)")

    step(4, "joe ask (knowledge graph, may be empty on a fresh install)")
    cp = subprocess.run(
        [sys.executable, sys.argv[0], "ask", "what tokenizer bugs exist in demo?"],
        capture_output=True, text=True, timeout=30,
    )
    print(cp.stdout)

    step(5, "/blame  (shows the AI-blame log for the file)")
    cp = subprocess.run(
        [sys.executable, sys.argv[0], "blame", str(src / "tokenizer.py")],
        capture_output=True, text=True, timeout=30,
    )
    print(cp.stdout)

    step(6, "tasks: one-line view of background work")
    cp = subprocess.run([sys.executable, sys.argv[0], "tasks"],
                        capture_output=True, text=True)
    print(cp.stdout)

    console.rule("[bold green]demo complete")
    console.print(
        f"[bold]sample repo:[/]      {demo_root}\n"
        f"[bold]what to try next:[/]\n"
        f"  cd {demo_root}\n"
        f"  joe                                # start the REPL\n"
        f"  /macro record my-morning           # capture a workflow\n"
        f"  /lessons distill                   # turn corrections into rules\n"
        f"  /reflect                           # write today's journal entry\n"
        f"  joe train collect && joe train modelfile  # rebuild personalised model\n"
    )
    return 0


def cmd_doctor(args: argparse.Namespace) -> int:
    """`joe doctor`: dependency / environment health check.

    With --fix, attempts to install missing items: pulls missing ollama
    models, pip-installs missing Python deps. System binaries still need
    manual brew/apt (we print the command).
    """
    rows: list[tuple[str, bool, str, str]] = []  # label, ok, detail, fix_hint
    def chk(label: str, ok: bool, detail: str = "", fix: str = "") -> None:
        rows.append((label, ok, detail, fix))

    # Ollama + models.
    try:
        r = urllib.request.urlopen("http://localhost:11434/api/tags", timeout=3)
        tags = json.loads(r.read()).get("models", [])
        chk("ollama", True, f"{len(tags)} models")
        names = {m.get("name", "").split(":")[0] for m in tags}
        chk("model: joe-gemma", "joe-gemma" in names, "",
            "ollama pull gemma3:4b  # then build a personalised Modelfile")
        chk("model: qwen2.5-coder",
            any("qwen2.5-coder" in m.get("name", "") for m in tags), "",
            "ollama pull qwen2.5-coder:14b")
        chk("model: nomic-embed-text", "nomic-embed-text" in names, "",
            "ollama pull nomic-embed-text")
    except Exception as e:
        chk("ollama", False, str(e), "brew install ollama && ollama serve")

    # Python deps.
    py_deps = {
        "rich": "rich", "prompt_toolkit": "prompt_toolkit",
        "fastapi": "fastapi", "uvicorn": "uvicorn", "mcp": "mcp",
    }
    for imp, pkg in py_deps.items():
        try:
            __import__(imp)
            chk(f"python: {pkg}", True)
        except ImportError:
            chk(f"python: {pkg}", False, "", f"python3 -m pip install --user {pkg}")

    # Companion binaries (joe-*).
    for t in ("joe-speak", "joe-listen", "joe-schedule",
              "joe-pair", "joe-watch-logs", "joe-proactive",
              "joe-http", "joe-mcp", "joe-index"):
        chk(t, shutil.which(t) is not None)

    # System binaries: per-platform brew vs apt hints.
    is_linux = sys.platform.startswith("linux")
    pkg_mgr_hint = "apt install" if is_linux else "brew install"
    for t, mac_pkg, linux_pkg in [
        ("gh", "gh", "gh"),
        ("git", "git", "git"),
        ("fswatch", "fswatch", "inotify-tools  # joe will use inotifywait on Linux"),
        ("rec", "sox", "sox"),
        ("whisper-cli", "whisper-cpp", "(build from source: github.com/ggerganov/whisper.cpp)"),
        ("pngpaste", "pngpaste", "(macOS only; on Linux joe uses xclip/wl-paste for images)"),
        ("pbcopy", "(macOS built-in)", "xclip  # OR wl-clipboard"),
        ("osascript", "(macOS built-in)", "(macOS only; on Linux joe uses notify-send)"),
        ("notify-send", "(macOS uses osascript)", "libnotify-bin"),
        ("espeak", "(macOS uses say)", "espeak  # or piper-tts for nicer voices"),
    ]:
        present = shutil.which(t) is not None
        # Skip flagging platform-specific tools missing on the wrong platform.
        if not present:
            if is_linux and t in {"pngpaste", "pbcopy", "osascript"}:
                continue
            if not is_linux and t in {"notify-send", "espeak"}:
                continue
        pkg = linux_pkg if is_linux else mac_pkg
        chk(t, present, "", f"{pkg_mgr_hint} {pkg}")

    # Optional configuration.
    chk("ntfy topic", bool(NTFY_TOPIC),
        NTFY_TOPIC or "set NTFY_TOPIC for phone push",
        "echo 'export NTFY_TOPIC=joe-<your-unique-tag>' >> ~/.zshrc")
    chk("history-index", HISTORY_INDEX_DB.exists(),
        str(HISTORY_INDEX_DB).replace(str(HOME), "~"))

    # If --fix, attempt to remediate.
    fixed: list[str] = []
    if getattr(args, "fix", False):
        for label, ok, _detail, hint in rows:
            if ok or not hint:
                continue
            # Auto-run ollama pull and pip install; print everything else.
            if hint.startswith("ollama pull "):
                model = hint.split("# ", 1)[0].strip().split()[-1]
                console.print(f"[dim]pulling {model}...[/]")
                cp = subprocess.run(["ollama", "pull", model],
                                    capture_output=True, text=True)
                if cp.returncode == 0:
                    fixed.append(f"ollama pull {model}")
                else:
                    console.print(f"[red]pull failed: {cp.stderr.strip()[:200]}[/]")
            elif hint.startswith("python3 -m pip install --user "):
                pkg = hint.split()[-1]
                console.print(f"[dim]pip-installing {pkg}...[/]")
                cp = subprocess.run(
                    [sys.executable, "-m", "pip", "install", "--user", "--quiet", pkg],
                    capture_output=True, text=True,
                )
                if cp.returncode == 0:
                    fixed.append(f"pip install {pkg}")

    lines = []
    for label, ok, detail, hint in rows:
        mark = "[green]ok  [/]" if ok else "[red]miss[/]"
        extra = f"  [dim]{detail}[/]" if detail else ""
        if not ok and hint and not getattr(args, "fix", False):
            extra += f"\n     [dim italic]fix:[/] [bold]{hint}[/]"
        lines.append(f"{mark}  {label}{extra}")
    body = "\n".join(lines)
    if fixed:
        body += "\n\n[green]auto-fixed:[/] " + ", ".join(fixed)
    panel("joe doctor" + (" --fix" if getattr(args, "fix", False) else ""),
          Text.from_markup(body), style="cyan")
    return 0 if all(ok for _, ok, _, _ in rows) else 1


def main() -> int:
    # Seed the default subagents on every invocation. Idempotent: no-op once
    # AGENTS_DIR has any file in it.
    _seed_default_agents()
    # Pre-dispatch: `joe watch ...` is a different subcommand from `joe` (REPL)
    # or `joe -p ...` (one-shot). Peel off the subcommand if it's "watch";
    # everything else stays in the default joe entrypoint.
    argv = sys.argv[1:]
    if argv and argv[0] == "watch":
        wp = argparse.ArgumentParser(prog="joe watch",
                                     description="auto-run lint + test on file change")
        wp.add_argument("path", nargs="?", default=".", help="directory to watch (default: cwd)")
        wp.add_argument("--debounce", type=float, default=2.0,
                        help="seconds to wait after a change before firing (default: 2.0)")
        return cmd_watch(wp.parse_args(argv[1:]))
    if argv and argv[0] == "init":
        ip = argparse.ArgumentParser(prog="joe init",
                                     description="seed .joe-profile.toml + RAG index for cwd")
        ip.add_argument("path", nargs="?", default=".")
        ip.add_argument("--force", action="store_true",
                        help="overwrite existing .joe-profile.toml")
        ip.add_argument("--no-index", action="store_true",
                        help="skip the RAG index build step")
        ip.add_argument("--no-style", action="store_true",
                        help="skip the codebase style fingerprint scan")
        return cmd_init(ip.parse_args(argv[1:]))
    if argv and argv[0] == "self-update":
        up = argparse.ArgumentParser(prog="joe self-update",
                                     description="fetch latest joe binary")
        up.add_argument("--from", dest="from_url", default=None,
                        help="scp source (host:path) or http(s) URL")
        up.add_argument("--dest", default=None,
                        help="install path (default: ~/.local/bin/joe)")
        return cmd_self_update(up.parse_args(argv[1:]))
    if argv and argv[0] == "doctor":
        dp = argparse.ArgumentParser(prog="joe doctor")
        dp.add_argument("--fix", action="store_true",
                        help="attempt to install missing ollama models + python deps")
        return cmd_doctor(dp.parse_args(argv[1:]))
    if argv and argv[0] == "completion":
        return cmd_completion(argv[1:])
    if argv and argv[0] == "demo":
        return cmd_demo()
    if argv and argv[0] == "ios-setup":
        return cmd_ios_setup()
    if argv and argv[0] == "stats":
        return cmd_stats()
    if argv and argv[0] == "mcp":
        if len(argv) < 2 or argv[1] not in {"init", "list"}:
            console.print("[red]usage: joe mcp init | list[/]")
            return 1
        if argv[1] == "init":
            return cmd_mcp_init()
        if argv[1] == "list":
            _mcp_connect_all()
            if not _MCP_CLIENTS:
                console.print(
                    "[dim](no MCP clients configured; joe mcp init scaffolds the config)[/]"
                )
                return 0
            for name, c in _MCP_CLIENTS.items():
                status = "ok" if c.connected else "FAIL"
                print(f"  {status:<4}  {name:<24}  {len(c.tools)} tool(s)")
            return 0
    if argv and argv[0] == "replay":
        if len(argv) < 2:
            console.print("[red]usage: joe replay <session> [alt-model][/]"); return 1
        return cmd_replay(argv[1], argv[2] if len(argv) > 2 else None)
    if argv and argv[0] == "blame":
        if len(argv) < 2:
            console.print("[red]usage: joe blame <path>[:line][/]"); return 1
        return cmd_blame(argv[1])
    if argv and argv[0] == "ask":
        if len(argv) < 2:
            console.print("[red]usage: joe ask <question>[/]"); return 1
        return cmd_ask(" ".join(argv[1:]), DEFAULT_MODEL)
    if argv and argv[0] == "inbox":
        return cmd_inbox()
    if argv and argv[0] == "reflect":
        return cmd_reflect(DEFAULT_MODEL)
    if argv and argv[0] == "sync":
        return cmd_sync(argv[1:])
    if argv and argv[0] == "eval":
        return cmd_eval(argv[1:], DEFAULT_MODEL)
    if argv and argv[0] == "train":
        return cmd_train(argv[1:], DEFAULT_MODEL)
    if argv and argv[0] == "lessons":
        if len(argv) < 2 or argv[1] not in {"list", "distill", "review"}:
            console.print("[red]usage: joe lessons list|distill|review[/]"); return 1
        if argv[1] == "distill":
            n = lessons_distill(DEFAULT_MODEL)
            print(f"distilled {n} new rule(s)")
            return 0
        if argv[1] == "list":
            for r in lessons_active_rules():
                print(f"- {r}")
            return 0
        if argv[1] == "review":
            editor = os.environ.get("EDITOR") or "vi"
            PROMPT_SUPPLEMENT.touch(exist_ok=True)
            subprocess.run([editor, str(PROMPT_SUPPLEMENT)])
            return 0
    if argv and argv[0] == "tasks":
        cmd_tasks(); return 0
    if argv and argv[0] == "task":
        if len(argv) < 2:
            console.print("[red]usage: joe task <id> | joe task kill <id>[/]")
            return 1
        if argv[1] == "kill" and len(argv) >= 3:
            return 0 if task_kill(argv[2]) else 1
        cmd_task_show(argv[1]); return 0

    ap = argparse.ArgumentParser(
        prog="joe",
        description=(
            "interactive joe-agent shell.\n"
            "subcommands (pre-argparse):\n"
            "  watch         auto lint+test on file change\n"
            "  init          seed .joe-profile.toml + RAG index for cwd\n"
            "  self-update   fetch latest joe binary\n"
            "  doctor        env/dependency health check\n"
            "  tasks         list background tasks\n"
            "  task <id>     show one task\n"
            "  blame <p>     AI-blame: who wrote that code\n"
            "  ask <q>       grounded answer from knowledge graph\n"
            "  inbox         PRs / mentions / failing CI / tasks\n"
            "  reflect       write today's developer-journal entry\n"
            "  sync          init <url> | push | pull | status\n"
            "  eval          build | run [model] | report\n"
            "  train         collect | modelfile | lora | activate\n"
            "  lessons       list | distill | review\n"
            "  ios-setup     print the iOS Shortcut recipe"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("-p", "--prompt", help="one-shot: run this prompt then exit")
    ap.add_argument("-s", "--session", help="session name for persistent memory")
    ap.add_argument("--model", default=DEFAULT_MODEL, help="orchestrator model (default: joe-gemma)")
    ap.add_argument("--coder", default=DEFAULT_CODER,
                    help=f"code-delegate model (default: {DEFAULT_CODER})")
    ap.add_argument("--unsafe-bash", action="store_true",
                    help="disable the bash allow-list (use carefully)")
    ap.add_argument("--image", action="append", default=[],
                    help="attach an image file to the prompt (repeatable)")
    ap.add_argument(
        "--transcript", nargs="?", const="", default=None,
        help="mirror every Rich render + user input to a transcript file "
             "(default: ~/.joe-agent/transcripts/repl-<ts>.log). External "
             "observers can `tail -F` it over SSH for a live view.",
    )
    args = ap.parse_args(argv)

    if args.transcript is not None:
        # nargs='?' + const='' means: present-but-no-value → use default path
        chosen = args.transcript if args.transcript else None
        resolved = enable_transcript(chosen)
        console.print(
            f"[dim]transcript: mirroring to[/] [bold]{resolved}[/]\n"
            f"[dim]watch live with:[/] [bold]tail -F {resolved}[/]"
        )

    # Stash --image attachments before the model call.
    for path in args.image:
        try:
            attach_image(path)
        except ToolError as e:
            console.print(f"[red]{e}[/]")
            return 1

    if args.prompt:
        cwd = Path.cwd()
        session = args.session or f"joe-oneshot-{dt.datetime.now().strftime('%Y%m%d-%H%M%S')}"
        # One-shot also gets MCP clients so the orchestrator can use them.
        _mcp_connect_all()
        run_turn(
            model=args.model, coder_model=args.coder, user_msg=args.prompt,
            cwd=cwd, session=session, allow_all_bash=args.unsafe_bash,
            max_turns=MAX_AUTO_TURNS,
        )
        return 0
    return repl(args.model, args.coder, args.unsafe_bash, args.session)


if __name__ == "__main__":
    raise SystemExit(main())
