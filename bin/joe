console = Console()


# --------------------------------------------------------------------------
# Live transcript: tee console output to a file so an external observer
# (e.g. someone tailing the file over SSH) sees the same rendered REPL.
# --------------------------------------------------------------------------


class _TeeStream:
    """A file-like object that writes to two underlying streams.

    Used by --transcript so every byte Rich emits to stdout also lands in
    a transcript file, ANSI escapes and all. The transcript becomes a
    faithful replay that any consumer (text editor, `tail -F`, asciinema-
    style player) can render.
    """

    def __init__(self, primary, mirror) -> None:
        self._primary = primary
        self._mirror = mirror

    def write(self, s: str) -> int:
        self._primary.write(s)
        try:
            self._mirror.write(s)
            self._mirror.flush()
        except Exception:
            pass
        try:
            return len(s)
        except Exception:
            return 0

    def flush(self) -> None:
        try:
            self._primary.flush()
        except Exception:
            pass
        try:
            self._mirror.flush()
        except Exception:
            pass

    def isatty(self) -> bool:
        # Pretend to be a TTY so Rich keeps emitting colors. The mirror
        # file ends up with ANSI escapes; `tail -F` over SSH renders them.
        try:
            return self._primary.isatty()
        except Exception:
            return False

    def __getattr__(self, name):
        return getattr(self._primary, name)


_transcript_handle = None  # set by enable_transcript(); kept module-level
                            # so REPL hooks can write user-input lines.


def enable_transcript(path: Optional[str] = None) -> Path:
    """Start tee'ing console output to `path` (default: a timestamped file
    under ~/.joe-agent/transcripts/). Returns the resolved path. Idempotent
    only in the sense that calling twice replaces the destination.
    """
    global _transcript_handle
    if path is None:
        out_dir = STATE_DIR / "transcripts"
        out_dir.mkdir(parents=True, exist_ok=True)
        ts = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
        resolved = out_dir / f"repl-{ts}.log"
    else:
        resolved = Path(os.path.expanduser(path)).resolve()
        resolved.parent.mkdir(parents=True, exist_ok=True)
    # Line-buffered so external tails see updates promptly.
    handle = open(resolved, "w", buffering=1, encoding="utf-8")
    _transcript_handle = handle
    # Rewire Rich's underlying file to our tee. Rich reads self.file at
    # each write, so setting .file mid-flight works for all later calls.
    console.file = _TeeStream(sys.stdout, handle)
    # A header so the consumer knows what they're looking at.
    handle.write(
        f"# joe transcript -- started {dt.datetime.now().isoformat()}\n"
        f"# pid={os.getpid()}  cwd={Path.cwd()}\n"
        f"# tail -F {resolved}  on a remote host for a live view\n\n"
    )
    handle.flush()
    return resolved


def transcript_user_input(text: str) -> None:
    """Write a user-input line to the transcript file so the observer can
    see what was typed (the terminal already shows it via prompt_toolkit;
    Rich never sees those bytes)."""
    if _transcript_handle is None:
        return
    try:
        _transcript_handle.write(f"\n[USER] {text}\n")
        _transcript_handle.flush()
    except Exception:
        pass


# --------------------------------------------------------------------------
# Portable OS helpers: notify, speak, clipboard read/write.
# joe is Mac-first but everything below has a Linux fallback so the agent
# core works without code changes when you `joe sync pull` to a Linux box.
# --------------------------------------------------------------------------

_IS_DARWIN = sys.platform == "darwin"


def os_notify(title: str, body: str) -> None:
    """Pop a desktop notification. macOS uses osascript, Linux notify-send."""
    title_s = title[:80].replace('"', '\\"')
    body_s = body[:240].replace('"', '\\"')
    if _IS_DARWIN:
        osa = shutil.which("osascript")
        if not osa:
            return
        subprocess.run(
            [osa, "-e",
             f'display notification "{body_s}" with title "{title_s}"'],
            capture_output=True,
        )
        return
    nsend = shutil.which("notify-send")
    if nsend:
        subprocess.run([nsend, "--app-name=joe", title_s, body_s],
                       capture_output=True)


def os_speak(text: str, voice: str = "Samantha", rate: int = 200,
             background: bool = True) -> None:
    """TTS. macOS: `say`. Linux: piper-tts (preferred), else espeak."""
    if not text.strip():
        return
    if _IS_DARWIN:
        say = shutil.which("say")
        if not say:
            return
        cmd = [say, "-v", voice, "-r", str(rate), text[:4000]]
    else:
        piper = shutil.which("piper-tts") or shutil.which("piper")
        espeak = shutil.which("espeak") or shutil.which("espeak-ng")
        if piper:
            # Piper has no built-in playback; pipe to aplay. Skipping unless
            # both are present.
            aplay = shutil.which("aplay") or shutil.which("paplay")
            if not aplay:
                espeak = espeak or shutil.which("espeak")
            else:
                ph = subprocess.Popen(
                    [piper, "--model", "en_US-lessac-medium"],
                    stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                    stderr=subprocess.DEVNULL,
                )
                ah = subprocess.Popen([aplay, "-q"], stdin=ph.stdout,
                                      stderr=subprocess.DEVNULL)
                ph.stdin.write(text[:4000].encode()); ph.stdin.close()
                if not background:
                    ah.wait()
                return
        if not espeak:
            return
        cmd = [espeak, "-s", str(int(rate * 0.9)), text[:4000]]
    if background:
        subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        subprocess.run(cmd)


def os_clip_copy(text: str) -> bool:
    """Put text on the system clipboard. Returns True on success."""
    candidates: list[list[str]] = []
    if _IS_DARWIN:
        if shutil.which("pbcopy"):
            candidates.append(["pbcopy"])
    else:
        # Wayland first, then X11.
        if shutil.which("wl-copy"):
            candidates.append(["wl-copy"])
        if shutil.which("xclip"):
            candidates.append(["xclip", "-selection", "clipboard"])
        if shutil.which("xsel"):
            candidates.append(["xsel", "--clipboard", "--input"])
    for cmd in candidates:
        try:
            p = subprocess.Popen(cmd, stdin=subprocess.PIPE)
            p.communicate(text.encode())
            if p.returncode == 0:
                return True
        except Exception:
            continue
    return False


def os_clip_image() -> Optional[Path]:
    """Capture the clipboard image to a temp PNG. Returns path or None."""
    out_dir = STATE_DIR / "pastes"
    out_dir.mkdir(parents=True, exist_ok=True)
    out_path = out_dir / f"paste-{dt.datetime.now().strftime('%Y%m%d-%H%M%S')}.png"
    if _IS_DARWIN:
        pngpaste = shutil.which("pngpaste")
        if not pngpaste:
            raise ToolError("pngpaste not found. Install with: brew install pngpaste")
        cp = subprocess.run([pngpaste, str(out_path)],
                            capture_output=True, text=True)
        if cp.returncode != 0:
            raise ToolError(
                f"pngpaste failed; is there an image on the clipboard? "
                f"(stderr: {cp.stderr.strip()})"
            )
    else:
        xclip = shutil.which("xclip")
        wl = shutil.which("wl-paste")
        if wl:
            cp = subprocess.run([wl, "-t", "image/png", "--no-newline"],
                                capture_output=True)
        elif xclip:
            cp = subprocess.run(
                [xclip, "-selection", "clipboard", "-t", "image/png", "-o"],
                capture_output=True,
            )
        else:
            raise ToolError("no clipboard image tool found; install xclip or wl-clipboard")
        if cp.returncode != 0 or not cp.stdout:
            raise ToolError("clipboard does not contain an image (or no image tool)")
        out_path.write_bytes(cp.stdout)
    if not out_path.exists() or out_path.stat().st_size == 0:
        raise ToolError("clipboard image is empty")
    return out_path


