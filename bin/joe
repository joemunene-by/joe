def banner(model: str, cwd: Path) -> None:
    short = str(cwd).replace(str(HOME), "~")
    body = Group(
        Text(_BRAND, style="bold cyan"),
        Text(""),
        Text.from_markup(
            f"[bold]model:[/] [cyan]{model}[/]  "
            f"[bold]coder:[/] [cyan]{DEFAULT_CODER}[/]\n"
            f"[bold]cwd:[/]   [yellow]{short}[/]\n"
            f"[dim]type [bold]/help[/] for commands, [bold]/exit[/] to quit. "
            f"start typing to chat.[/]"
        ),
    )
    console.print(Panel(body, border_style="cyan", padding=(0, 1)))


def panel(title: str, body, style: str = "white", subtitle: Optional[str] = None) -> None:
    if isinstance(body, str):
        body = Text(body)
    console.print(Panel(body, title=title, title_align="left", border_style=style, subtitle=subtitle))


# --------------------------------------------------------------------------
# Session memory (SQLite)
# --------------------------------------------------------------------------


def _db() -> sqlite3.Connection:
    conn = sqlite3.connect(str(SESSION_DB))
    conn.execute(
        "CREATE TABLE IF NOT EXISTS turns ("
        " session TEXT NOT NULL, ts TEXT NOT NULL,"
        " role TEXT NOT NULL, content TEXT NOT NULL)"
    )
    conn.execute("CREATE INDEX IF NOT EXISTS idx_turns ON turns(session, ts)")
    return conn


def session_recall(name: str, max_pairs: int = 12) -> str:
    c = _db()
    rows = list(reversed(c.execute(
        "SELECT role, content FROM turns WHERE session = ? ORDER BY ts DESC LIMIT ?",
        (name, max_pairs * 2),
    ).fetchall()))
    c.close()
    if not rows:
        return ""
    return "<conversation_history>\n" + "\n\n".join(f"{r.upper()}: {c}" for r, c in rows) + "\n</conversation_history>"


def session_append(name: str, role: str, content: str) -> None:
    c = _db()
    c.execute("INSERT INTO turns (session, ts, role, content) VALUES (?, ?, ?, ?)",
              (name, dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(), role, content))
    c.commit(); c.close()


# --------------------------------------------------------------------------
# Edit history (undo / redo / history slash commands)
# --------------------------------------------------------------------------

# Each edit-history entry is one line of JSON in EDIT_LOG with this shape:
#   {"ts": ..., "path": ..., "before_blob": ..., "after_blob": ...,
#    "op": "write" | "edit", "applied": True/False, "note": "..."}
#
# `before_blob` / `after_blob` point at files in EDITS_DIR named by content
# hash so identical states share storage. `applied` flips to False after
# /undo and back to True after /redo, so the log doubles as redo state.


def _hash_text(text: str) -> str:
    import hashlib
    return hashlib.sha1(text.encode("utf-8", errors="replace")).hexdigest()[:16]


def _store_blob(text: str) -> str:
    h = _hash_text(text)
    p = EDITS_DIR / h
    if not p.exists():
        p.write_text(text, encoding="utf-8")
    return h


def _load_blob(h: str) -> str:
    p = EDITS_DIR / h
    if not p.exists():
        raise FileNotFoundError(f"edit blob {h} missing")
    return p.read_text(encoding="utf-8")


def log_edit(path: str, before: Optional[str], after: str, op: str, note: str = "") -> None:
    """Append an entry to the edit log. before=None for new files."""
    entry = {
        "ts": dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
        "path": str(_resolve_path(path)),
        "before_blob": _store_blob(before) if before is not None else None,
        "after_blob": _store_blob(after),
        "op": op,
        "applied": True,
        "note": note,
    }
    with EDIT_LOG.open("a") as f:
        f.write(json.dumps(entry) + "\n")


def _read_log() -> list[dict]:
    if not EDIT_LOG.exists():
        return []
    out: list[dict] = []
    for ln in EDIT_LOG.read_text().splitlines():
        ln = ln.strip()
        if not ln:
            continue
        try:
            out.append(json.loads(ln))
        except json.JSONDecodeError:
            continue
    return out


def _write_log(entries: list[dict]) -> None:
    with EDIT_LOG.open("w") as f:
        for e in entries:
            f.write(json.dumps(e) + "\n")


def cmd_history(limit: int = 15) -> None:
    entries = _read_log()
    if not entries:
        panel("Edit history", "(no edits yet)", style="dim")
        return
    rows: list[str] = []
    now = dt.datetime.now(dt.UTC).replace(tzinfo=None)
    for i, e in enumerate(reversed(entries[-limit:])):
        ts = dt.datetime.fromisoformat(e["ts"])
        age = now - ts
        age_s = f"{int(age.total_seconds())}s"
        if age.total_seconds() > 3600:
            age_s = f"{age.total_seconds() / 3600:.1f}h"
        elif age.total_seconds() > 60:
            age_s = f"{int(age.total_seconds() / 60)}m"
        status = "" if e["applied"] else " [undone]"
        rel = e["path"].replace(str(HOME), "~")
        rows.append(f"{i:>3}. [{e['op']:<5}] {age_s:>5} ago  {rel}{status}")
    panel(f"Recent edits (top of stack last)", Text("\n".join(reversed(rows))), style="cyan",
          subtitle=f"{len(entries)} total")


def cmd_undo(n: int = 1) -> None:
    entries = _read_log()
    applied = [e for e in entries if e["applied"]]
    if not applied:
        console.print("[yellow]nothing to undo[/]")
        return
    target = applied[-n:]  # most recent N
    for e in reversed(target):
        path = Path(e["path"])
        before = e["before_blob"]
        if before is None:
            # File was created by us; undo = delete.
            if path.exists():
                if _confirm(f"Undo created file: delete {path}?"):
                    path.unlink()
                    e["applied"] = False
                    console.print(f"[green]deleted[/] {path}")
                    lesson_capture(
                        source="undo",
                        rejected=f"created {path}",
                        note="user reverted the creation outright",
                    )
                else:
                    console.print(f"[dim]skipped {path}[/]")
        else:
            content = _load_blob(before)
            if _confirm(f"Undo {e['op']} on {path}: restore {len(content)} bytes?"):
                path.write_text(content, encoding="utf-8")
                e["applied"] = False
                console.print(f"[green]reverted[/] {path}")
                lesson_capture(
                    source="undo",
                    rejected=f"{e['op']} on {path}",
                    note=f"user reverted the change to its prior state ({len(content)} bytes)",
                )
            else:
                console.print(f"[dim]skipped {path}[/]")
    _write_log(entries)


def cmd_redo(n: int = 1) -> None:
    entries = _read_log()
    undone = [e for e in entries if not e["applied"]]
    if not undone:
        console.print("[yellow]nothing to redo[/]")
        return
    target = undone[:n]
    for e in target:
        path = Path(e["path"])
        after = e["after_blob"]
        content = _load_blob(after)
        if _confirm(f"Redo {e['op']} on {path}: re-apply {len(content)} bytes?"):
            path.write_text(content, encoding="utf-8")
            e["applied"] = True
            console.print(f"[green]re-applied[/] {path}")
        else:
            console.print(f"[dim]skipped {path}[/]")
    _write_log(entries)


# --------------------------------------------------------------------------
# AI-blame / provenance log
# --------------------------------------------------------------------------
# Every successful <write> / <edit> through joe is logged with the user
# message that triggered it, the model that produced it, the active subagent
# persona (if any), the session, and approximate line range. `joe blame
# file:line` then surfaces "this code came from this prompt under this
# persona on this date", analogous to `git blame`, but for *intent* rather
# than just the most recent commit author.


def _provdb() -> sqlite3.Connection:
    c = sqlite3.connect(str(PROVENANCE_DB))
    c.execute(
        "CREATE TABLE IF NOT EXISTS provenance ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " ts TEXT NOT NULL,"
        " path TEXT NOT NULL,"
        " op TEXT NOT NULL,"
        " session TEXT NOT NULL,"
        " model TEXT NOT NULL,"
        " agent TEXT NOT NULL,"
        " user_msg TEXT NOT NULL,"
        " line_start INTEGER,"
        " line_end INTEGER,"
        " adds INTEGER,"
        " dels INTEGER,"
        " before_blob TEXT,"
        " after_blob TEXT)"
    )
    c.execute("CREATE INDEX IF NOT EXISTS idx_prov_path ON provenance(path)")
    c.execute("CREATE INDEX IF NOT EXISTS idx_prov_ts ON provenance(ts)")
    return c


def provenance_record(
    path: Path, op: str, before: Optional[str], after: str,
    line_start: Optional[int], line_end: Optional[int],
    adds: int, dels: int,
) -> None:
    """Stamp a write/edit. Best-effort; never raises."""
    try:
        before_blob = _store_blob(before) if before is not None else None
        after_blob = _store_blob(after)
        c = _provdb()
        c.execute(
            "INSERT INTO provenance (ts, path, op, session, model, agent,"
            " user_msg, line_start, line_end, adds, dels, before_blob, after_blob)"
            " VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
            (
                dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
                str(path),
                op,
                _TURN_CTX.get("session", ""),
                _TURN_CTX.get("model", ""),
                _TURN_CTX.get("agent", ""),
                _TURN_CTX.get("user_msg", "")[:4000],
                line_start, line_end, adds, dels,
                before_blob, after_blob,
            ),
        )
        c.commit(); c.close()
    except Exception:
        return


def provenance_blame(path: str, line: Optional[int]) -> list[dict]:
    """Return matching provenance entries for `path:line`, newest first."""
    p = str(_resolve_path(path))
    c = _provdb()
    if line is None:
        rows = c.execute(
            "SELECT ts, path, op, session, model, agent, user_msg,"
            " line_start, line_end, adds, dels"
            " FROM provenance WHERE path = ? ORDER BY ts DESC LIMIT 30",
            (p,),
        ).fetchall()
    else:
        rows = c.execute(
            "SELECT ts, path, op, session, model, agent, user_msg,"
            " line_start, line_end, adds, dels"
            " FROM provenance WHERE path = ?"
            " AND ((line_start IS NULL OR line_start <= ?)"
            " AND  (line_end   IS NULL OR line_end   >= ?))"
            " ORDER BY ts DESC LIMIT 30",
            (p, line, line),
        ).fetchall()
    c.close()
    cols = ["ts", "path", "op", "session", "model", "agent", "user_msg",
            "line_start", "line_end", "adds", "dels"]
    return [dict(zip(cols, r)) for r in rows]


def cmd_blame(target: str) -> int:
    """Print provenance entries for `path` or `path:line`."""
    line: Optional[int] = None
    path = target
    if ":" in target and target.rsplit(":", 1)[-1].isdigit():
        path, _, ln = target.rpartition(":")
        line = int(ln)
    rows = provenance_blame(path, line)
    if not rows:
        console.print(f"[dim](no provenance for {target}; the code may pre-date joe or "
                      f"was written outside joe)[/]")
        return 0
    blocks = []
    for r in rows:
        when = r["ts"][:19]
        rng = (f"L{r['line_start']}-{r['line_end']}" if r["line_start"] is not None
               else "whole file")
        agent_lbl = f"@@{r['agent']}" if r["agent"] else "(no agent)"
        msg = r["user_msg"][:300] + ("..." if len(r["user_msg"]) > 300 else "")
        blocks.append(
            f"[bold]{when}[/]  [{r['op']}]  {rng}  +{r['adds']}/-{r['dels']}\n"
            f"  [dim]model:[/] {r['model']}   [dim]agent:[/] {agent_lbl}   "
            f"[dim]session:[/] {r['session']}\n"
            f"  [yellow]>[/] {msg}"
        )
    panel(
        f"blame {target}",
        Text.from_markup("\n\n".join(blocks)),
        style="bright_blue",
        subtitle=f"{len(rows)} entries (newest first)",
    )
    return 0


# --------------------------------------------------------------------------
# Lessons-learned: capture corrections and distill into a prompt supplement
# that gets injected into joe-gemma's prompt on subsequent turns. Over time
# joe should drift toward Joe's actual preferences without retraining.
# --------------------------------------------------------------------------


def _lessdb() -> sqlite3.Connection:
    c = sqlite3.connect(str(LESSONS_DB))
    c.execute(
        "CREATE TABLE IF NOT EXISTS events ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " ts TEXT NOT NULL,"
        " source TEXT NOT NULL,"        # 'undo' | 'manual' | 'distillation'
        " session TEXT NOT NULL,"
        " model TEXT NOT NULL,"
        " agent TEXT NOT NULL,"
        " user_msg TEXT NOT NULL,"
        " rejected TEXT NOT NULL,"      # what joe did (path / op / preview)
        " note TEXT NOT NULL)"          # optional context / what user wanted instead
    )
    c.execute(
        "CREATE TABLE IF NOT EXISTS rules ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " ts TEXT NOT NULL,"
        " rule TEXT NOT NULL UNIQUE,"
        " status TEXT NOT NULL DEFAULT 'active',"
        " source_event_count INTEGER NOT NULL DEFAULT 0)"
    )
    return c


def lesson_capture(source: str, rejected: str, note: str = "") -> None:
    """Store a single correction event. Best-effort."""
    try:
        c = _lessdb()
        c.execute(
            "INSERT INTO events (ts, source, session, model, agent, user_msg,"
            " rejected, note) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
            (
                dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
                source,
                _TURN_CTX.get("session", ""),
                _TURN_CTX.get("model", ""),
                _TURN_CTX.get("agent", ""),
                _TURN_CTX.get("user_msg", "")[:2000],
                rejected[:2000],
                note[:2000],
            ),
        )
        c.commit(); c.close()
    except Exception:
        return


def lessons_active_rules() -> list[str]:
    try:
        c = _lessdb()
        rows = c.execute(
            "SELECT rule FROM rules WHERE status = 'active' ORDER BY id ASC"
        ).fetchall()
        c.close()
        return [r[0] for r in rows]
    except Exception:
        return []


def lessons_block() -> str:
    """Inject active lessons into _initial_prompt as a learned-preferences block."""
    rules = lessons_active_rules()
    if not rules and not PROMPT_SUPPLEMENT.is_file():
        return ""
    lines: list[str] = []
    if rules:
        lines.extend(f"- {r}" for r in rules)
    if PROMPT_SUPPLEMENT.is_file():
        sup = PROMPT_SUPPLEMENT.read_text(encoding="utf-8", errors="replace").strip()
        if sup:
            lines.append("")
            lines.append(sup)
    if not lines:
        return ""
    return (
        "<learned_preferences note=\"distilled from prior corrections; obey before defaults\">\n"
        + "\n".join(lines) + "\n</learned_preferences>"
    )


def lessons_distill(model: str) -> int:
    """Read recent (last 14 days) events, ask the model to distill rules,
    insert new ones into the rules table, return the count added."""
    c = _lessdb()
    cutoff = (dt.datetime.now(dt.UTC).replace(tzinfo=None) - dt.timedelta(days=14)).isoformat()
    events = c.execute(
        "SELECT source, user_msg, rejected, note FROM events"
        " WHERE ts > ? ORDER BY ts DESC LIMIT 60",
        (cutoff,),
    ).fetchall()
    existing = {r[0] for r in c.execute("SELECT rule FROM rules").fetchall()}
    c.close()
    if not events:
        return 0
    formatted = "\n\n".join(
        f"[{src}] user_asked: {um[:240]}\n"
        f"        joe_did:     {rej[:240]}\n"
        f"        note:        {note[:240]}"
        for src, um, rej, note in events
    )
    spec = (
        "These are corrections / undos / manual lessons from my recent work "
        "with joe. Distill them into a numbered list of short, imperative "
        "preference rules (one line each, under 100 chars). Each rule should "
        "be a concrete behaviour I want joe to apply NEXT time. Skip rules "
        "that are obvious (style I already follow), duplicates, or one-offs. "
        "Output ONLY the numbered list, no preamble. Maximum 10 rules.\n\n"
        f"<events>\n{formatted}\n</events>"
    )
    raw = _ollama_once(model, spec).strip()
    candidates: list[str] = []
    for ln in raw.splitlines():
        ln = ln.strip()
        ln = re.sub(r"^\d+[\.\)]\s*", "", ln)
        ln = re.sub(r"^[-*]\s*", "", ln)
        if 8 <= len(ln) <= 200:
            candidates.append(ln)
    if not candidates:
        return 0
    c = _lessdb()
    added = 0
    for cand in candidates:
        if cand in existing:
            continue
        try:
            c.execute(
                "INSERT INTO rules (ts, rule, source_event_count, status)"
                " VALUES (?, ?, ?, 'active')",
                (dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
                 cand, len(events)),
            )
            added += 1
        except sqlite3.IntegrityError:
            continue
    c.commit(); c.close()
    return added


# --------------------------------------------------------------------------
# Knowledge graph: extract (subject, relation, object) triples from each
# (user, assistant) pair into a SQLite graph DB. /ask traverses the graph
# plus runs joe-gemma over the matched neighborhood for a grounded answer.
# --------------------------------------------------------------------------


def _kgdb() -> sqlite3.Connection:
    c = sqlite3.connect(str(KNOWLEDGE_DB))
    c.execute(
        "CREATE TABLE IF NOT EXISTS triples ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " ts TEXT NOT NULL,"
        " subject TEXT NOT NULL,"
        " relation TEXT NOT NULL,"
        " object TEXT NOT NULL,"
        " session TEXT NOT NULL,"
        " confidence REAL NOT NULL DEFAULT 0.7)"
    )
    c.execute("CREATE INDEX IF NOT EXISTS idx_kg_subj ON triples(subject)")
    c.execute("CREATE INDEX IF NOT EXISTS idx_kg_obj ON triples(object)")
    return c


_KG_EXTRACT_PROMPT = (
    "Extract durable, non-trivial facts from this conversation as JSON-Lines. "
    "Each line is a single object with keys: subject, relation, object. "
    "Subjects + objects are short noun phrases (proper nouns when possible). "
    "Relations are short verbs / verb phrases. Capture things like: "
    "'<repo> uses <library>', '<person> is <role>', '<feature> launched on <date>', "
    "'<concept> means <definition>'. Skip greetings, shell commands, transient state, "
    "and anything model-specific (tool calls, internal protocol). "
    "If nothing is durable, output nothing. Limit to 8 facts. "
    "Output ONLY the JSON lines, no preamble.\n\n"
    "<conversation>\nUSER: {user}\nASSISTANT: {assistant}\n</conversation>"
)


def _extract_triples(model: str, user_msg: str, asst_msg: str) -> list[dict]:
    """Ask the model for triples. Returns [] on any failure."""
    prompt = _KG_EXTRACT_PROMPT.format(
        user=user_msg[:2000], assistant=asst_msg[:3000],
    )
    try:
        raw = _ollama_once(model, prompt, timeout=120).strip()
    except Exception:
        return []
    out: list[dict] = []
    for ln in raw.splitlines():
        ln = ln.strip().rstrip(",")
        if not ln or not ln.startswith("{"):
            continue
        try:
            obj = json.loads(ln)
        except json.JSONDecodeError:
            continue
        if not isinstance(obj, dict):
            continue
        s = (obj.get("subject") or "").strip()
        r = (obj.get("relation") or "").strip()
        o = (obj.get("object") or "").strip()
        if 2 <= len(s) <= 120 and 2 <= len(r) <= 80 and 2 <= len(o) <= 240:
            out.append({"subject": s, "relation": r, "object": o})
    return out[:8]


def kg_remember(session: str, model: str, user_msg: str, asst_msg: str) -> None:
    """Background-thread entrypoint: extract + store triples. Silent on fail."""
    triples = _extract_triples(model, user_msg, asst_msg)
    if not triples:
        return
    try:
        c = _kgdb()
        ts = dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat()
        for t in triples:
            c.execute(
                "INSERT INTO triples (ts, subject, relation, object, session)"
                " VALUES (?, ?, ?, ?, ?)",
                (ts, t["subject"], t["relation"], t["object"], session),
            )
        c.commit(); c.close()
    except Exception:
        return


def kg_neighborhood(query: str, k: int = 12) -> list[dict]:
    """Find triples whose subject or object overlaps with the query terms.

    First a simple LIKE pass; then for each hit, also pull 1-hop neighbors
    so the answer has connective tissue.
    """
    if not query.strip():
        return []
    terms = [t for t in re.findall(r"[A-Za-z0-9_-]{3,}", query) if t]
    if not terms:
        return []
    c = _kgdb()
    where = " OR ".join(["subject LIKE ?"] * len(terms) + ["object LIKE ?"] * len(terms))
    params = [f"%{t}%" for t in terms] * 2
    rows = c.execute(
        f"SELECT subject, relation, object, session, ts FROM triples"
        f" WHERE {where} ORDER BY ts DESC LIMIT ?",
        (*params, k),
    ).fetchall()
    seeds = [{"subject": s, "relation": r, "object": o, "session": ss, "ts": t}
             for s, r, o, ss, t in rows]
    # 1-hop expansion.
    seen = {(d["subject"], d["relation"], d["object"]) for d in seeds}
    extra: list[dict] = []
    for d in seeds:
        for node in (d["subject"], d["object"]):
            for s2, r2, o2, ss2, t2 in c.execute(
                "SELECT subject, relation, object, session, ts FROM triples"
                " WHERE subject = ? OR object = ? LIMIT 6",
                (node, node),
            ).fetchall():
                key = (s2, r2, o2)
                if key in seen:
                    continue
                seen.add(key)
                extra.append({"subject": s2, "relation": r2, "object": o2,
                              "session": ss2, "ts": t2})
    c.close()
    return seeds + extra[:k]


def cmd_ask(query: str, model: str) -> int:
    triples = kg_neighborhood(query, k=15)
    if not triples:
        console.print(
            "[dim](knowledge graph empty for that query; have you had any "
            "conversations on this topic yet?)[/]"
        )
        return 0
    formatted = "\n".join(
        f"- {t['subject']}  --[{t['relation']}]-->  {t['object']}"
        f"  [from session {t['session']} on {t['ts'][:10]}]"
        for t in triples
    )
    spec = (
        "Use these facts from my knowledge graph to answer the question. "
        "Cite the session where each fact came from. If the facts don't "
        "cover the answer, say so and recommend asking joe directly.\n\n"
        f"<facts>\n{formatted}\n</facts>\n\n"
        f"<question>{query}</question>"
    )
    out = _ollama_once(model, spec).strip()
    panel(
        f"ask: {query}",
        Markdown(out),
        style="bright_blue",
        subtitle=f"grounded in {len(triples)} graph triples",
    )
    return 0


# --------------------------------------------------------------------------
# Smart inbox: aggregate things that need your attention across gh + local
# state (review requests, mentions, failing CI, pending tasks, recent ntfy).
# --------------------------------------------------------------------------


def _gh_json(args: list[str], timeout: int = 12) -> list[dict]:
    try:
        cp = subprocess.run(
            ["gh", *args], capture_output=True, text=True, timeout=timeout,
        )
        if cp.returncode != 0:
            return []
        out = cp.stdout.strip()
        if not out:
            return []
        return json.loads(out)
    except Exception:
        return []


def cmd_inbox() -> int:
    if not shutil.which("gh"):
        console.print("[red]gh CLI not on PATH (brew install gh)[/]")
        return 1
    items: list[tuple[str, str, str]] = []  # (priority, label, body)

    # PRs requesting review from me.
    revs = _gh_json([
        "search", "prs", "--state", "open",
        "--review-requested", "@me", "--limit", "10",
        "--json", "number,title,repository,url",
    ])
    for r in revs:
        repo = r.get("repository", {}).get("nameWithOwner", "")
        items.append((
            "P0",
            f"review-requested #{r.get('number')} in {repo}",
            f"{r.get('title', '')[:100]}\n  {r.get('url', '')}",
        ))
    # Issues / PRs mentioning me.
    mentions = _gh_json([
        "search", "issues", "--mentions", "@me",
        "--state", "open", "--limit", "10",
        "--json", "number,title,repository,url,isPullRequest",
    ])
    for m in mentions:
        repo = m.get("repository", {}).get("nameWithOwner", "")
        kind = "pr" if m.get("isPullRequest") else "issue"
        items.append((
            "P1",
            f"mention in {kind} #{m.get('number')} ({repo})",
            f"{m.get('title', '')[:100]}\n  {m.get('url', '')}",
        ))
    # Failing CI runs on active repos.
    for repo in _active_repos():
        if not (repo / ".git").exists():
            continue
        runs = _gh_json(
            ["run", "list", "-R", str(repo), "--limit", "3",
             "--status", "failure",
             "--json", "name,databaseId,displayTitle,headBranch,url,conclusion"],
        )
        for r in runs[:2]:
            items.append((
                "P0",
                f"failing CI: {r.get('name', '')} on {repo.name}",
                f"{r.get('displayTitle', '')[:100]}  ({r.get('headBranch', '')})\n  {r.get('url', '')}",
            ))
    # Local pending background tasks.
    running = [d for d in task_list() if d.get("status") == "running"]
    if running:
        items.append((
            "P2",
            f"{len(running)} background task(s) running",
            "\n".join(f"#{d['id']}  {d['cmd'][:80]}" for d in running[:5]),
        ))
    # Recent lessons / supplement growth.
    if PROMPT_SUPPLEMENT.is_file():
        mtime = dt.datetime.fromtimestamp(PROMPT_SUPPLEMENT.stat().st_mtime)
        age = dt.datetime.now() - mtime
        if age < dt.timedelta(days=2):
            items.append((
                "P3",
                f"prompt supplement updated {int(age.total_seconds() / 3600)}h ago",
                str(PROMPT_SUPPLEMENT),
            ))

    if not items:
        panel("Inbox", "(nothing to attend to)", style="green")
        return 0
    items.sort(key=lambda x: x[0])
    pri_color = {"P0": "red", "P1": "yellow", "P2": "cyan", "P3": "dim"}
    lines = []
    for pri, label, body in items:
        col = pri_color.get(pri, "white")
        lines.append(f"[{col}]{pri}[/]  [bold]{label}[/]\n     {body}")
    panel(
        f"Inbox ({len(items)} items)",
        Text.from_markup("\n\n".join(lines)),
        style="bright_blue",
        subtitle="gh PRs / mentions / failing CI / local tasks",
    )
    return 0


# --------------------------------------------------------------------------
# End-of-day reflection: writes 2-3 paragraphs into developer-journal.md.
# --------------------------------------------------------------------------


def cmd_reflect(model: str) -> int:
    today = dt.date.today().isoformat()
    pieces: list[str] = []
    # Commits today across active repos.
    for r in _active_repos():
        if not (r / ".git").exists():
            continue
        cp = subprocess.run(
            ["git", "-C", str(r), "log", "--since=24.hours",
             "--pretty=format:%h  %s  (%an)", "--no-merges"],
            capture_output=True, text=True, timeout=8,
        )
        if cp.returncode == 0 and cp.stdout.strip():
            pieces.append(f"# commits in {r.name}\n{cp.stdout.strip()}")
    # Today's journal.
    journal_path = JOURNAL_DIR / f"{today}.md"
    if journal_path.is_file():
        pieces.append(f"# today's journal\n{journal_path.read_text()}")
    # Lessons captured today.
    try:
        c = _lessdb()
        cutoff = (dt.datetime.now(dt.UTC).replace(tzinfo=None)
                  - dt.timedelta(hours=24)).isoformat()
        events = c.execute(
            "SELECT source, user_msg, rejected FROM events"
            " WHERE ts > ? ORDER BY ts DESC", (cutoff,),
        ).fetchall()
        c.close()
        if events:
            pieces.append(
                "# corrections today\n"
                + "\n".join(f"- [{s}] asked: {u[:120]}  -- rejected: {r[:120]}"
                            for s, u, r in events)
            )
    except Exception:
        pass
    # Counts of writes/edits today.
    try:
        c = _provdb()
        cutoff = (dt.datetime.now(dt.UTC).replace(tzinfo=None)
                  - dt.timedelta(hours=24)).isoformat()
        n_writes = c.execute(
            "SELECT COUNT(*) FROM provenance WHERE ts > ? AND op = 'write'",
            (cutoff,),
        ).fetchone()[0]
        n_edits = c.execute(
            "SELECT COUNT(*) FROM provenance WHERE ts > ? AND op = 'edit'",
            (cutoff,),
        ).fetchone()[0]
        c.close()
        pieces.append(f"# joe activity today\nwrites: {n_writes}  edits: {n_edits}")
    except Exception:
        pass

    if not pieces:
        console.print("[dim](nothing happened today that joe can see)[/]")
        return 0
    payload = "\n\n".join(pieces)
    spec = (
        "Write a short developer-journal reflection (2-3 short paragraphs, "
        "under 250 words) about today's work using the inputs below. "
        "First-person, plain prose. Focus on: what got done, what stuck, "
        "what to think about overnight, what to attempt tomorrow. Skip the "
        "obvious recap of commits; pull through what they MEAN. No emojis, "
        "no em-dashes as separators.\n\n"
        f"<inputs>\n{payload[:12000]}\n</inputs>"
    )
    text = _ollama_once(model, spec).strip()
    DEVELOPER_JOURNAL.parent.mkdir(parents=True, exist_ok=True)
    header = f"\n\n## {today}\n\n"
    with DEVELOPER_JOURNAL.open("a", encoding="utf-8") as f:
        f.write(header + text + "\n")
    panel(
        f"Reflection for {today}",
        Markdown(text),
        style="bright_blue",
        subtitle=f"appended to {DEVELOPER_JOURNAL}",
    )
    return 0


# --------------------------------------------------------------------------
# Cross-machine sync: ~/.joe-agent as a private git repo.
# --------------------------------------------------------------------------


_SYNC_GITIGNORE = """\
# joe sync: skip large + ephemeral state. Edit if you actually want these.
# What stays in the synced repo: sessions, lessons, agents, profiles,
# macros, knowledge graph, journals, prompt supplement, the active-model
# marker. Everything else is either regenerable or local-only.

# large blob caches (content-addressed; regenerable from session log)
edits/

# ephemeral, machine-local
tasks/
voice/
pastes/
input-history
http-token
*.log

# heavy or regenerable derived state
training-data/
snaps/
exports/
history-index.sqlite
provenance.sqlite
evals.sqlite
vector-index.sqlite
knowledge-index.sqlite
*-index.sqlite

# transient sqlite write-ahead artefacts
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# legacy / not-yet-used
.DS_Store

# encryption key material (always private, never sync)
sync-age.key
"""

# When --encrypt is on, the *plain* versions of these files stay local
# (gitignored) and only the .age ciphertext lands in the synced repo.
_ENCRYPTED_FILES = (
    "joe-sessions.sqlite",
    "lessons.sqlite",
    "knowledge.sqlite",
    "prompt-supplement.md",
)


def _age_available() -> bool:
    return shutil.which("age") is not None and shutil.which("age-keygen") is not None


def _age_keyfile() -> Path:
    return STATE_DIR / "sync-age.key"


def _age_pubkey() -> Optional[str]:
    key = _age_keyfile()
    if not key.is_file():
        return None
    try:
        cp = subprocess.run(
            ["age-keygen", "-y", str(key)],
            capture_output=True, text=True, timeout=5,
        )
        if cp.returncode == 0:
            return cp.stdout.strip()
    except Exception:
        return None
    return None


def _sync_encrypt(plain_files: tuple[str, ...]) -> int:
    """Encrypt each named file in STATE_DIR to <name>.age in-place."""
    pub = _age_pubkey()
    if not pub:
        console.print(
            "[red]no age key found; run [bold]joe sync encrypt-init[/] first[/]"
        )
        return 1
    n = 0
    for name in plain_files:
        src = STATE_DIR / name
        if not src.is_file():
            continue
        dst = src.with_suffix(src.suffix + ".age")
        cp = subprocess.run(
            ["age", "-r", pub, "-o", str(dst), str(src)],
            capture_output=True, text=True,
        )
        if cp.returncode == 0:
            n += 1
        else:
            console.print(f"[red]encrypt failed for {name}: {cp.stderr.strip()}[/]")
    console.print(f"[dim]encrypted {n} file(s) -> *.age[/]")
    return 0


def _sync_decrypt() -> int:
    key = _age_keyfile()
    if not key.is_file():
        console.print(
            "[red]no age key at {0}; copy it from your other machine first[/]"
            .format(key)
        )
        return 1
    n = 0
    for age_path in STATE_DIR.glob("*.age"):
        # Strip .age suffix.
        plain = age_path.with_suffix("")
        cp = subprocess.run(
            ["age", "-d", "-i", str(key), "-o", str(plain), str(age_path)],
            capture_output=True, text=True,
        )
        if cp.returncode == 0:
            n += 1
        else:
            console.print(f"[red]decrypt failed for {age_path.name}: {cp.stderr.strip()}[/]")
    console.print(f"[dim]decrypted {n} file(s)[/]")
    return 0


def cmd_sync(args: list[str]) -> int:
    if not args:
        console.print(
            "[dim]joe sync init <git-url> | push [--encrypt] | "
            "pull [--encrypt] | status | encrypt-init[/]"
        )
        return 1
    sub = args[0]
    encrypt = "--encrypt" in args
    args = [a for a in args if a != "--encrypt"]
    sub = args[0]  # in case --encrypt was first
    if sub == "encrypt-init":
        if not _age_available():
            console.print(
                "[red]`age` and `age-keygen` not on PATH.[/] install with:\n"
                "  brew install age  (macOS)\n"
                "  apt install age   (Debian/Ubuntu)\n"
                "then re-run [bold]joe sync encrypt-init[/]"
            )
            return 1
        key = _age_keyfile()
        if key.exists():
            console.print(f"[yellow]key already exists at {key}[/]")
        else:
            cp = subprocess.run(
                ["age-keygen", "-o", str(key)],
                capture_output=True, text=True,
            )
            if cp.returncode != 0:
                console.print(f"[red]age-keygen failed: {cp.stderr.strip()}[/]")
                return 1
            key.chmod(0o600)
        pub = _age_pubkey() or "(unknown)"
        panel(
            "joe sync encrypt-init",
            Text.from_markup(
                f"[bold]key file:[/]    {key}  [dim](600, never sync this)[/]\n"
                f"[bold]public key:[/]  {pub}\n\n"
                "[dim]on your other machine, copy sync-age.key into\n"
                f"~/.joe-agent/ before running [bold]joe sync pull --encrypt[/]\n"
                "(the gitignore excludes it from the sync repo)[/]"
            ),
            style="green",
        )
        return 0
    git = shutil.which("git")
    if not git:
        console.print("[red]git not on PATH[/]"); return 1
    state_git = STATE_DIR / ".git"
    if sub == "init":
        if len(args) < 2:
            console.print("[red]joe sync init <git-url>[/]"); return 1
        remote = args[1]
        if state_git.exists():
            console.print("[yellow]already a git repo; setting remote 'origin'[/]")
        else:
            subprocess.run([git, "init", "-q", "-b", "main", str(STATE_DIR)],
                           check=False)
        (STATE_DIR / ".gitignore").write_text(_SYNC_GITIGNORE)
        subprocess.run([git, "-C", str(STATE_DIR), "remote", "remove", "origin"],
                       capture_output=True)
        subprocess.run([git, "-C", str(STATE_DIR), "remote", "add", "origin", remote],
                       check=False)
        subprocess.run([git, "-C", str(STATE_DIR), "add", "-A"], check=False)
        subprocess.run(
            [git, "-C", str(STATE_DIR), "commit", "-m", "joe sync: init"],
            check=False, capture_output=True,
        )
        panel(
            "joe sync init",
            Text.from_markup(
                f"[bold]state dir:[/] {STATE_DIR}\n"
                f"[bold]remote:[/]    {remote}\n\n"
                "[dim]next: run [bold]joe sync push[/] to publish, "
                "then [bold]joe sync pull[/] on your other machine.[/]"
            ),
            style="green",
        )
        return 0
    if not state_git.exists():
        console.print("[red]not initialised; run `joe sync init <url>` first[/]")
        return 1
    if sub == "status":
        subprocess.run([git, "-C", str(STATE_DIR), "status", "-sb"])
        subprocess.run([git, "-C", str(STATE_DIR), "log", "--oneline", "-5"])
        return 0
    if sub == "push":
        if encrypt:
            # On encrypt mode, also add plain sensitive files to gitignore
            # (idempotent) so only the .age ciphertext lands in the repo.
            gi = STATE_DIR / ".gitignore"
            existing = gi.read_text() if gi.is_file() else ""
            extras = [f for f in _ENCRYPTED_FILES if f not in existing]
            if extras:
                with gi.open("a") as f:
                    f.write("\n# joe sync --encrypt: keep plain files local\n")
                    for f_name in extras:
                        f.write(f"{f_name}\n")
            rc = _sync_encrypt(_ENCRYPTED_FILES)
            if rc != 0:
                return rc
        subprocess.run([git, "-C", str(STATE_DIR), "add", "-A"], check=False)
        msg = f"joe sync: {dt.datetime.now().isoformat(timespec='seconds')}"
        if encrypt:
            msg += " (encrypted)"
        cp = subprocess.run(
            [git, "-C", str(STATE_DIR), "commit", "-m", msg],
            capture_output=True, text=True,
        )
        if "nothing to commit" in (cp.stdout + cp.stderr):
            console.print("[dim](nothing to sync)[/]")
        cp = subprocess.run(
            [git, "-C", str(STATE_DIR), "push", "-u", "origin", "main"],
            capture_output=True, text=True,
        )
        if cp.returncode == 0:
            console.print(f"[green]pushed[/]")
        else:
            console.print(f"[red]push failed:[/] {cp.stderr.strip()}")
            return 1
        return 0
    if sub == "pull":
        cp = subprocess.run(
            [git, "-C", str(STATE_DIR), "pull", "--rebase", "origin", "main"],
            capture_output=True, text=True,
        )
        out = (cp.stdout + "\n" + cp.stderr).strip()
        panel("joe sync pull",
              Text(out or "(no output)"),
              style="green" if cp.returncode == 0 else "red")
        if cp.returncode != 0:
            return cp.returncode
        if encrypt:
            _sync_decrypt()
        return 0
    console.print(f"[red]unknown sync sub: {sub}[/]")
    return 1


# --------------------------------------------------------------------------
# Self-eval: reruns past prompts whose answers you accepted, scores drift.
# --------------------------------------------------------------------------


def _evaldb() -> sqlite3.Connection:
    c = sqlite3.connect(str(EVALS_DB))
    c.execute(
        "CREATE TABLE IF NOT EXISTS eval_set ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " ts_built TEXT NOT NULL,"
        " session TEXT NOT NULL,"
        " user_msg TEXT NOT NULL,"
        " gold_asst TEXT NOT NULL,"
        " gold_embed BLOB)"
    )
    c.execute(
        "CREATE TABLE IF NOT EXISTS results ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " ts TEXT NOT NULL,"
        " eval_id INTEGER NOT NULL,"
        " model TEXT NOT NULL,"
        " answer TEXT NOT NULL,"
        " score REAL NOT NULL)"
    )
    return c


def cmd_eval(args: list[str], default_model: str) -> int:
    if not args:
        console.print("[dim]joe eval build | run [model] | report | add <user> <gold>[/]")
        return 1
    sub = args[0]
    if sub == "add":
        # Manual benchmark entry. Usage: joe eval add "user prompt" "gold answer"
        if len(args) < 3:
            console.print(
                "[red]usage: joe eval add \"<user prompt>\" \"<gold answer>\"[/]"
            )
            return 1
        user_msg, gold = args[1], args[2]
        if len(user_msg) < 5 or len(gold) < 5:
            console.print("[red]prompt and gold each need >= 5 chars[/]"); return 1
        vec = _embed(gold[:EMBED_INPUT_MAX_CHARS])
        if not vec:
            console.print("[red]embedding failed (is nomic-embed-text installed?)[/]")
            return 1
        c = _evaldb()
        ts = dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat()
        c.execute(
            "INSERT INTO eval_set (ts_built, session, user_msg, gold_asst, gold_embed)"
            " VALUES (?, ?, ?, ?, ?)",
            (ts, "manual", user_msg, gold, _pack_vec(vec)),
        )
        total = c.execute("SELECT COUNT(*) FROM eval_set").fetchone()[0]
        c.commit(); c.close()
        console.print(f"[green]added[/] (eval set is now {total} entries)")
        return 0
    if sub == "build":
        limit = int(args[1]) if len(args) > 1 and args[1].isdigit() else 40
        c = _db()
        # Pull recent (user, assistant) pairs where the assistant turn is
        # at least 50 chars and the user turn is not a single command.
        rows = c.execute(
            "SELECT session, ts, role, content FROM turns ORDER BY ts DESC LIMIT 1000"
        ).fetchall()
        c.close()
        pairs: list[tuple[str, str, str]] = []
        for i in range(len(rows) - 1):
            ses_u, ts_u, r_u, c_u = rows[i + 1]
            ses_a, ts_a, r_a, c_a = rows[i]
            if r_u == "user" and r_a == "assistant" and ses_u == ses_a:
                if len(c_u) > 20 and len(c_a) > 50 and not c_u.startswith("/"):
                    pairs.append((ses_u, c_u, c_a))
        pairs = pairs[:limit]
        if not pairs:
            console.print("[red]no usable (user, assistant) pairs found[/]")
            return 1
        c = _evaldb()
        c.execute("DELETE FROM eval_set")
        ts = dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat()
        added = 0
        for sess, um, am in pairs:
            vec = _embed(am[:EMBED_INPUT_MAX_CHARS])
            if not vec:
                continue
            c.execute(
                "INSERT INTO eval_set (ts_built, session, user_msg, gold_asst, gold_embed)"
                " VALUES (?, ?, ?, ?, ?)",
                (ts, sess, um, am, _pack_vec(vec)),
            )
            added += 1
        c.commit(); c.close()
        console.print(f"[green]eval set built[/]: {added} entries")
        return 0
    if sub == "run":
        auto_promote = "--auto-promote" in args
        args_no_flags = [a for a in args if a != "--auto-promote"]
        model = args_no_flags[1] if len(args_no_flags) > 1 else default_model
        c = _evaldb()
        items = c.execute(
            "SELECT id, user_msg, gold_embed FROM eval_set"
        ).fetchall()
        c.close()
        if not items:
            console.print("[red]eval set empty; run `joe eval build` first[/]")
            return 1
        ts = dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat()
        scores: list[float] = []
        c = _evaldb()
        for eid, um, ge in items:
            try:
                ans = _ollama_once(model, um, timeout=120).strip()
            except Exception:
                ans = ""
            if not ans:
                continue
            v = _embed(ans[:EMBED_INPUT_MAX_CHARS])
            if not v:
                continue
            sim = _cosine(v, _unpack_vec(ge))
            scores.append(sim)
            c.execute(
                "INSERT INTO results (ts, eval_id, model, answer, score)"
                " VALUES (?, ?, ?, ?, ?)",
                (ts, eid, model, ans[:8000], sim),
            )
        c.commit(); c.close()
        if not scores:
            console.print("[red]eval run produced no scores[/]")
            return 1
        avg = sum(scores) / len(scores)
        console.print(
            f"[green]eval done[/]  model={model}  n={len(scores)}  "
            f"avg_similarity={avg:.3f}"
        )
        # Auto-promotion: compare to the most-recent eval of any other model.
        if auto_promote:
            threshold = float(os.environ.get("JOE_PROMOTE_THRESHOLD", "0.02"))
            c = _evaldb()
            rivals = c.execute(
                "SELECT model, AVG(score), MAX(ts) AS last_ts"
                " FROM results WHERE model != ? AND ts != ?"
                " GROUP BY model ORDER BY last_ts DESC LIMIT 5",
                (model, ts),
            ).fetchall()
            c.close()
            beaten: list[tuple[str, float]] = [
                (m, avg - a) for m, a, _ in rivals if (avg - a) >= threshold
            ]
            current = os.environ.get("JOE_DEFAULT_MODEL", default_model)
            if beaten and model != current:
                marker = STATE_DIR / "active-model"
                marker.write_text(model)
                deltas = ", ".join(f"{m} (+{d:.3f})" for m, d in beaten)
                panel(
                    "model promoted",
                    Text.from_markup(
                        f"[bold green]new active model:[/] {model}\n"
                        f"[bold]beats:[/]              {deltas}\n"
                        f"[bold]marker:[/]             {marker}\n\n"
                        f"[dim]flip your shell default to make it stick:\n"
                        f"  echo 'export JOE_DEFAULT_MODEL={model}' >> ~/.zshrc[/]"
                    ),
                    style="green",
                    subtitle=f"threshold +{threshold:.2f}",
                )
            elif auto_promote:
                console.print(
                    f"[dim](auto-promote: {model} did not beat current "
                    f"default by >= {threshold:.2f})[/]"
                )
        return 0
    if sub == "report":
        c = _evaldb()
        runs = c.execute(
            "SELECT ts, model, COUNT(*) as n, AVG(score) as avg"
            " FROM results GROUP BY ts, model ORDER BY ts DESC LIMIT 20"
        ).fetchall()
        c.close()
        if not runs:
            console.print("[dim](no eval runs yet)[/]"); return 0
        lines = []
        prev: dict[str, float] = {}
        for ts, model, n, avg in runs:
            delta = ""
            if model in prev:
                d = avg - prev[model]
                if abs(d) > 0.005:
                    sign = "+" if d > 0 else ""
                    color = "green" if d > 0 else "red"
                    delta = f"  [{color}]{sign}{d:.3f}[/]"
            prev[model] = avg
            lines.append(
                f"[bold]{ts[:19]}[/]  {model:<24}  n={n:<3}  avg={avg:.3f}{delta}"
            )
        panel("Eval report (newer first)", Text.from_markup("\n".join(lines)),
              style="cyan",
              subtitle="positive deltas = improvement vs previous run")
        return 0
    console.print(f"[red]unknown eval sub: {sub}[/]")
    return 1


# --------------------------------------------------------------------------
# Self-training: collect data + rebuild ollama Modelfile (or hand off to
# mlx-lm if installed for real LoRA).
# --------------------------------------------------------------------------


def cmd_train(args: list[str], default_model: str) -> int:
    if not args:
        console.print("[dim]joe train collect | modelfile [version] | lora | activate <tag>[/]")
        return 1
    sub = args[0]
    if sub == "collect":
        # Walk sessions, dump (user, assistant) pairs that look like positive
        # examples (no immediate /undo after). Output as chat-format JSONL.
        c = _db()
        rows = c.execute(
            "SELECT session, ts, role, content FROM turns ORDER BY ts ASC"
        ).fetchall()
        c.close()
        # Find session+approx-timestamps of undo events to skip those exchanges.
        undo_keys = set()
        try:
            le = _lessdb()
            for ts, sess in le.execute(
                "SELECT ts, session FROM events WHERE source = 'undo'"
            ).fetchall():
                undo_keys.add((sess, ts[:13]))  # match by session + hour
            le.close()
        except Exception:
            pass
        ts_str = dt.datetime.now(dt.UTC).replace(tzinfo=None).strftime("%Y%m%d-%H%M%S")
        out_path = TRAINING_DATA_DIR / f"jsonl-{ts_str}.jsonl"
        n = 0
        with out_path.open("w") as f:
            for i in range(len(rows) - 1):
                s1, t1, r1, c1 = rows[i]
                s2, t2, r2, c2 = rows[i + 1]
                if s1 != s2 or r1 != "user" or r2 != "assistant":
                    continue
                if len(c1) < 20 or len(c2) < 50:
                    continue
                if (s1, t2[:13]) in undo_keys:
                    continue
                record = {
                    "messages": [
                        {"role": "user", "content": c1},
                        {"role": "assistant", "content": c2},
                    ],
                }
                f.write(json.dumps(record) + "\n")
                n += 1
        # Also dump active lessons as few-shot "system rules" file.
        rules = lessons_active_rules()
        rules_path = TRAINING_DATA_DIR / f"rules-{ts_str}.txt"
        rules_path.write_text("\n".join(rules))
        panel(
            "joe train collect",
            Text.from_markup(
                f"[bold]JSONL pairs:[/]  {n}  ({out_path})\n"
                f"[bold]rules:[/]        {len(rules)}  ({rules_path})\n\n"
                f"[dim]next: `joe train modelfile` (fast, ollama-only)\n"
                f"     or `joe train lora` (real fine-tune via mlx-lm)[/]"
            ),
            style="green",
        )
        return 0
    if sub == "modelfile":
        version = args[1] if len(args) > 1 else dt.date.today().strftime("v%Y%m%d")
        new_tag = f"joe-gemma:{version}"
        # Build a Modelfile that bakes in active lessons + a few high-similarity
        # MESSAGE examples drawn from recent training data.
        latest_jsonl = sorted(TRAINING_DATA_DIR.glob("jsonl-*.jsonl"))
        sample_msgs: list[tuple[str, str]] = []
        if latest_jsonl:
            for ln in latest_jsonl[-1].read_text().splitlines()[-25:]:
                try:
                    rec = json.loads(ln)
                except json.JSONDecodeError:
                    continue
                msgs = rec.get("messages") or []
                if (len(msgs) >= 2 and msgs[0]["role"] == "user"
                        and msgs[1]["role"] == "assistant"):
                    u = msgs[0]["content"][:800]
                    a = msgs[1]["content"][:1200]
                    sample_msgs.append((u, a))
        sample_msgs = sample_msgs[-8:]  # cap
        rules = lessons_active_rules()
        rules_block = ""
        if rules:
            rules_block = (
                "Learned preferences (obey before defaults):\n"
                + "\n".join(f"  - {r}" for r in rules)
                + "\n\n"
            )
        # Pull the original joe-gemma Modelfile so we extend rather than replace.
        cp = subprocess.run(["ollama", "show", "--modelfile", "joe-gemma"],
                            capture_output=True, text=True, timeout=10)
        base = cp.stdout if cp.returncode == 0 else "FROM gemma3:4b\n"
        # Strip ollama's auto-prepended FROM digest header so we end up with a
        # clean Modelfile.
        base_lines = [ln for ln in base.splitlines()
                      if not ln.startswith("# Modelfile generated")
                      and not ln.startswith("# To build")]
        base = "\n".join(base_lines).strip()
        modelfile_path = TRAINING_DATA_DIR / f"Modelfile.{version}"
        with modelfile_path.open("w") as f:
            f.write(base + "\n\n")
            if rules_block:
                # Append a sub-system note that gets concatenated to the base.
                f.write("SYSTEM \"\"\"" + "\n")
                f.write(rules_block.strip() + "\n")
                f.write("\"\"\"\n\n")
            for u, a in sample_msgs:
                u_esc = u.replace("\"", "\\\"")
                a_esc = a.replace("\"", "\\\"")
                f.write(f"MESSAGE user \"{u_esc}\"\n")
                f.write(f"MESSAGE assistant \"{a_esc}\"\n\n")
        # Build it.
        cp = subprocess.run(
            ["ollama", "create", new_tag, "-f", str(modelfile_path)],
            capture_output=True, text=True, timeout=300,
        )
        if cp.returncode != 0:
            panel(
                "joe train modelfile (failed)",
                Text((cp.stdout + "\n" + cp.stderr).strip()),
                style="red", subtitle=str(modelfile_path),
            )
            return 1
        panel(
            "joe train modelfile (built)",
            Text.from_markup(
                f"[bold]new model:[/] {new_tag}\n"
                f"[bold]examples:[/]  {len(sample_msgs)}  baked-in\n"
                f"[bold]rules:[/]     {len(rules)}  in system prompt\n\n"
                f"[dim]activate with: joe train activate {version}[/]"
            ),
            style="green",
            subtitle=str(modelfile_path),
        )
        return 0
    if sub == "lora":
        mlx = shutil.which("mlx_lm.lora") or shutil.which("mlx-lm")
        latest_jsonl = sorted(TRAINING_DATA_DIR.glob("jsonl-*.jsonl"))
        if not mlx:
            panel(
                "joe train lora",
                Text.from_markup(
                    "[red]mlx-lm not installed[/]\n\n"
                    "install with:\n"
                    "  pip install --user mlx-lm\n\n"
                    "then re-run [bold]joe train lora[/]; this routes through:\n"
                    "  mlx_lm.lora --model gemma3:4b --data "
                    f"{latest_jsonl[-1] if latest_jsonl else '<jsonl>'} "
                    "--train --iters 200\n\n"
                    "or just use [bold]joe train modelfile[/] for the lighter, "
                    "ollama-only path."
                ),
                style="yellow",
            )
            return 1
        if not latest_jsonl:
            console.print("[red]no training data; run `joe train collect` first[/]")
            return 1
        cmd = [
            mlx, "--model", "mlx-community/gemma-3-4b-it-4bit",
            "--train", "--data", str(latest_jsonl[-1].parent),
            "--iters", "200",
            "--adapter-path", str(TRAINING_DATA_DIR / "adapter"),
        ]
        panel("joe train lora (spawning)", Syntax(" ".join(cmd), "bash",
              theme="ansi_dark"), style="cyan")
        # Spawn as a background joe-task so progress is captured + ntfy fires.
        data = task_spawn(" ".join(shlex.quote(x) for x in cmd), Path.cwd(),
                          label="joe-train-lora")
        console.print(
            f"[green]LoRA run started as task[/] #{data['id']}; "
            f"watch with /task {data['id']}"
        )
        return 0
    if sub == "activate":
        if len(args) < 2:
            console.print("[red]joe train activate <version-tag>[/]"); return 1
        tag = f"joe-gemma:{args[1]}"
        cp = subprocess.run(["ollama", "list"], capture_output=True, text=True)
        if tag.split(":")[0] not in cp.stdout or args[1] not in cp.stdout:
            console.print(f"[red]model {tag} not found in ollama; build it first[/]")
            return 1
        # We can't safely edit the user's shell env from here, so just write
        # a hint into a known file and tell the user how to flip the default.
        marker = STATE_DIR / "active-model"
        marker.write_text(tag)
        panel(
            "joe train activate",
            Text.from_markup(
                f"[bold]active model marker:[/] {marker}\n"
                f"[bold]tag:[/]                  {tag}\n\n"
                "[dim]joe doesn't auto-swap models; pass [bold]--model "
                f"{tag}[/] or set [bold]JOE_DEFAULT_MODEL={tag}[/] in your "
                "zshrc and re-source.[/]"
            ),
            style="green",
        )
        return 0
    console.print(f"[red]unknown train sub: {sub}[/]")
    return 1


# --------------------------------------------------------------------------
# MCP client (joe-as-client). Connects to external MCP servers configured
# in ~/.joe-agent/mcp-clients.json so the orchestrator can invoke tools
# from them via the <mcp server="..." tool="..."> tag. The MCP SDK is
# async-only, so each connection runs its own event loop in a background
# thread; we expose synchronous `call` / `list_tools` that block on the
# loop via `asyncio.run_coroutine_threadsafe`.
# --------------------------------------------------------------------------

# Lazy import: only resolved when the user actually configures MCP clients,
# so users without the mcp SDK never pay the import cost.
_MCP_AVAILABLE: Optional[bool] = None


def _mcp_check_available() -> bool:
    global _MCP_AVAILABLE
    if _MCP_AVAILABLE is not None:
        return _MCP_AVAILABLE
    try:
        import asyncio  # noqa: F401
        import mcp  # noqa: F401
        from mcp import ClientSession  # noqa: F401
        from mcp.client.stdio import stdio_client  # noqa: F401
        _MCP_AVAILABLE = True
    except ImportError:
        _MCP_AVAILABLE = False
    return _MCP_AVAILABLE


class MCPClient:
    """One connection to an external MCP server, wrapping the async SDK.

    Spawns the server process (stdio) and keeps an asyncio loop alive in a
    background thread. Sync methods schedule coroutines onto that loop via
    run_coroutine_threadsafe so the rest of joe stays single-threaded.
    """

    def __init__(self, config: dict) -> None:
        self.name = config["name"]
        self.config = config
        self.tools: list = []           # raw mcp Tool objects
        self.tool_names: list[str] = []
        self.connected = False
        self._loop = None
        self._thread: Optional[threading.Thread] = None
        self._session = None
        self._stack = None
        self._connect_error: str = ""

    def start(self) -> bool:
        """Spin up the background loop + connect. Returns True on success."""
        import asyncio
        self._loop = asyncio.new_event_loop()
        self._thread = threading.Thread(
            target=self._loop.run_forever, daemon=True,
        )
        self._thread.start()
        fut = asyncio.run_coroutine_threadsafe(self._connect(), self._loop)
        try:
            ok = fut.result(timeout=20)
        except Exception as e:
            self._connect_error = str(e)
            ok = False
        self.connected = ok
        return ok

    async def _connect(self) -> bool:
        from contextlib import AsyncExitStack
        from mcp import ClientSession
        from mcp.client.stdio import StdioServerParameters, stdio_client
        try:
            transport = self.config.get("transport", "stdio")
            self._stack = AsyncExitStack()
            await self._stack.__aenter__()
            if transport == "stdio":
                params = StdioServerParameters(
                    command=self.config["command"],
                    args=self.config.get("args", []),
                    env=self.config.get("env"),
                )
                (read, write) = await self._stack.enter_async_context(
                    stdio_client(params),
                )
            else:
                self._connect_error = f"unsupported transport: {transport}"
                return False
            self._session = await self._stack.enter_async_context(
                ClientSession(read, write),
            )
            await self._session.initialize()
            tools_result = await self._session.list_tools()
            self.tools = list(tools_result.tools)
            self.tool_names = [t.name for t in self.tools]
            return True
        except Exception as e:
            self._connect_error = str(e)
            return False

    def call(self, tool: str, args: dict, timeout: float = 120) -> str:
        """Block-and-return the tool's text content, or 'ERROR: ...'."""
        if not self.connected or self._session is None:
            return f"ERROR: {self.name} not connected ({self._connect_error})"
        import asyncio
        fut = asyncio.run_coroutine_threadsafe(
            self._call(tool, args), self._loop,
        )
        try:
            return fut.result(timeout=timeout)
        except Exception as e:
            return f"ERROR: {e}"

    async def _call(self, tool: str, args: dict) -> str:
        try:
            result = await self._session.call_tool(tool, args)
        except Exception as e:
            return f"ERROR: {e}"
        # result.content is list[TextContent | ImageContent | EmbeddedResource]
        parts: list[str] = []
        for c in getattr(result, "content", []) or []:
            text = getattr(c, "text", None)
            if text:
                parts.append(text)
        if not parts:
            return "(no content returned)"
        return "\n".join(parts)


# Module-level registry of connected clients, keyed by server name.
_MCP_CLIENTS: dict[str, MCPClient] = {}


def _mcp_load_config() -> list[dict]:
    if not MCP_CLIENTS_CONFIG.is_file():
        return []
    try:
        cfg = json.loads(MCP_CLIENTS_CONFIG.read_text())
    except Exception:
        return []
    return cfg.get("servers", []) if isinstance(cfg, dict) else []


def _mcp_connect_all() -> None:
    """Connect to every configured MCP server. Best-effort; failures are
    captured per-client and printed but don't block joe startup."""
    if _MCP_CLIENTS:
        return  # already connected
    servers = _mcp_load_config()
    if not servers:
        return
    if not _mcp_check_available():
        console.print(
            "[yellow]mcp-clients.json configured but the `mcp` SDK is not "
            "installed.[/]  pip install --user mcp"
        )
        return
    for s in servers:
        if not isinstance(s, dict) or "name" not in s:
            continue
        if not s.get("enabled", True):
            continue
        client = MCPClient(s)
        ok = client.start()
        _MCP_CLIENTS[s["name"]] = client
        if ok:
            console.print(
                f"[dim]mcp client[/] [bold green]connected[/] "
                f"{s['name']} ({len(client.tools)} tools)"
            )
        else:
            console.print(
                f"[dim]mcp client[/] [bold red]failed[/] "
                f"{s['name']}: {client._connect_error}"
            )


def _mcp_tools_block() -> str:
    """Format the currently-connected MCP tools so the model can call them."""
    if not _MCP_CLIENTS:
        return ""
    lines: list[str] = []
    for name, client in _MCP_CLIENTS.items():
        if not client.connected:
            continue
        for t in client.tools:
            desc = (getattr(t, "description", "") or "").strip().replace("\n", " ")
            if len(desc) > 120:
                desc = desc[:120] + "..."
            lines.append(f"  <mcp server=\"{name}\" tool=\"{t.name}\" /> -- {desc}")
    if not lines:
        return ""
    return (
        "<mcp_tools>\n"
        "Available external MCP tools. Use them via:\n"
        "  <mcp server=\"<name>\" tool=\"<tool>\">{\"arg\": \"value\"}</mcp>\n"
        "args body is a JSON object. Result comes back in <tool_result>.\n"
        + "\n".join(lines)
        + "\n</mcp_tools>"
    )


def tool_mcp(attrs: dict, body: str) -> str:
    server = attrs.get("server", "")
    tool = attrs.get("tool", "")
    if not server or not tool:
        raise ToolError("<mcp> needs server=\"...\" and tool=\"...\"")
    client = _MCP_CLIENTS.get(server)
    if not client:
        raise ToolError(
            f"<mcp server={server!r}>: not connected. "
            f"available: {sorted(_MCP_CLIENTS.keys()) or '(none)'}"
        )
    try:
        args = json.loads(body) if body.strip() else {}
    except json.JSONDecodeError as e:
        raise ToolError(f"<mcp>: args body must be JSON ({e})")
    if not isinstance(args, dict):
        raise ToolError("<mcp>: args body must be a JSON object")
    panel(
        f"MCP call: {server}.{tool}",
        Syntax(json.dumps(args, indent=2), "json", theme="ansi_dark"),
        style="bright_blue",
    )
    out = client.call(tool, args)
    if len(out) > 6000:
        out = out[:6000] + "\n[... truncated ...]"
    panel(
        f"MCP result: {server}.{tool}",
        Syntax(out, "text", theme="ansi_dark"),
        style="bright_blue" if not out.startswith("ERROR:") else "red",
    )
    return out


# --------------------------------------------------------------------------
# Background task tracker (long-running shell jobs with ntfy phone push)
# --------------------------------------------------------------------------
#
# A "task" is a backgrounded shell command that joe spawned and is tracking
# in TASKS_DIR. Each task gets a short id, a JSON state file, and a log file:
#
#   ~/.joe-agent/tasks/<id>.json    {id, cmd, pid, status, started, finished,
#                                    exit_code, cwd, label}
#   ~/.joe-agent/tasks/<id>.log     captured stdout + stderr
#
# When the command finishes, a small in-process watcher thread updates the
# JSON and fires a notification (ntfy.sh if NTFY_TOPIC is set, plus a macOS
# osascript banner). The watcher dies with the joe process, so tasks survive
# the parent's exit but the *notification* requires joe to still be running.
# For fully-detached long-runs, schedule via `joe-schedule` instead.


def _task_id() -> str:
    return secrets.token_hex(3)


def _task_paths(tid: str) -> tuple[Path, Path]:
    return TASKS_DIR / f"{tid}.json", TASKS_DIR / f"{tid}.log"


def _task_load(tid: str) -> Optional[dict]:
    state, _ = _task_paths(tid)
    if not state.exists():
        return None
    try:
        return json.loads(state.read_text())
    except json.JSONDecodeError:
        return None


def _task_save(tid: str, data: dict) -> None:
    state, _ = _task_paths(tid)
    state.write_text(json.dumps(data, indent=2))


def _task_notify(data: dict) -> None:
    msg = (
        f"joe-task #{data['id']} {data['status']} "
        f"(exit {data.get('exit_code', '?')}): {data['cmd'][:80]}"
    )
    # Phone push via ntfy.sh.
    if NTFY_TOPIC:
        try:
            req = urllib.request.Request(
                f"https://ntfy.sh/{NTFY_TOPIC}",
                data=msg.encode(),
                headers={"Title": "joe-task done", "Priority": "default"},
                method="POST",
            )
            urllib.request.urlopen(req, timeout=5).close()
        except Exception:
            pass
    # Local banner (portable: osascript on macOS, notify-send on Linux).
    try:
        os_notify("joe-task", msg)
    except Exception:
        pass


def _task_watch(tid: str, proc: subprocess.Popen) -> None:
    """Daemon thread: wait for `proc`, write final status, notify."""
    exit_code = proc.wait()
    data = _task_load(tid) or {}
    data["status"] = "finished" if exit_code == 0 else "failed"
    data["exit_code"] = exit_code
    data["finished"] = dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat()
    _task_save(tid, data)
    _task_notify(data)


def task_spawn(cmd: str, cwd: Path, label: str = "") -> dict:
    """Start `cmd` in the background under cwd; return its task state."""
    tid = _task_id()
    state, logp = _task_paths(tid)
    logf = logp.open("w")
    proc = subprocess.Popen(
        ["bash", "-c", cmd], cwd=str(cwd),
        stdout=logf, stderr=subprocess.STDOUT,
        start_new_session=True,  # survives joe exit
    )
    data = {
        "id": tid, "cmd": cmd, "pid": proc.pid, "status": "running",
        "started": dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(), "finished": None,
        "exit_code": None, "cwd": str(cwd), "label": label,
    }
    _task_save(tid, data)
    t = threading.Thread(target=_task_watch, args=(tid, proc), daemon=True)
    t.start()
    return data


def task_list() -> list[dict]:
    out: list[dict] = []
    for f in sorted(TASKS_DIR.glob("*.json")):
        try:
            d = json.loads(f.read_text())
        except json.JSONDecodeError:
            continue
        # Probe running tasks to see if the PID actually exists; the watcher
        # might have been killed with the joe parent before it could update.
        if d.get("status") == "running":
            try:
                os.kill(d["pid"], 0)
            except ProcessLookupError:
                d["status"] = "orphaned"  # process gone, no exit recorded
            except PermissionError:
                pass  # exists but not ours, treat as running
        out.append(d)
    return out


def task_kill(tid: str) -> bool:
    data = _task_load(tid)
    if not data or data.get("status") != "running":
        return False
    try:
        os.kill(data["pid"], signal.SIGTERM)
        return True
    except ProcessLookupError:
        return False


def cmd_tasks(state_unused=None) -> None:
    rows = task_list()
    if not rows:
        panel("Background tasks", "(no tasks yet)", style="dim"); return
    now = dt.datetime.now(dt.UTC).replace(tzinfo=None)
    lines: list[str] = []
    for d in rows[-12:]:
        started = dt.datetime.fromisoformat(d["started"])
        age = now - started
        age_s = (f"{age.total_seconds():.0f}s" if age.total_seconds() < 60
                 else f"{age.total_seconds() / 60:.1f}m" if age.total_seconds() < 3600
                 else f"{age.total_seconds() / 3600:.1f}h")
        status_color = {"running": "yellow", "finished": "green",
                        "failed": "red", "orphaned": "magenta"}.get(d["status"], "white")
        lines.append(
            f"[bold]#{d['id']}[/]  [{status_color}]{d['status']:<8}[/]"
            f"  age {age_s:>5}  exit {d.get('exit_code', '-'): <4}  "
            f"{d['cmd'][:60]}"
        )
    panel(f"Background tasks ({len(rows)} total)",
          Text.from_markup("\n".join(lines)),
          style="cyan",
          subtitle=f"ntfy: {NTFY_TOPIC or '(unset)'}")


def cmd_task_show(tid: str) -> None:
    d = _task_load(tid)
    if not d:
        console.print(f"[red]no task #{tid}[/]"); return
    _, logp = _task_paths(tid)
    log = logp.read_text() if logp.exists() else "(no log yet)"
    if len(log) > 4000:
        log = "[... earlier output truncated ...]\n" + log[-4000:]
    panel(
        f"Task #{tid}  [{d['status']}]",
        Group(
            Text.from_markup(
                f"[bold]cmd:[/] {d['cmd']}\n"
                f"[bold]cwd:[/] {d['cwd']}\n"
                f"[bold]pid:[/] {d['pid']}    "
                f"[bold]started:[/] {d['started']}\n"
                f"[bold]exit:[/] {d.get('exit_code', '-')}    "
                f"[bold]finished:[/] {d.get('finished', '-')}"
            ),
            Text(""),
            Syntax(log, "text", theme="ansi_dark"),
        ),
        style="cyan",
    )


# --------------------------------------------------------------------------
# Cross-session memory: embed every (user, assistant) turn so future
# sessions can retrieve relevant past context.
# --------------------------------------------------------------------------


def _hidb() -> sqlite3.Connection:
    c = sqlite3.connect(str(HISTORY_INDEX_DB))
    c.execute(
        "CREATE TABLE IF NOT EXISTS hist ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " session TEXT NOT NULL, ts TEXT NOT NULL,"
        " user_msg TEXT NOT NULL, asst_msg TEXT NOT NULL,"
        " embed BLOB NOT NULL)"
    )
    c.execute("CREATE INDEX IF NOT EXISTS idx_hist_ts ON hist(ts)")
    return c


def _embed(text: str) -> Optional[list[float]]:
    """Hit the local Ollama embedding endpoint. Returns None on failure."""
    if not text.strip():
        return None
    text = text[:EMBED_INPUT_MAX_CHARS]
    body = json.dumps({"model": EMBED_MODEL, "prompt": text}).encode()
    try:
        req = urllib.request.Request(
            "http://localhost:11434/api/embeddings",
            data=body, headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=15) as r:
            obj = json.loads(r.read())
        vec = obj.get("embedding")
        if not vec or not isinstance(vec, list):
            return None
        return [float(x) for x in vec]
    except Exception:
        return None


def _pack_vec(v: list[float]) -> bytes:
    return struct.pack(f"{len(v)}f", *v)


def _unpack_vec(b: bytes) -> list[float]:
    n = len(b) // 4
    return list(struct.unpack(f"{n}f", b))


def _cosine(a: list[float], b: list[float]) -> float:
    if len(a) != len(b):
        return 0.0
    dot = sum(x * y for x, y in zip(a, b))
    na = math.sqrt(sum(x * x for x in a))
    nb = math.sqrt(sum(y * y for y in b))
    if na == 0 or nb == 0:
        return 0.0
    return dot / (na * nb)


def history_remember(session: str, user_msg: str, asst_msg: str) -> None:
    """Embed and store a (user, assistant) pair. Best-effort: silent on fail."""
    combined = f"USER: {user_msg}\n\nASSISTANT: {asst_msg[:4000]}"
    vec = _embed(combined)
    if not vec:
        return
    c = _hidb()
    c.execute(
        "INSERT INTO hist (session, ts, user_msg, asst_msg, embed)"
        " VALUES (?, ?, ?, ?, ?)",
        (session, dt.datetime.now(dt.UTC).replace(tzinfo=None).isoformat(),
         user_msg[:4000], asst_msg[:4000], _pack_vec(vec)),
    )
    c.commit(); c.close()


def _parse_time_phrase(query: str) -> tuple[Optional[str], Optional[str], str]:
    """Sniff temporal hints out of a free-text query.

    Returns (since_iso, until_iso, cleaned_query) where the ISO strings
    are UTC timestamps (or None) and cleaned_query has the time phrase
    stripped if we matched one. Best-effort; misses fall back to no
    time filter.
    """
    now = dt.datetime.now(dt.UTC).replace(tzinfo=None)
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)
    patterns: list[tuple[str, dt.datetime, Optional[dt.datetime]]] = [
        # phrase                         since                              until
        (r"\btoday\b",                  today_start,                        None),
        (r"\bthis morning\b",           today_start,                        today_start + dt.timedelta(hours=12)),
        (r"\bthis afternoon\b",         today_start + dt.timedelta(hours=12), today_start + dt.timedelta(hours=18)),
        (r"\bthis evening\b",           today_start + dt.timedelta(hours=18), today_start + dt.timedelta(days=1)),
        (r"\byesterday morning\b",      today_start - dt.timedelta(days=1),  today_start - dt.timedelta(days=1) + dt.timedelta(hours=12)),
        (r"\byesterday afternoon\b",    today_start - dt.timedelta(days=1) + dt.timedelta(hours=12), today_start - dt.timedelta(days=1) + dt.timedelta(hours=18)),
        (r"\byesterday\b",              today_start - dt.timedelta(days=1),  today_start),
        (r"\blast week\b",              today_start - dt.timedelta(days=7),  today_start),
        (r"\bthis week\b",              today_start - dt.timedelta(days=now.weekday()), None),
        (r"\blast month\b",             today_start - dt.timedelta(days=30), today_start),
    ]
    for pat, since, until in patterns:
        if re.search(pat, query, re.IGNORECASE):
            cleaned = re.sub(pat, "", query, flags=re.IGNORECASE).strip()
            return (
                since.isoformat(),
                until.isoformat() if until else None,
                cleaned or query,  # keep original if cleaning emptied it
            )
    # "N hours/days ago"
    m = re.search(r"\b(\d+)\s+(hour|hr|day|week)s?\s+ago\b", query, re.IGNORECASE)
    if m:
        n = int(m.group(1))
        unit = m.group(2).lower()
        delta = {
            "hour": dt.timedelta(hours=n), "hr": dt.timedelta(hours=n),
            "day": dt.timedelta(days=n), "week": dt.timedelta(weeks=n),
        }[unit]
        since = now - delta
        cleaned = re.sub(m.re, "", query).strip()
        return (since.isoformat(), None, cleaned or query)
    # explicit ISO date
    m = re.search(r"\b(\d{4})-(\d{2})-(\d{2})\b", query)
    if m:
        y, mo, da = int(m.group(1)), int(m.group(2)), int(m.group(3))
        start = dt.datetime(y, mo, da)
        return (start.isoformat(), (start + dt.timedelta(days=1)).isoformat(),
                re.sub(m.re, "", query).strip() or query)
    return (None, None, query)


def history_recall(user_msg: str, k: int = 3, exclude_session: str = "") -> list[dict]:
    """Find k most similar past turns to `user_msg`. Empty list on miss.

    If the query contains a time phrase (today / yesterday / last week /
    N hours ago / 2026-05-10 / etc.), narrow to that window before
    similarity ranking.
    """
    if len(user_msg.strip()) < 12:
        return []
    since, until, cleaned = _parse_time_phrase(user_msg)
    q = _embed(cleaned)
    if not q:
        return []
    c = _hidb()
    sql = ("SELECT id, session, ts, user_msg, asst_msg, embed FROM hist"
           " WHERE session != ?")
    params: list = [exclude_session]
    if since:
        sql += " AND ts >= ?"; params.append(since)
    if until:
        sql += " AND ts < ?"; params.append(until)
    rows = c.execute(sql, params).fetchall()
    c.close()
    if not rows:
        return []
    scored: list[tuple[float, dict]] = []
    for rid, sess, ts, um, am, eb in rows:
        score = _cosine(q, _unpack_vec(eb))
        scored.append((score, {"id": rid, "session": sess, "ts": ts,
                                "user_msg": um, "asst_msg": am, "score": score}))
    scored.sort(key=lambda x: x[0], reverse=True)
    # If user gave an explicit time window, lower the similarity floor.
    floor = 0.18 if (since or until) else 0.35
    return [d for s, d in scored[:k] if s >= floor]


def history_block(picks: list[dict]) -> str:
    if not picks:
        return ""
    parts = []
    for p in picks:
        when = p["ts"][:10]
        parts.append(
            f"[from session {p['session']} on {when}, similarity {p['score']:.2f}]\n"
            f"USER: {p['user_msg'][:600]}\n"
            f"YOU: {p['asst_msg'][:1200]}"
        )
    return "<past_turns note=\"retrieved by similarity, may or may not be relevant\">\n" \
           + "\n\n".join(parts) + "\n</past_turns>"


# --------------------------------------------------------------------------
# Token budget helpers
# --------------------------------------------------------------------------


def estimate_tokens(text: str) -> int:
    return max(1, len(text) // CHARS_PER_TOKEN)


def session_token_estimate(session: str, max_pairs: int = 12) -> int:
    if not session:
        return 0
    c = _db()
    rows = c.execute(
        "SELECT content FROM turns WHERE session = ? ORDER BY ts DESC LIMIT ?",
        (session, max_pairs * 2),
    ).fetchall()
    c.close()
    return sum(estimate_tokens(r[0]) for r in rows)


# --------------------------------------------------------------------------
# Auto-test-on-edit (run profile test_cmd after a successful write/edit)
# --------------------------------------------------------------------------


def _maybe_auto_test(path: Path) -> None:
    """If JOE_AUTO_TEST=1 and the profile has a test_cmd, run it briefly."""
    if os.environ.get("JOE_AUTO_TEST", "").strip() not in {"1", "true", "yes"}:
        return
    try:
        profile = _load_profile(path.parent if path.is_file() else path)
    except Exception:
        return
    test_cmd = profile.get("test_cmd")
    if not test_cmd:
        return
    # Find the repo root (where the profile applies).
    cwd = path.parent if path.is_file() else path
    try:
        repo = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=str(cwd), capture_output=True, text=True, timeout=3,
        ).stdout.strip()
    except Exception:
        repo = ""
    cwd_run = Path(repo) if repo else cwd
    try:
        cp = subprocess.run(
            test_cmd, shell=True, cwd=str(cwd_run),
            capture_output=True, text=True, timeout=180,
        )
    except subprocess.TimeoutExpired:
        panel("Auto-test", "TIMEOUT (180s)", style="yellow"); return
    out = (cp.stdout or "") + (("\n[stderr]\n" + cp.stderr) if cp.stderr else "")
    tail = out.splitlines()[-12:] if out else []
    panel(
        f"Auto-test ({test_cmd})",
        Text("\n".join(tail) if tail else "(no output)"),
        style="green" if cp.returncode == 0 else "red",
        subtitle=f"exit {cp.returncode}  ·  cwd {cwd_run}",
    )


# --------------------------------------------------------------------------
# Tool call protocol: XML-style tags emitted by the model.
# --------------------------------------------------------------------------

# Each tool spec describes how to detect, parse, and label a tool call.
# We do a streaming scan: tokens arrive, we accumulate, and look for a
# closing tag or self-closing one. When found, we pause generation,
# execute, feed result back as the next prompt.

@dataclasses.dataclass
class ToolCall:
    name: str
    attrs: dict[str, str]
    body: str
    raw: str  # the exact text we matched (for replacement / display)


# We support both:
#   self-closing:  <tool_name attr="val" />
#   block:         <tool_name attr="val">body</tool_name>
TAG_PAT = re.compile(
    r"<(?P<name>read|write|edit|bash|grep|glob|delegate|"
    r"test|lint|build|web_search|web_fetch|plan|image|mcp)"
    # attrs: greedy any-char-but-> with a tail-trim of optional `/` so we still
    # detect self-closing tags. Previous version excluded `/` which broke
    # paths like `/tmp/foo`.
    r"(?P<attrs>\s+[^>]*?)??\s*"
    r"(?P<self>/>|>(?P<body>.*?)</(?P=name)>)",
    re.DOTALL,
)
ATTR_PAT = re.compile(r'(\w+)\s*=\s*"([^"]*)"')


RUN_LEGACY_PAT = re.compile(r"^RUN:\s*(.+?)\s*$", re.MULTILINE)

# Fallback for when the model emits an opener like `<web_search query="...">`
# but forgets the closing tag (or `/>`). Recognise it as a self-closing call
# IF the tag carries attributes, so we don't false-positive on prose that
# happens to mention the tag name.
OPENER_FALLBACK_PAT = re.compile(
    r"<(?P<name>read|write|edit|bash|grep|glob|delegate|"
    r"test|lint|build|web_search|web_fetch|plan|image|mcp)"
    r"(?P<attrs>\s+[^>]+?)\s*/?>"
    r"(?!.*</(?P=name)>)",  # only if there's no matching close downstream
    re.DOTALL,
)


def extract_first_tool_call(text: str) -> Optional[ToolCall]:
    m = TAG_PAT.search(text)
    if m:
        attrs = {k: v for k, v in ATTR_PAT.findall(m.group("attrs") or "")}
        body = (m.group("body") or "").strip() if m.group("body") is not None else ""
        return ToolCall(name=m.group("name"), attrs=attrs, body=body, raw=m.group(0))
    # Fallback: a bare opener like `<web_search query="...">` with no close.
    m2 = OPENER_FALLBACK_PAT.search(text)
    if m2:
        attrs = {k: v for k, v in ATTR_PAT.findall(m2.group("attrs") or "")}
        return ToolCall(name=m2.group("name"), attrs=attrs, body="", raw=m2.group(0))
    # Backward-compat: the personalised joe-gemma Modelfile teaches a
    # `RUN: <cmd>` protocol from the older joe-agent one-shot wrapper.
    # Honour it here as a bash call so the model doesn't get stranded.
    legacy = RUN_LEGACY_PAT.search(text)
    if legacy:
        return ToolCall(name="bash", attrs={}, body=legacy.group(1).strip(), raw=legacy.group(0))
    return None


# --------------------------------------------------------------------------
# Tool implementations
# --------------------------------------------------------------------------

class ToolError(RuntimeError):
    pass


def _resolve_path(p: str) -> Path:
    return Path(os.path.expanduser(p)).resolve()


def tool_read(attrs: dict, body: str) -> str:
    path = attrs.get("path")
    if not path:
        raise ToolError("<read /> requires path=\"...\"")
    p = _resolve_path(path)
    if not p.exists():
        raise ToolError(f"{path}: no such file")
    if p.is_dir():
        raise ToolError(f"{path}: is a directory; use <glob> or <bash>ls</bash> instead")
    text = p.read_text(encoding="utf-8", errors="replace")
    lines = text.splitlines()
    # Cap absurd reads.
    if len(lines) > 2000:
        text = "\n".join(lines[:2000]) + f"\n... [truncated; file has {len(lines)} lines]"
    panel(
        f"Read {path}",
        Syntax(text, _guess_lexer(p), line_numbers=True, theme="ansi_dark", word_wrap=False),
        style="green",
        subtitle=f"{len(lines)} lines",
    )
    return text


def tool_write(attrs: dict, body: str, confirm: bool = True) -> str:
    path = attrs.get("path")
    if not path:
        raise ToolError("<write> requires path=\"...\"")
    # Catch the model's habit of using placeholder paths from documentation
    # examples (path/to/file.py, /path/to/..., ~/dir/file.ext, etc.).
    placeholder_patterns = ("path/to/", "/path/to/", "your/path", "<path>", "{path}")
    if any(pat in path for pat in placeholder_patterns):
        # Auto-capture as a lesson so /lessons distill can teach the model
        # to stop emitting placeholders next time.
        try:
            lesson_capture(
                source="placeholder-path",
                rejected=f"<write path={path!r}>",
                note="emitted a documentation-example placeholder path "
                     "instead of an absolute or cwd-relative real path",
            )
        except Exception:
            pass
        raise ToolError(
            f"<write path={path!r}>: that's a placeholder, not a real path. "
            f"Re-emit <write> with the actual target path from the user's request. "
            f"If you don't know the path, STOP."
        )
    p = _resolve_path(path)
    # Strangers-in-the-repo check: if the path is in a directory that has
    # no neighbors AND no git ancestor recognises it, the model is probably
    # hallucinating a project structure that doesn't exist. We don't refuse
    # (the user might genuinely be creating a new dir) but we add a clear
    # warning to the result the model sees in <tool_result>, so it can
    # reconsider before continuing.
    stranger_warning = ""
    if not p.exists():
        # Check: is ANY part of this path's parent chain a real existing dir
        # inside the cwd or a parent git repo?
        try:
            cwd_now = Path.cwd()
            existing_ancestor: Optional[Path] = None
            for ancestor in p.parents:
                if ancestor.is_dir():
                    existing_ancestor = ancestor
                    break
            if existing_ancestor is None or not (
                str(existing_ancestor).startswith(str(cwd_now))
                or str(cwd_now).startswith(str(existing_ancestor))
            ):
                stranger_warning = (
                    f"NOTE: {path} is in a directory that doesn't exist "
                    f"under {cwd_now}. If you're creating a brand-new tree, "
                    f"this is fine. If you meant an existing project path, "
                    f"check <plan_environment> for the real layout."
                )
        except Exception:
            pass
    p.parent.mkdir(parents=True, exist_ok=True)
    existing = p.read_text(encoding="utf-8", errors="replace") if p.exists() else None
    if existing is not None:
        diff_lines = list(difflib.unified_diff(
            existing.splitlines(), body.splitlines(),
            fromfile=f"a/{path}", tofile=f"b/{path}", lineterm="",
        ))
        diff = "\n".join(diff_lines)
        if diff:
            adds = sum(1 for ln in diff_lines if ln.startswith("+") and not ln.startswith("+++"))
            dels = sum(1 for ln in diff_lines if ln.startswith("-") and not ln.startswith("---"))
            panel(
                f"Write {path}",
                Syntax(diff, "diff", theme="ansi_dark"),
                style="yellow",
                subtitle=f"+{adds} / -{dels}  ({len(existing)} -> {len(body)} bytes)",
            )
        else:
            panel(f"Write {path} (no changes)", "", style="dim")
            return "no changes"
    else:
        panel(
            f"Write {path} (new file)",
            Syntax(body[:4000] + ("..." if len(body) > 4000 else ""),
                   _guess_lexer(p), theme="ansi_dark"),
            style="green",
            subtitle=f"{len(body)} bytes  ·  {len(body.splitlines())} lines",
        )
    if confirm and not _confirm(f"Apply this write to {path}?"):
        return "user denied write"
    p.write_text(body, encoding="utf-8")
    log_edit(path=str(p), before=existing, after=body, op="write")
    line_count = len(body.splitlines())
    adds_n = sum(1 for ln in (diff_lines if existing is not None else [])
                 if ln.startswith("+") and not ln.startswith("+++"))
    dels_n = sum(1 for ln in (diff_lines if existing is not None else [])
                 if ln.startswith("-") and not ln.startswith("---"))
    if existing is None:
        adds_n, dels_n = line_count, 0
    provenance_record(
        p, "write", existing, body,
        line_start=1, line_end=max(1, line_count),
        adds=adds_n, dels=dels_n,
    )
    _maybe_auto_test(p)
    msg = f"wrote {len(body)} bytes to {path}"
    if stranger_warning:
        msg += "\n" + stranger_warning
    return msg


def tool_edit(attrs: dict, body: str, confirm: bool = True) -> str:
    path = attrs.get("path")
    if not path:
        raise ToolError("<edit> requires path=\"...\"")
    # Body contains <old>...</old> <new>...</new>
    old_m = re.search(r"<old>\s*(.*?)\s*</old>", body, re.DOTALL)
    new_m = re.search(r"<new>\s*(.*?)\s*</new>", body, re.DOTALL)
    if not old_m or not new_m:
        raise ToolError("<edit> body must contain <old>...</old><new>...</new>")
    p = _resolve_path(path)
    if not p.exists():
        raise ToolError(f"{path}: no such file")
    src = p.read_text(encoding="utf-8", errors="replace")
    old, new = old_m.group(1), new_m.group(1)
    if src.count(old) == 0:
        raise ToolError(f"<edit> old-string not found in {path}")
    if src.count(old) > 1:
        raise ToolError(f"<edit> old-string not unique in {path} ({src.count(old)} matches)")
    new_src = src.replace(old, new, 1)
    diff_lines = list(difflib.unified_diff(
        src.splitlines(), new_src.splitlines(),
        fromfile=f"a/{path}", tofile=f"b/{path}", lineterm="",
    ))
    diff = "\n".join(diff_lines)
    adds = sum(1 for ln in diff_lines if ln.startswith("+") and not ln.startswith("+++"))
    dels = sum(1 for ln in diff_lines if ln.startswith("-") and not ln.startswith("---"))
    panel(
        f"Edit {path}", Syntax(diff, "diff", theme="ansi_dark"),
        style="yellow", subtitle=f"+{adds} / -{dels}",
    )
    if confirm and not _confirm(f"Apply this edit to {path}?"):
        return "user denied edit"
    p.write_text(new_src, encoding="utf-8")
    log_edit(path=str(p), before=src, after=new_src, op="edit")
    # Best-effort line range: find old in src by counting newlines before match.
    idx = src.find(old)
    ls = src.count("\n", 0, idx) + 1 if idx >= 0 else None
    le = (ls + new.count("\n")) if ls is not None else None
    provenance_record(
        p, "edit", src, new_src,
        line_start=ls, line_end=le, adds=adds, dels=dels,
    )
    _maybe_auto_test(p)
    return f"edited {path}"


def tool_bash(attrs: dict, body: str, allow_all: bool, confirm: bool = True) -> str:
    cmd = body.strip()
    if not cmd:
        raise ToolError("<bash> body is empty")
    if not allow_all:
        try:
            first = shlex.split(cmd)[0]
        except ValueError:
            first = ""
        if os.path.basename(first) not in ALLOWED_BASH_PROGRAMS:
            raise ToolError(f"<bash>: {first!r} not in safe allow-list (pass --unsafe-bash to broaden)")
    panel(f"Bash", Syntax(cmd, "bash", theme="ansi_dark"), style="magenta")
    if confirm and not _confirm("Run this command?"):
        return "user denied bash"
    try:
        cp = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=120)
    except subprocess.TimeoutExpired:
        return "TIMEOUT (120s)"
    out = (cp.stdout or "") + (("\n[stderr]\n" + cp.stderr) if cp.stderr else "")
    if not out:
        out = f"(exit {cp.returncode}, no output)"
    if len(out) > 6000:
        out = out[:6000] + "\n[... truncated ...]"
    panel("Bash output", Syntax(out, "text", theme="ansi_dark"),
          style="dim", subtitle=f"exit {cp.returncode}")
    return out


def tool_grep(attrs: dict, body: str) -> str:
    pat = attrs.get("pattern") or body.strip()
    where = attrs.get("path", ".")
    if not pat:
        raise ToolError("<grep> requires pattern=\"...\" or body")
    p = _resolve_path(where)
    try:
        cp = subprocess.run(
            ["grep", "-r", "-n", "-I", "--max-count=20",
             "--exclude-dir=.git", "--exclude-dir=node_modules",
             "--exclude-dir=.next", "--exclude-dir=__pycache__",
             "--exclude-dir=target", pat, str(p)],
            capture_output=True, text=True, timeout=20,
        )
    except subprocess.TimeoutExpired:
        return "TIMEOUT"
    out = cp.stdout or "(no matches)"
    if len(out) > 4000:
        out = out[:4000] + "\n[... truncated ...]"
    panel(f"Grep {pat!r} in {where}", Syntax(out, "text", theme="ansi_dark"), style="cyan")
    return out


def tool_glob(attrs: dict, body: str) -> str:
    pat = attrs.get("pattern") or body.strip()
    if not pat:
        raise ToolError("<glob> requires pattern=\"...\" or body")
    matches = glob.glob(os.path.expanduser(pat), recursive=True)[:200]
    out = "\n".join(matches) if matches else "(no matches)"
    panel(f"Glob {pat!r}", Syntax(out, "text", theme="ansi_dark"),
          style="cyan", subtitle=f"{len(matches)} matches")
    return out


_LAST_DELEGATE_FINGERPRINT: dict[str, list[str]] = {"fps": []}


def _fingerprint(s: str, n: int = 200) -> str:
    """First-N-chars + length, normalised for whitespace. Cheap dup check."""
    norm = re.sub(r"\s+", " ", s).strip()
    return f"{len(norm)}::{norm[:n]}"


def tool_delegate(attrs: dict, body: str, coder_model: str) -> str:
    spec = body.strip()
    if not spec:
        raise ToolError("<delegate> body is empty")
    # Delegate-loop detection: if the last two delegates had near-identical
    # specs, the model is asking the coder the same question twice. Refuse
    # rather than burn turns + tokens on a stuck pattern.
    fp = _fingerprint(spec)
    recent = _LAST_DELEGATE_FINGERPRINT["fps"][-2:]
    if recent and recent.count(fp) >= 1:
        _LAST_DELEGATE_FINGERPRINT["fps"].append(fp)
        raise ToolError(
            "delegate-loop: this spec matches a recent <delegate>. "
            "The coder won't give a different answer to the same question. "
            "Either change the task substantively, switch model, or STOP."
        )
    _LAST_DELEGATE_FINGERPRINT["fps"].append(fp)
    # Trim history so the dict doesn't grow forever.
    if len(_LAST_DELEGATE_FINGERPRINT["fps"]) > 20:
        _LAST_DELEGATE_FINGERPRINT["fps"] = _LAST_DELEGATE_FINGERPRINT["fps"][-10:]
    model = attrs.get("model", coder_model)
    panel(
        f"Delegate to {model}",
        Syntax(spec, "text", theme="ansi_dark", word_wrap=True),
        style="bright_blue",
    )
    # Wrap the spec with the user's style rules (resolved from the active
    # profile + lessons supplement) so the coder model picks them up even
    # though it doesn't share the orchestrator's system prompt. We also
    # inject the active cwd so the coder doesn't emit nonsensical paths
    # ("src/foo.ts" when cwd is /) and the lessons supplement so newly-
    # distilled preferences propagate down to the code-writing layer.
    cwd_for_style = Path.cwd()
    short_cwd = str(cwd_for_style).replace(str(HOME), "~")
    style_hint = ""
    try:
        prof = _load_profile(cwd_for_style)
        ctx = prof.get("context_extra", "").strip()
        if ctx:
            style_hint = f"\nProject context:\n{ctx}\n"
    except Exception:
        pass
    lessons_hint = ""
    try:
        rules = lessons_active_rules()
        if rules:
            lessons_hint = (
                "\nLearned preferences (obey before defaults):\n"
                + "\n".join(f"  - {r}" for r in rules)
                + "\n"
            )
    except Exception:
        pass
    wrapped = (
        f"<cwd>{short_cwd}</cwd>\n"
        "Any file paths you produce MUST be absolute (~/foo or /Users/.../foo) "
        "or correctly relative to the cwd above. Never emit speculative paths "
        "like 'src/...' unless the cwd is a project root that has them.\n\n"
        "You are writing code for the user. Match this style by default "
        "(the active repo profile may override):\n"
        "  - Python: type hints, dataclasses where state is plain, "
        "    ruff-formatted, pytest with descriptive test names.\n"
        "  - TypeScript: strict, named exports, Tailwind utility classes.\n"
        "  - Rust: rustfmt-clean, clippy -D warnings, prefer Result over panic.\n"
        "  - No em-dashes as separators (use commas, colons, parens).\n"
        "  - No emojis in source, READMEs, commit messages, UI strings.\n"
        "  - Comments only when WHY is non-obvious; never WHAT.\n"
        f"{style_hint}{lessons_hint}"
        "Respond with code only inside a single fenced code block. "
        "Include the language tag. Brief preamble outside the fence is OK.\n\n"
        f"Task:\n{spec}"
    )
    out = _ollama_once(model, wrapped)
    panel(f"Code from {model}", Markdown(out), style="bright_blue")
    return out


# --------------------------------------------------------------------------
# Round-2 tools: test / lint / build, web_search / web_fetch, plan
# --------------------------------------------------------------------------


def _detect_lang_root(path_str: str) -> tuple[Optional[str], Optional[Path]]:
    """Walk up from `path_str` looking for a project-marker file."""
    p = _resolve_path(path_str) if path_str else Path.cwd()
    if p.is_file():
        p = p.parent
    for ancestor in [p] + list(p.parents):
        if (ancestor / "pyproject.toml").exists() or (ancestor / "pytest.ini").exists() \
                or (ancestor / "setup.py").exists():
            return "python", ancestor
        if (ancestor / "Cargo.toml").exists():
            return "rust", ancestor
        if (ancestor / "package.json").exists():
            # Prefer pnpm > bun > npm based on lockfiles.
            return "node", ancestor
        if (ancestor / "go.mod").exists():
            return "go", ancestor
    return None, None


def _node_runner(repo: Path) -> str:
    if (repo / "pnpm-lock.yaml").exists():
        return "pnpm"
    if (repo / "bun.lock").exists() or (repo / "bun.lockb").exists():
        return "bun"
    if (repo / "yarn.lock").exists():
        return "yarn"
    return "npm"


def _spawn(cmd: str, cwd: Path, timeout: int = 300, confirm: bool = True) -> str:
    panel("Run", Syntax(f"$ {cmd}  (cwd: {cwd})", "bash", theme="ansi_dark"), style="magenta")
    if confirm and not _confirm("Run it?"):
        return "user denied run"
    try:
        cp = subprocess.run(cmd, shell=True, cwd=str(cwd),
                            capture_output=True, text=True, timeout=timeout)
    except subprocess.TimeoutExpired:
        return f"TIMEOUT ({timeout}s)"
    out = (cp.stdout or "") + (("\n[stderr]\n" + cp.stderr) if cp.stderr else "")
    if not out:
        out = f"(exit {cp.returncode}, no output)"
    if len(out) > 6000:
        out = out[:6000] + "\n[... truncated ...]"
    panel("Output", Syntax(out, "text", theme="ansi_dark"),
          style="dim", subtitle=f"exit {cp.returncode}")
    return out


def tool_test(attrs: dict, body: str, confirm: bool = True) -> str:
    where = attrs.get("path", ".")
    lang, root = _detect_lang_root(where)
    if not lang or not root:
        raise ToolError(f"<test path={where!r}>: no project marker found")
    target = attrs.get("target") or body.strip() or ""
    if lang == "python":
        cmd = f"pytest {target}".strip()
    elif lang == "rust":
        cmd = f"cargo test {target}".strip()
    elif lang == "node":
        runner = _node_runner(root)
        cmd = f"{runner} test {target}".strip()
    elif lang == "go":
        cmd = f"go test {target or './...'}".strip()
    else:
        raise ToolError(f"unknown language: {lang}")
    return _spawn(cmd, root, timeout=600, confirm=confirm)


def tool_lint(attrs: dict, body: str, confirm: bool = True) -> str:
    where = attrs.get("path", ".")
    lang, root = _detect_lang_root(where)
    if not lang or not root:
        raise ToolError(f"<lint path={where!r}>: no project marker found")
    if lang == "python":
        cmd = "ruff check ."
    elif lang == "rust":
        cmd = "cargo clippy -- -D warnings"
    elif lang == "node":
        # eslint, biome, tsc. Prefer biome if present, then eslint, then tsc.
        if (root / "biome.json").exists() or (root / "biome.jsonc").exists():
            cmd = f"{_node_runner(root)} run -s lint"
        elif (root / ".eslintrc").exists() or (root / ".eslintrc.json").exists() \
                or (root / "eslint.config.js").exists() or (root / "eslint.config.mjs").exists():
            cmd = "npx eslint ."
        else:
            cmd = "npx tsc --noEmit"
    elif lang == "go":
        cmd = "go vet ./..."
    else:
        raise ToolError(f"unknown language: {lang}")
    return _spawn(cmd, root, timeout=300, confirm=confirm)


def tool_build(attrs: dict, body: str, confirm: bool = True) -> str:
    where = attrs.get("path", ".")
    lang, root = _detect_lang_root(where)
    if not lang or not root:
        raise ToolError(f"<build path={where!r}>: no project marker found")
    if lang == "python":
        cmd = "python3 -m build"
    elif lang == "rust":
        cmd = "cargo build --release"
    elif lang == "node":
        cmd = f"{_node_runner(root)} run build"
    elif lang == "go":
        cmd = "go build ./..."
    else:
        raise ToolError(f"unknown language: {lang}")
    return _spawn(cmd, root, timeout=900, confirm=confirm)


# --- web search + fetch ---

class _HTMLStripper(HTMLParser):
    """Minimal HTML to text. Drops script/style, keeps newlines around blocks."""

    BLOCK_TAGS = {"p", "br", "div", "li", "h1", "h2", "h3", "h4", "h5", "h6",
                  "tr", "section", "article", "pre", "hr"}

    def __init__(self):
        super().__init__()
        self._buf: list[str] = []
        self._skip = 0

    def handle_starttag(self, tag, attrs):
        if tag in {"script", "style", "noscript"}:
            self._skip += 1
        elif tag in self.BLOCK_TAGS:
            self._buf.append("\n")

    def handle_endtag(self, tag):
        if tag in {"script", "style", "noscript"}:
            self._skip = max(0, self._skip - 1)
        elif tag in self.BLOCK_TAGS:
            self._buf.append("\n")

    def handle_data(self, data):
        if self._skip:
            return
        self._buf.append(data)

    def text(self) -> str:
        out = "".join(self._buf)
        # Collapse extra whitespace.
        out = re.sub(r"\n\s*\n+", "\n\n", out)
        out = re.sub(r"[ \t]+", " ", out)
        return out.strip()


def _html_to_text(html: str) -> str:
    p = _HTMLStripper()
    try:
        p.feed(html)
    except Exception:
        # Fallback: strip tags by regex.
        return re.sub(r"<[^>]+>", " ", html)
    return p.text()


def _http_get(url: str, timeout: int = 12) -> str:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": "joe-agent/1.0 (Mozilla/5.0 compatible)",
            "Accept": "text/html,application/xhtml+xml",
        },
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        body = resp.read()
        try:
            charset = resp.headers.get_content_charset() or "utf-8"
        except Exception:
            charset = "utf-8"
        return body.decode(charset, errors="replace")


def tool_web_search(attrs: dict, body: str) -> str:
    query = attrs.get("query") or body.strip()
    if not query:
        raise ToolError("<web_search> requires query=\"...\" or body")
    url = "https://html.duckduckgo.com/html/?q=" + urllib.parse.quote(query)
    try:
        html = _http_get(url, timeout=12)
    except Exception as e:
        raise ToolError(f"web_search request failed: {e}") from e
    # Parse DDG HTML results. Each hit is in a div.result with an a.result__a.
    results: list[tuple[str, str, str]] = []
    for m in re.finditer(
        r'<a[^>]+class="[^"]*result__a[^"]*"[^>]*href="([^"]+)"[^>]*>(.*?)</a>'
        r'.*?<a[^>]+class="[^"]*result__snippet[^"]*"[^>]*>(.*?)</a>',
        html, re.DOTALL,
    ):
        href = urllib.parse.unquote(m.group(1))
        # DDG wraps real URLs in a redirect. Pull out the `uddg` param if present.
        rd = re.search(r"uddg=([^&]+)", href)
        if rd:
            href = urllib.parse.unquote(rd.group(1))
        title = _html_to_text(m.group(2)).strip()
        snippet = _html_to_text(m.group(3)).strip()
        results.append((title, href, snippet))
        if len(results) >= 6:
            break
    if not results:
        return f"(no results for {query!r})"
    lines = []
    for i, (title, href, snippet) in enumerate(results, 1):
        lines.append(f"{i}. {title}\n   {href}\n   {snippet[:240]}")
    out = "\n\n".join(lines)
    panel(f"Web search: {query!r}", Markdown(out), style="cyan",
          subtitle=f"{len(results)} results")
    return out


def tool_web_fetch(attrs: dict, body: str) -> str:
    url = attrs.get("url") or body.strip()
    if not url:
        raise ToolError("<web_fetch> requires url=\"...\" or body")
    if not (url.startswith("http://") or url.startswith("https://")):
        raise ToolError(f"<web_fetch>: {url!r} must be http(s)")
    try:
        html = _http_get(url, timeout=15)
    except Exception as e:
        raise ToolError(f"web_fetch failed: {e}") from e
    text = _html_to_text(html)
    if len(text) > 6000:
        text = text[:6000] + "\n\n[... truncated; page was longer ...]"
    panel(f"Fetched {url}", Markdown(text[:2500] + ("..." if len(text) > 2500 else "")),
          style="cyan", subtitle=f"{len(text)} chars")
    return text


# --- plan mode ---

@dataclasses.dataclass
class Plan:
    title: str
    steps: list[str]

    def render(self) -> Group:
        items = [Text(f"{i + 1}. {s}", style="white") for i, s in enumerate(self.steps)]
        return Group(Text(self.title, style="bold cyan"), *items)


def parse_plan_block(text: str) -> Optional[Plan]:
    """Extract a <plan title="...">...</plan> block. Steps are numbered lines."""
    m = re.search(r'<plan(\s+title="([^"]*)")?\s*>(.*?)</plan>', text, re.DOTALL)
    if not m:
        return None
    title = m.group(2) or "Plan"
    body = m.group(3).strip()
    steps: list[str] = []
    for line in body.splitlines():
        ln = line.strip()
        if not ln:
            continue
        # Match "1." or "1)" or "-" or "*" prefixes.
        ln = re.sub(r"^(\d+[\.\)]|[-*])\s+", "", ln)
        if ln:
            steps.append(ln)
    if not steps:
        return None
    return Plan(title=title, steps=steps)


def _plan_validate(plan: Plan, cwd: Path) -> tuple[list[str], list[str]]:
    """Look at each plan step for file-path-shaped tokens and check the
    repo for them. Returns (present, missing) lists. Used to warn the
    user before kicking the plan loop on a hallucinated codebase.
    """
    # Pull the repo's file list (empty if not a git repo).
    repo_files: set[str] = set()
    try:
        cp = subprocess.run(
            ["git", "-C", str(cwd), "ls-files"],
            capture_output=True, text=True, timeout=5,
        )
        if cp.returncode == 0:
            repo_files = set(cp.stdout.splitlines())
    except Exception:
        pass
    # File-shaped token: looks like a path with a recognised code extension.
    pat = re.compile(
        r"(?:[\w./@-]+/)?[\w@-]+\."
        r"(?:ts|tsx|js|jsx|py|rs|go|rb|java|kt|swift|c|cc|cpp|h|hpp|md|toml|yaml|yml|json|sh)"
    )
    seen: set[str] = set()
    present: list[str] = []
    missing: list[str] = []
    for step in plan.steps:
        for m in pat.findall(step):
            tok = m.strip("` ,.:;\"'")
            if tok in seen:
                continue
            seen.add(tok)
            # Match by suffix so 'src/foo.py' hits 'project/src/foo.py'.
            hit = (
                tok in repo_files
                or any(rf.endswith(tok) for rf in repo_files)
                or (cwd / tok).exists()
            )
            (present if hit else missing).append(tok)
    return present, missing


def _detect_framework(cwd: Path) -> str:
    """Best-effort hint at the project's framework/stack so the executor
    doesn't write Express middleware into a Next.js App Router repo.
    Returns a one-line description like 'Next.js 16 App Router (no src/)'.
    """
    hints: list[str] = []
    # JS/TS world: package.json + dir layout.
    pkg = cwd / "package.json"
    if pkg.is_file():
        try:
            data = json.loads(pkg.read_text())
            deps = {**(data.get("dependencies") or {}),
                    **(data.get("devDependencies") or {})}
            if "next" in deps:
                next_v = deps["next"]
                if (cwd / "app").is_dir():
                    hints.append(f"Next.js {next_v} App Router (routes at app/api/<name>/route.ts)")
                elif (cwd / "src" / "app").is_dir():
                    hints.append(f"Next.js {next_v} App Router (routes at src/app/api/<name>/route.ts)")
                elif (cwd / "pages").is_dir():
                    hints.append(f"Next.js {next_v} Pages Router (routes at pages/api/<name>.ts)")
                else:
                    hints.append(f"Next.js {next_v}")
            elif "express" in deps:
                hints.append(f"Express {deps['express']}")
            elif "fastify" in deps:
                hints.append(f"Fastify {deps['fastify']}")
            elif "@nestjs/core" in deps:
                hints.append(f"NestJS")
            elif "react" in deps and "vite" in deps:
                hints.append(f"Vite + React {deps.get('react', '?')}")
            elif "react" in deps:
                hints.append(f"React {deps.get('react', '?')}")
            if "next-auth" in deps:
                hints.append(f"next-auth {deps['next-auth']}")
            if "@prisma/client" in deps:
                hints.append(f"Prisma {deps['@prisma/client']}")
            if "drizzle-orm" in deps:
                hints.append("Drizzle ORM")
            if "tailwindcss" in deps:
                hints.append(f"Tailwind {deps['tailwindcss']}")
        except Exception:
            pass
    # Python world.
    pyproj = cwd / "pyproject.toml"
    if pyproj.is_file():
        try:
            txt = pyproj.read_text()
            if "fastapi" in txt.lower():
                hints.append("FastAPI")
            elif "django" in txt.lower():
                hints.append("Django")
            elif "flask" in txt.lower():
                hints.append("Flask")
            if "ruff" in txt.lower():
                hints.append("ruff")
            if "pytest" in txt.lower():
                hints.append("pytest")
        except Exception:
            pass
    # Rust.
    if (cwd / "Cargo.toml").is_file():
        hints.append("Rust (Cargo)")
    # Go.
    if (cwd / "go.mod").is_file():
        hints.append("Go modules")
    return "; ".join(hints) if hints else "unknown stack"


def _plan_grounding(cwd: Path) -> str:
    """Probe cwd before plan execution so steps don't hallucinate files.

    Captures: real pwd, git repo root, framework detection, git ls-files
    truncated to 80 entries, top-level ls. Injected as <plan_environment>
    into every step prompt so the executor grounds against actual paths
    and frameworks instead of inventing speculative ones (e.g., Express
    middleware in a Next.js App Router project).
    """
    parts: list[str] = []
    parts.append(f"pwd: {cwd}")
    framework = _detect_framework(cwd)
    parts.append(f"detected stack: {framework}")
    try:
        gp = subprocess.run(
            ["git", "-C", str(cwd), "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=3,
        )
        if gp.returncode == 0 and gp.stdout.strip():
            parts.append(f"git repo: {gp.stdout.strip()}")
            ls = subprocess.run(
                ["git", "-C", str(cwd), "ls-files"],
                capture_output=True, text=True, timeout=5,
            )
            if ls.returncode == 0:
                all_files = ls.stdout.splitlines()
                files = all_files[:80]
                parts.append(
                    f"git ls-files (first {len(files)} of "
                    f"{len(all_files)}; YOU MUST use only these paths or "
                    f"propose new files under existing parent dirs):\n"
                    + "\n".join(f"  {f}" for f in files)
                )
        else:
            parts.append("git repo: (cwd is not in a git repo)")
            ls = subprocess.run(
                ["ls", "-la", str(cwd)],
                capture_output=True, text=True, timeout=3,
            )
            if ls.returncode == 0:
                parts.append("ls -la:\n" + ls.stdout[:2000])
    except Exception as e:
        parts.append(f"grounding probe error: {e}")
    return (
        "<plan_environment>\n"
        + "\n".join(parts)
        + "\nIMPORTANT: do NOT invent paths that don't appear above. "
        "If the framework is Next.js App Router, the right place for an "
        "API route is app/api/<name>/route.ts -- NOT pages/api/, NOT "
        "src/app/api/ unless src/ appears in the listing above. Match "
        "the existing convention exactly.\n"
        "</plan_environment>"
    )


def _plan_change_count() -> int:
    """How many provenance entries exist right now (for delta tracking)."""
    try:
        c = _provdb()
        n = c.execute("SELECT COUNT(*) FROM provenance").fetchone()[0]
        c.close()
        return int(n)
    except Exception:
        return 0


def execute_plan(
    plan: Plan,
    model: str,
    coder_model: str,
    cwd: Path,
    session: Optional[str],
    allow_all_bash: bool,
) -> None:
    """Step through a plan with user approval after each step.

    Reports plan complete only if at least one provenance entry was added
    during execution. Otherwise reports 'plan failed: 0 changes landed' so
    the user doesn't get a false 'success' when the executor hallucinated
    against files that don't exist.
    """
    panel(plan.title, plan.render(), style="bright_cyan",
          subtitle=f"{len(plan.steps)} steps")

    # Prerequisite check: if every file mentioned in the steps is absent
    # from the repo, the planner likely hallucinated a codebase. Warn but
    # let the user proceed (some plans create new files).
    present, missing = _plan_validate(plan, cwd)
    if missing and not present:
        panel(
            "plan prerequisite check failed",
            Text.from_markup(
                f"[bold red]The plan references {len(missing)} path(s) that "
                f"don't exist in this repo[/]:\n"
                + "\n".join(f"  - [yellow]{p}[/]" for p in missing[:12])
                + (f"\n  ... +{len(missing) - 12} more" if len(missing) > 12 else "")
                + "\n\n[dim]Likely the planner hallucinated a codebase. "
                "Either /cwd to the real project, or refine the prompt with "
                "actual file names from the repo.[/]"
            ),
            style="red",
            subtitle=plan.title,
        )
        if not _confirm("Run the plan anyway?"):
            console.print("[yellow]plan aborted (failed prereq check)[/]")
            return
    elif missing:
        console.print(
            f"[dim]plan references {len(present)} known + {len(missing)} "
            f"unknown path(s); the unknown ones may be files the plan will "
            f"create.[/]"
        )

    if not _confirm(f"Execute this {len(plan.steps)}-step plan?"):
        console.print("[yellow]plan aborted[/]")
        return

    # Snapshot the provenance count up front so we can tell at the end
    # whether ANY real writes/edits landed during the plan.
    prov_before = _plan_change_count()
    grounding = _plan_grounding(cwd)

    for i, step in enumerate(plan.steps, 1):
        console.rule(f"[bold cyan]Step {i}/{len(plan.steps)}:[/] {step}")
        step_prov_before = _plan_change_count()
        prompt = (
            f"{grounding}\n\n"
            f"<plan_step n=\"{i}\" total=\"{len(plan.steps)}\">{step}</plan_step>\n\n"
            "Execute THIS step ONLY. Use the standard tools (write / edit / "
            "delegate / test / lint / etc.). When the step is complete, stop "
            "emitting tags and confirm in a single sentence.\n\n"
            "HARD RULES:\n"
            "  - Exactly ONE tag per response. Don't stack <write>, <edit>, "
            "    <read> in the same turn -- emit one, wait for the result.\n"
            "  - Use ONLY paths that appear in <plan_environment> above, OR "
            "    absolute paths the user gave you in the original request. "
            "    Inventing 'src/foo.py' when no such file is listed is a bug. "
            "    If the step needs a new file, propose the exact path and "
            "    confirm with a short prose sentence first.\n"
            "  - Stay on this step's task. Do NOT pivot to unrelated files "
            "    or repos if a tool errors. If you genuinely cannot proceed, "
            "    output exactly STOP: <reason> on its own line and stop.\n"
            "  - For code-writing tasks the first tag must be <delegate>, "
            "    not <write> (per the code-writing protocol).\n"
        )
        run_turn(
            model=model, coder_model=coder_model, user_msg=prompt,
            cwd=cwd, session=session, allow_all_bash=allow_all_bash,
            max_turns=MAX_AUTO_TURNS,
        )
        step_changes = _plan_change_count() - step_prov_before
        console.print(
            f"[dim]step {i} produced {step_changes} change(s)[/]"
        )
        if i < len(plan.steps):
            if not _confirm(f"Step {i} done. Continue to step {i + 1}?"):
                console.print(f"[yellow]plan stopped at step {i}[/]")
                break

    # Verdict based on actual changes, not on the model declaring victory.
    total_changes = _plan_change_count() - prov_before
    if total_changes == 0:
        panel(
            "plan failed",
            Text.from_markup(
                f"[bold red]0 changes landed.[/]\n"
                f"The executor declared steps 'complete' but no file was "
                f"written or edited. Likely causes:\n"
                f"  - cwd doesn't match the project the plan is about\n"
                f"  - the planner hallucinated a codebase that doesn't exist\n"
                f"  - the executor emitted placeholder paths and was rejected\n\n"
                f"Try: /cwd into the real project, or @reponame your-task."
            ),
            style="red",
            subtitle=plan.title,
        )
    else:
        panel(
            f"plan complete  ({total_changes} change{'s' if total_changes != 1 else ''})",
            Text(plan.title),
            style="green",
        )


def _guess_lexer(p: Path) -> str:
    return {
        ".py": "python", ".ts": "typescript", ".tsx": "tsx",
        ".js": "javascript", ".jsx": "jsx", ".rs": "rust",
        ".go": "go", ".sh": "bash", ".yml": "yaml", ".yaml": "yaml",
        ".json": "json", ".toml": "toml", ".md": "markdown",
        ".css": "css", ".html": "html", ".sql": "sql", ".rb": "ruby",
        ".swift": "swift", ".c": "c", ".cpp": "cpp", ".h": "c",
    }.get(p.suffix.lower(), "text")


_AFFIRMATIVE = {
    "y", "yes", "yeah", "yep", "ya", "yup", "yass",
    "sure", "ok", "okay", "k", "kk",
    "do it", "go", "go ahead", "ship it", "send it", "send",
    "absolutely", "definitely", "please",
    "fine", "alright", "aight", "righto",
    "+1", "👍",
}
_NEGATIVE = {
    "n", "no", "nope", "nah", "nay", "ne", "naw",
    "stop", "cancel", "abort", "skip", "pass",
    "-1", "👎",
}


def _confirm(question: str) -> bool:
    # JOE_AUTO_YES short-circuits everything (intended for scripts / piped use).
    if os.environ.get("JOE_AUTO_YES", "").strip() in {"1", "true", "yes"}:
        console.print(f"[bold yellow]{question}[/] [dim](JOE_AUTO_YES, auto-y)[/]")
        return True

    def _interpret(ans: str) -> bool:
        a = ans.strip().lower()
        if not a:
            return False  # bare Enter = the default 'N'
        if a in _AFFIRMATIVE:
            return True
        if a in _NEGATIVE:
            return False
        # Loose match: if the first word is affirmative, take it.
        first = a.split()[0]
        return first in _AFFIRMATIVE

    # Rich's Prompt.ask returns the default silently when stdin isn't a TTY,
    # which breaks piped tests (`yes y | joe -p ...`). When we detect that,
    # fall back to plain readline so piped input actually feeds the answer.
    if not sys.stdin.isatty():
        console.print(f"[bold yellow]{question}[/] [y/N]:", end=" ")
        try:
            ans = sys.stdin.readline()
        except (EOFError, KeyboardInterrupt):
            return False
        return _interpret(ans)
    ans = Prompt.ask(f"[bold yellow]{question}[/] [y/N]", default="N", show_default=False)
    return _interpret(ans)


# --------------------------------------------------------------------------
# Ollama
# --------------------------------------------------------------------------


def _ollama_once(model: str, prompt: str, timeout: int = 600) -> str:
    body = {"model": model, "prompt": prompt, "stream": False, "think": False}
    images = _drain_image_base64()
    if images:
        body["images"] = images
    req = urllib.request.Request(
        OLLAMA_URL,
        data=json.dumps(body).encode(),
        headers={"Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return json.loads(r.read())["response"]


def _ollama_stream_to_console(model: str, prompt: str) -> str:
    """Stream tokens to the console, Claude-Code-style.

    A 'thinking' spinner runs from the moment the request is sent until the
    first non-empty token arrives, then it's replaced by a streaming label
    and the tokens print as they come. Returns the full text.
    """
    body = {"model": model, "prompt": prompt, "stream": True, "think": False}
    images = _drain_image_base64()
    if images:
        body["images"] = images
        console.print(f"[bright_blue]attaching {len(images)} image(s) to this turn[/]")
    payload = json.dumps(body).encode()
    req = urllib.request.Request(OLLAMA_URL, data=payload, headers={"Content-Type": "application/json"})
    buf: list[str] = []

    with console.status(
        Text.from_markup(f"[bold cyan]{model}[/] is thinking..."),
        spinner="dots",
        spinner_style="cyan",
    ) as status:
        try:
            resp = urllib.request.urlopen(req, timeout=600)
        except Exception as e:
            console.print(f"[red]ollama call failed:[/] {e}")
            raise
        first_token_seen = False
        for raw in resp:
            line = raw.decode("utf-8", errors="ignore").strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            tok = obj.get("response", "")
            if tok:
                if not first_token_seen:
                    status.stop()
                    console.print(f"[bold cyan]{model}:[/]", end=" ")
                    first_token_seen = True
                console.print(tok, end="", soft_wrap=True)
                sys.stdout.flush()
                buf.append(tok)
            if obj.get("done"):
                break
        resp.close()
    if buf:
        console.print()  # final newline after streaming
    return "".join(buf)


# --------------------------------------------------------------------------
# Slash commands
# --------------------------------------------------------------------------


SLASH_COMMAND_NAMES = (
    "help", "exit", "quit", "cwd", "model", "coder", "clear", "save", "load",
    "sessions", "whoami", "cost", "compact", "yolo", "doctor",
    "read", "run", "diff", "copy", "history", "undo", "redo",
    "plan", "test", "lint", "build", "explain", "profile",
    "commit", "push", "pr", "issue", "snap",
    "tasks", "task",
    "listen", "speak", "paste", "attach", "journal",
    "web", "fetch",
    "tools", "repos", "agents",
    "recall", "review", "timer", "fork", "share",
)


class _JoeCompleter:  # pragma: no cover (prompt_toolkit-dependent)
    """Tab-complete slash commands, @repo, @@agent, and file paths."""

    def __init__(self) -> None:
        if not _PT_AVAILABLE:
            return
        self._path = PathCompleter(expanduser=True)

    def get_completions(self, document, complete_event):  # noqa: D401
        from prompt_toolkit.completion import Completion
        text = document.text_before_cursor
        word = document.get_word_before_cursor(WORD=True)
        # /<slash>
        if text.startswith("/") and " " not in text:
            prefix = text[1:]
            for name in SLASH_COMMAND_NAMES:
                if name.startswith(prefix):
                    yield Completion(name, start_position=-len(prefix))
            return
        # @@agent
        if text.startswith("@@") and " " not in text:
            prefix = text[2:]
            for a in _list_agents():
                if a.name.startswith(prefix):
                    yield Completion(a.name, start_position=-len(prefix),
                                     display_meta=a.description[:60])
            return
        # @repo
        if text.startswith("@") and not text.startswith("@@") and " " not in text:
            prefix = text[1:]
            for r in _active_repos():
                if r.name.startswith(prefix):
                    yield Completion(r.name, start_position=-len(prefix),
                                     display_meta=str(r).replace(str(HOME), "~"))
            return
        # After certain slashes, complete file paths.
        path_slashes = ("/read ", "/diff ", "/explain ", "/attach ",
                        "/test ", "/lint ", "/build ", "/run ")
        if any(text.startswith(s) for s in path_slashes):
            from prompt_toolkit.document import Document
            yield from self._path.get_completions(
                Document(word, cursor_position=len(word)), complete_event,
            )


_pt_session: Optional["PromptSession"] = None


def _get_input(cwd_short: str) -> str:
    """Prompt the user, preferring prompt_toolkit (tab + history). Rich fallback."""
    global _pt_session
    if _PT_AVAILABLE and sys.stdin.isatty():
        if _pt_session is None:
            _pt_session = PromptSession(
                history=FileHistory(str(INPUT_HISTORY_FILE)),
                completer=_JoeCompleter(),
                complete_while_typing=False,
                enable_history_search=True,
            )
        # ANSI: bold cyan "joe", reset, dim "(cwd)", reset, "> ".
        label = ANSI(
            f"\n\033[1;36mjoe\033[0m \033[2m({cwd_short})\033[0m > "
        )
        return _pt_session.prompt(label).strip()
    return Prompt.ask(f"\n[bold cyan]joe[/] [dim]({cwd_short})[/]").strip()


def _print_status_line(state: dict) -> None:
    """One-line status above each prompt: session, model, repo, ctx, tasks."""
    short_cwd = str(state["cwd"]).replace(str(HOME), "~")
    tk = session_token_estimate(state["session"])
    ratio = tk / CONTEXT_BUDGET_TOKENS
    ctx_color = "green" if ratio < 0.5 else "yellow" if ratio < 0.85 else "red"
    # Background task count.
    running = sum(1 for d in task_list() if d.get("status") == "running")
    yolo = os.environ.get("JOE_AUTO_YES", "").strip() in {"1", "true", "yes"}
    flags = []
    if state.get("speak"):
        flags.append(f"speak:{state.get('voice', 'on')}")
    if yolo:
        flags.append("[red bold]yolo[/]")
    if running:
        flags.append(f"tasks:{running}")
    flag_str = ("  " + "  ".join(flags)) if flags else ""
    bar = (
        f"[dim]{state['session']}[/]  "
        f"[cyan]{state['model']}[/]  "
        f"[yellow]{short_cwd}[/]  "
        f"[{ctx_color}]ctx ~{tk}[/]"
        f"{flag_str}"
    )
    console.rule(Text.from_markup(bar), style="dim", align="left")


def _active_repos() -> list[Path]:
    """Best-effort list of git repos joe is aware of on this machine.

    Resolution order:
      1. ~/.joe-agent/repos.txt — one absolute path per line (user override).
      2. Otherwise: scan ~/* and ~/Desktop/* for directories with a .git
         entry. Caps at 32 to keep things fast.

    To pin your own list, drop a file at ~/.joe-agent/repos.txt with
    full paths (~ expansion is supported).
    """
    pinned = STATE_DIR / "repos.txt"
    if pinned.is_file():
        out: list[Path] = []
        for ln in pinned.read_text().splitlines():
            ln = ln.strip()
            if not ln or ln.startswith("#"):
                continue
            p = Path(os.path.expanduser(ln)).resolve()
            if p.is_dir():
                out.append(p)
        return out
    seen: set[str] = set()
    out = []
    for root in (HOME, HOME / "Desktop"):
        if not root.is_dir():
            continue
        try:
            children = sorted(root.iterdir())
        except OSError:
            continue
        for p in children:
            if not p.is_dir():
                continue
            if str(p) in seen:
                continue
            if (p / ".git").exists() or (p / ".hg").exists():
                out.append(p); seen.add(str(p))
            if len(out) >= 32:
                return out
    return out


def slash_help() -> None:
    body = (
        "[bold cyan]session[/]\n"
        "[bold]/help[/]                this message\n"
        "[bold]/exit[/], [bold]/quit[/]         leave the REPL\n"
        "[bold]/cwd[/] [path]          show or change working directory\n"
        "[bold]/model[/] [name]        show or change orchestrator model\n"
        "[bold]/coder[/] [name]        show or change code-delegate model\n"
        "[bold]/clear[/]               wipe the screen + reset conversation\n"
        "[bold]/save <name>[/]         save this session under [italic]name[/]\n"
        "[bold]/load <name>[/]         restore a saved session\n"
        "[bold]/sessions[/]            list saved sessions\n"
        "[bold]/whoami[/]              show model / profile / repo / RAG status\n"
        "[bold]/cost[/]                tokens estimated for this session + budget\n"
        "[bold]/compact[/]             summarise oldest turns to free context\n"
        "[bold]/yolo[/]                toggle JOE_AUTO_YES for this REPL\n"
        "[bold cyan]files + shell[/]\n"
        "[bold]/read <path>[/]         show a file with syntax highlighting\n"
        "[bold]/run <cmd>[/]           run a bash command (allow-list)\n"
        "[bold]/diff[/] [path]         git diff for path (or whole repo)\n"
        "[bold]/copy[/] [N]            pbcopy last code block (or Nth code block)\n"
        "[bold]/history[/] [N]         last N edits with ages\n"
        "[bold]/undo[/] [N]            revert the last N writes / edits\n"
        "[bold]/redo[/] [N]            re-apply the next undone edit\n"
        "[bold cyan]code workflow[/]\n"
        "[bold]/plan <task>[/]         multi-step plan with approval per step\n"
        "[bold]/test[/] [path]         pytest / cargo test / npm test (auto-detect)\n"
        "[bold]/lint[/] [path]         ruff / clippy / eslint / tsc (auto-detect)\n"
        "[bold]/build[/] [path]        cargo build / npm run build / etc.\n"
        "[bold]/explain <path>[/]      route a file to the coder for a summary\n"
        "[bold]/profile[/]             show active per-repo profile\n"
        "[bold cyan]git + github[/]\n"
        "[bold]/commit[/] [subject]    draft + apply a git commit\n"
        "[bold]/push[/] [remote]       push current branch (default: origin)\n"
        "[bold]/pr <sub>[/]            gh pr: list, view N, comment N, review N, create\n"
        "[bold]/issue <sub>[/]         gh issue: list, view N, comment N, new, close N\n"
        "[bold]/snap <sub>[/]          save | restore | list | drop  (tar repo state)\n"
        "[bold cyan]background + scheduling[/]\n"
        "[bold]&<cmd>[/]               start <cmd> as a background task\n"
        "[bold]/tasks[/]               list background tasks\n"
        "[bold]/task <id>[/]           show one task (or '/task kill <id>')\n"
        "[bold cyan]voice + vision + journal[/]\n"
        "[bold]/listen[/] [--duration N]  record + transcribe + send as prompt\n"
        "[bold]/speak[/] [voice|off|text]  toggle auto-TTS or pick a voice\n"
        "[bold]/paste[/]               attach clipboard image to next turn\n"
        "[bold]/attach <path>[/]       attach an image file to next turn\n"
        "[bold]/journal[/] [text]      open today's journal (or append a line)\n"
        "[bold cyan]search + web[/]\n"
        "[bold]/web <query>[/]         DuckDuckGo HTML search\n"
        "[bold]/fetch <url>[/]         fetch a URL and strip to text\n"
        "[bold cyan]misc[/]\n"
        "[bold]/tools[/]               list available tool tags + protocol\n"
        "[bold]/repos[/]               list active repos the model can search\n"
        "[bold]/agents[/]              list named subagent personas\n"
        "[bold]/recall <q>[/]          search cross-session memory by similarity\n"
        "[bold]/review[/]              joe-gemma reviews the current git diff\n"
        "[bold]/timer <m>[/] [label]   pomodoro: macOS notification when done\n"
        "[bold]/fork <name>[/]         copy current session under a new name\n"
        "[bold]/share[/] [session]     export session to markdown in ~/.joe-agent/exports\n"
        "[bold]/blame <p>[/]:<line>   show provenance (prompt/model/agent) for a line\n"
        "[bold]/lessons <sub>[/]       list | add <rule> | drop <n> | distill | review\n"
        "[bold]/macro <sub>[/]         record <name> | stop | run <name> | list | drop\n"
        "[bold]/ask <question>[/]      grounded answer from the knowledge graph\n"
        "[bold]/inbox[/]               gh PRs / mentions / failing CI / pending tasks\n"
        "[bold]/reflect[/]             write today's developer-journal entry\n"
        "[bold]/doctor[/]              run a quick env/dependency health check\n"
        "[bold]///[/]                  enter multi-line mode (end with another ///)\n"
        "[bold]@<repo> <msg>[/]        run a turn with cwd switched to that repo\n"
        "[bold]@@<agent> <msg>[/]      run a turn under a named subagent persona\n"
    )
    panel("Slash commands", Text.from_markup(body), style="cyan")


def slash_tools() -> None:
    body = (
        "[bold]<read path=\"...\" />[/]\n"
        "[bold]<write path=\"...\">content</write>[/]\n"
        "[bold]<edit path=\"...\"><old>X</old><new>Y</new></edit>[/]\n"
        "[bold]<bash>cmd</bash>[/]\n"
        "[bold]<grep pattern=\"...\" path=\"...\" />[/]\n"
        "[bold]<glob pattern=\"...\" />[/]\n"
        "[bold]<delegate model=\"qwen2.5-coder:14b\">spec</delegate>[/]\n"
        "[bold]<test path=\"...\" />[/]                auto-detects pytest / cargo / npm\n"
        "[bold]<lint path=\"...\" />[/]                auto-detects ruff / clippy / eslint\n"
        "[bold]<build path=\"...\" />[/]               auto-detects build command\n"
        "[bold]<web_search query=\"...\" />[/]         DuckDuckGo HTML search\n"
        "[bold]<web_fetch url=\"...\" />[/]            fetch a URL + strip HTML\n"
        "[bold]<plan title=\"...\">steps</plan>[/]    multi-step plan with approval\n"
        "[bold]<image path=\"...\" />[/]               attach image for next vision turn\n"
    )
    panel("Tool protocol (XML tags the model emits)", Text.from_markup(body), style="cyan")


