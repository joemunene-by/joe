#!/usr/bin/env python3
"""joe-wake: always-on voice listener with "hey joe" wake-word detection.

Sits in a loop:
  1. Records short audio windows (default 3s) via `rec` with VAD trim.
  2. Transcribes each window with whisper-cli (the same binary joe-listen uses).
  3. Scans the transcript for the wake word ("hey joe", "joe", configurable).
  4. On match, records a longer follow-up utterance (up to --max-utterance s),
     feeds it to `joe -p`, and speaks the response back via `joe-speak`.
  5. Sleeps briefly between windows so the mic isn't pegged.

Designed to live in a long-running background process. Pair it with a
launchd LaunchAgent and you have an ambient agent that wakes when you
talk to it.

Usage:
  joe-wake                            defaults
  joe-wake --wake-word "yo joe"       custom phrase
  joe-wake --window 4                 window size in seconds
  joe-wake --model base.en            whisper model
  joe-wake --voice Daniel             tts voice (macOS only)

Stop with Ctrl-C.

Privacy: every window is recorded and transcribed locally. Nothing leaves
the box unless `joe -p` itself routes to a cloud model. The recorded
audio is discarded after transcription unless --keep-wav is set.
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HOME = Path.home()
DEFAULT_WAKE_WORDS = ("hey joe", "joe please", "yo joe", "okay joe")
DEFAULT_WHISPER_MODEL = "base.en"

MODEL_DIR_CANDIDATES = [
    Path("/opt/homebrew/share/whisper-cpp/models"),
    Path("/usr/local/share/whisper-cpp/models"),
    HOME / ".cache" / "whisper-cpp" / "models",
]


def _which(name: str) -> str:
    p = shutil.which(name)
    if not p:
        raise SystemExit(f"joe-wake: missing dependency {name!r}")
    return p


def _find_model(name: str) -> Path:
    for d in MODEL_DIR_CANDIDATES:
        p = d / f"ggml-{name}.bin"
        if p.exists():
            return p
    raise SystemExit(
        f"joe-wake: whisper model {name!r} not found. download with "
        f"download-ggml-model.sh {name}"
    )


def record_window(seconds: float, out: Path) -> bool:
    """Record `seconds` of audio to `out`. Returns False if recording is silent."""
    rec = _which("rec")
    cmd = [rec, "-q", "-r", "16000", "-c", "1", "-b", "16", str(out),
           "trim", "0", str(seconds)]
    cp = subprocess.run(cmd, capture_output=True, text=True)
    if cp.returncode != 0:
        return False
    if not out.exists() or out.stat().st_size < 1000:
        return False
    return True


def record_utterance(max_seconds: float, silence_s: float, out: Path) -> bool:
    """Record until silence_s of quiet OR max_seconds reached."""
    rec = _which("rec")
    cmd = [rec, "-q", "-r", "16000", "-c", "1", "-b", "16", str(out),
           "silence", "1", "0.1", "1%",
           "1", str(silence_s), "2%",
           "trim", "0", str(max_seconds)]
    cp = subprocess.run(cmd, capture_output=True, text=True)
    if cp.returncode != 0:
        return False
    if not out.exists() or out.stat().st_size < 2000:
        return False
    return True


def transcribe(wav: Path, model: str) -> str:
    cli = _which("whisper-cli")
    model_path = _find_model(model)
    cp = subprocess.run(
        [cli, "-m", str(model_path), "-f", str(wav),
         "-nt", "-l", "en", "--no-prints"],
        capture_output=True, text=True,
    )
    if cp.returncode != 0:
        return ""
    text = (cp.stdout or "").strip()
    lines = [ln for ln in text.splitlines() if ln and not ln.startswith("[")]
    return " ".join(lines).strip().lower()


def matches_wake(text: str, wake_words: list[str]) -> bool:
    """Whether `text` contains any wake-word phrase (loose match)."""
    if not text:
        return False
    norm = re.sub(r"[^a-z ]+", " ", text)
    norm = re.sub(r"\s+", " ", norm).strip()
    for w in wake_words:
        if w in norm:
            return True
    return False


def ask_joe(prompt: str) -> str:
    """Run joe -p and return its stdout."""
    joe = _which("joe")
    cp = subprocess.run(
        [joe, "-p", prompt],
        capture_output=True, text=True, timeout=600,
    )
    return (cp.stdout or "").strip()


def speak(text: str, voice: str) -> None:
    joe_speak = shutil.which("joe-speak")
    if joe_speak:
        subprocess.Popen(
            [joe_speak, "--voice", voice, "--background", text],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        return
    # Fallback: macOS say or Linux espeak.
    if sys.platform == "darwin":
        say = shutil.which("say")
        if say:
            subprocess.Popen([say, "-v", voice, text[:4000]],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        espeak = shutil.which("espeak") or shutil.which("espeak-ng")
        if espeak:
            subprocess.Popen([espeak, text[:4000]],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def main() -> int:
    ap = argparse.ArgumentParser(prog="joe-wake")
    ap.add_argument("--window", type=float, default=3.0,
                    help="seconds per wake-word listening window (default: 3)")
    ap.add_argument("--max-utterance", type=float, default=20.0,
                    help="max seconds to capture after wake (default: 20)")
    ap.add_argument("--silence", type=float, default=1.0,
                    help="seconds of silence to end an utterance (default: 1)")
    ap.add_argument("--model", default=DEFAULT_WHISPER_MODEL,
                    help=f"whisper model (default: {DEFAULT_WHISPER_MODEL})")
    ap.add_argument("--wake-word", action="append", default=[],
                    help="phrase to wake on (repeatable; default: hey joe / joe please / yo joe)")
    ap.add_argument("--voice", default="Samantha",
                    help="TTS voice (default: Samantha)")
    ap.add_argument("--cooldown", type=float, default=0.5,
                    help="sleep between windows (default: 0.5)")
    ap.add_argument("--keep-wav", action="store_true",
                    help="don't delete the recorded WAVs")
    args = ap.parse_args()

    wake_words = [w.lower() for w in (args.wake_word or DEFAULT_WAKE_WORDS)]
    print(f"[joe-wake] listening for: {', '.join(wake_words)!r}", file=sys.stderr)
    print(f"[joe-wake] window {args.window}s; max-utterance {args.max_utterance}s",
          file=sys.stderr)
    print(f"[joe-wake] whisper model: {args.model}; tts voice: {args.voice}",
          file=sys.stderr)
    print(f"[joe-wake] Ctrl-C to stop.", file=sys.stderr)

    try:
        while True:
            with tempfile.TemporaryDirectory() as td:
                window_wav = Path(td) / "window.wav"
                if not record_window(args.window, window_wav):
                    time.sleep(args.cooldown)
                    continue
                text = transcribe(window_wav, args.model)
                if not text:
                    time.sleep(args.cooldown)
                    continue
                if not matches_wake(text, wake_words):
                    time.sleep(args.cooldown)
                    continue
                print(f"[joe-wake] wake: {text!r}", file=sys.stderr)
                # Tone or quick acknowledgement so the user knows we're listening.
                speak("yes?", args.voice)
                utter_wav = Path(td) / "utter.wav"
                if not record_utterance(args.max_utterance, args.silence, utter_wav):
                    print("[joe-wake] no utterance captured.", file=sys.stderr)
                    continue
                prompt = transcribe(utter_wav, args.model)
                if args.keep_wav:
                    kept = HOME / ".joe-agent" / "voice"
                    kept.mkdir(parents=True, exist_ok=True)
                    (kept / f"wake-{int(time.time())}.wav").write_bytes(utter_wav.read_bytes())
                if not prompt:
                    print("[joe-wake] empty transcription.", file=sys.stderr)
                    continue
                print(f"[joe-wake] heard: {prompt!r}", file=sys.stderr)
                answer = ask_joe(prompt)
                if not answer:
                    speak("sorry, no answer.", args.voice)
                    continue
                print(f"[joe-wake] said: {answer[:200]}", file=sys.stderr)
                speak(answer, args.voice)
                # Don't immediately re-wake on the model's own audio echo.
                time.sleep(2)
    except KeyboardInterrupt:
        print("\n[joe-wake] stopped.", file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
