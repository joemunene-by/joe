{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "joe",
  "version": "0.3.0",
  "identifier": "com.joe-agent.menubar",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "joe",
        "width": 920,
        "height": 720,
        "minWidth": 520,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "joe-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "joe"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Native desktop surface for the joe agent",
    "longDescription": "Menu-bar tray + full desktop app for joe. Permission-gated file tree, git pane, agent chat, and a permissions inspector. Everything runs locally — no embedded model, no telemetry."
  }
}
