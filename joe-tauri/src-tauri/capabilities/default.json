{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "joe desktop + menu-bar capabilities. User-defined fs/git/shell/agent commands are exported via the invoke_handler in main.rs; everything below is the platform-side surface (windows, dialogs, shell-plugin).",
  "windows": ["main", "desktop"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible",
    "core:window:allow-set-title",
    "core:webview:allow-create-webview-window",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm"
  ]
}
